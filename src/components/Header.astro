---
import {
  buildLocalePath,
  detectLocaleFromPath,
  stripLocalePrefix,
  SUPPORTED_LOCALES,
} from '../lib/i18n.js';

export interface Props {
  activeNav?: string; // e.g. 'como-funciona', 'precios', 'recursos'
}
const { activeNav } = Astro.props;
const currentPath = Astro.url.pathname;
const currentLocale = detectLocaleFromPath(currentPath);
const currentBasePath = stripLocalePrefix(currentPath);
const localeOptions = SUPPORTED_LOCALES.map((locale) => ({
  ...locale,
  href: buildLocalePath(locale.code, currentBasePath),
  isActive: locale.code === currentLocale,
}));
