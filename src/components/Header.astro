<script>
  function detectLocale(pathname) {
    if (pathname === '/en' || pathname.startsWith('/en/')) {
      return 'en';
    }

    if (pathname === '/pt' || pathname.startsWith('/pt/')) {
      return 'pt';
    }

    return 'es';
  }

  function normalizePath(pathname) {
    if (!pathname) {
      return '/';
    }

    let normalized = pathname.startsWith('/') ? pathname : `/${pathname}`;
    normalized = normalized.replace(/\/index\.html$/i, '/');
    normalized = normalized.replace(/\/{2,}/g, '/');

    if (normalized !== '/' && !normalized.endsWith('/')) {
      normalized = `${normalized}/`;
    }

    return normalized || '/';
  }

  function stripLocale(pathname) {
    const normalized = normalizePath(pathname);
    const locale = detectLocale(normalized);

    if (locale === 'es') {
      return normalized;
    }

    const prefix = `/${locale}`;
    const stripped = normalized.slice(prefix.length) || '/';
    return stripped.startsWith('/') ? normalizePath(stripped) : normalizePath(`/${stripped}`);
  }

  function buildLocaleHref(locale, pathname) {
    const basePath = stripLocale(pathname);

    if (locale === 'es') {
      return basePath;
    }

    return normalizePath(`/${locale}${basePath === '/' ? '/' : basePath}`);
  }

  function syncLanguageSwitchers() {
    const pathname = window.location.pathname;
    const currentLocale = detectLocale(pathname);

    document.querySelectorAll('[data-language-switcher]').forEach((switcher) => {
      const current = switcher.querySelector('[data-language-current]');
      const currentFlag = switcher.querySelector('[data-language-flag]');

      if (current) {
        current.textContent = currentLocale.toUpperCase();
      }

      if (currentFlag) {
        currentFlag.setAttribute(
          'src',
          currentLocale === 'en'
            ? '/flags/gb.svg'
            : currentLocale === 'pt'
              ? '/flags/pt.svg'
              : '/flags/es.svg',
        );
      }

      switcher.querySelectorAll('[data-locale-option]').forEach((link) => {
        const locale = link.getAttribute('data-locale-option');

        if (!locale) {
          return;
        }

        const isActive = locale === currentLocale;

        link.setAttribute('href', buildLocaleHref(locale, pathname));
        link.classList.toggle('is-active', isActive);

        if (isActive) {
          link.setAttribute('aria-current', 'page');
        } else {
          link.removeAttribute('aria-current');
        }
      });
    });
  }

  function closeMobile() {
    document.getElementById('mobileMenu')?.classList.remove('active');
    document.getElementById('hamburgerBtn')?.classList.remove('active');
    document.body.style.overflow = '';
  }

  document.getElementById('hamburgerBtn')?.addEventListener('click', function () {
    this.classList.toggle('active');
    document.getElementById('mobileMenu')?.classList.toggle('active');
    document.body.style.overflow = this.classList.contains('active') ? 'hidden' : '';
  });

  syncLanguageSwitchers();
</script>

