---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import entryLogo from '../../reelevo-brand-logo-transparent-shadow.png';
import { normalizePrimarySiteUrl } from '../lib/i18n.js';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  activeNav?: string;
  schema?: object | object[];
  enableEntrySplash?: boolean;
}

const {
  title,
  description,
  canonical: canonicalInput = Astro.url.href,
  ogTitle = title,
  ogDescription = description,
  ogImage: ogImageInput = 'https://www.gmvsolutions.es/factory-bg.jpg',
  activeNav,
  schema,
  enableEntrySplash = Astro.url.pathname === '/',
} = Astro.props;

const canonical = normalizePrimarySiteUrl(canonicalInput);
const ogImage = normalizePrimarySiteUrl(ogImageInput);
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  {enableEntrySplash && (
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const splashKey = 'reelevo-entry-splash-seen';

        root.classList.add('entry-splash-booting');

        try {
          if (window.sessionStorage.getItem(splashKey) !== '1') {
            root.classList.add('show-entry-splash');
            window.sessionStorage.setItem(splashKey, '1');
          }
        } catch {
          root.classList.add('show-entry-splash');
        } finally {
          root.classList.remove('entry-splash-booting');
        }
      })();
    </script>
  )}

  {enableEntrySplash && (
    <style is:inline>
      html,
      body {
        background: #000;
      }

      html.entry-splash-booting body,
      html.show-entry-splash body {
        overflow: hidden;
      }

      .site-shell {
        opacity: 1;
        visibility: visible;
        transition: opacity .6s ease, visibility 0s linear 0s;
      }

      .entry-splash {
        position: fixed;
        inset: 0;
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        background: #000;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transition: opacity .6s ease, visibility 0s linear .6s;
      }

      .entry-splash__logo-wrap {
        position: relative;
        z-index: 1;
        opacity: 0;
        transform: translateY(12px);
        filter: blur(10px);
        transition: opacity .42s ease, transform .6s cubic-bezier(.22,1,.36,1), filter .6s ease;
      }

      .entry-splash__logo {
        width: min(62vw, 420px);
        height: auto;
        transform: scale(1);
        transform-origin: 58% center;
        filter: drop-shadow(0 12px 34px rgba(0,0,0,.42));
        transition: transform .92s cubic-bezier(.16,1,.3,1), opacity .5s ease;
      }

      html.entry-splash-booting .site-shell,
      html.show-entry-splash .site-shell {
        opacity: 0 !important;
        visibility: hidden !important;
        pointer-events: none !important;
      }

      html.entry-splash-booting .entry-splash {
        opacity: 0 !important;
        visibility: hidden !important;
        pointer-events: none !important;
      }

      html.show-entry-splash .entry-splash {
        opacity: 1 !important;
        visibility: visible !important;
        pointer-events: auto !important;
        transition: opacity .6s ease;
      }

      .entry-splash-logo-visible .entry-splash__logo-wrap {
        opacity: 1;
        transform: translateY(0);
        filter: blur(0);
      }

      .entry-splash-logo-visible .entry-splash__logo {
        animation: entryBreath 1.45s ease-in-out infinite;
      }

      .entry-splash-zoom .entry-splash__logo {
        animation: none;
        transform: scale(4.8);
        opacity: 0;
      }

      @keyframes entryBreath {
        0%, 100% { transform: scale(1); opacity: .9; }
        50% { transform: scale(1.05); opacity: 1; }
      }

      @media (max-width: 600px) {
        .entry-splash__logo {
          width: min(78vw, 300px);
        }

        .entry-splash-zoom .entry-splash__logo {
          transform: scale(5.6);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .entry-splash,
        .site-shell,
        .entry-splash__logo-wrap {
          transition: none;
        }

        .entry-splash__logo {
          animation: none;
          transition: none;
        }
      }
    </style>
  )}

  <!-- Cookiebot -->
  <script id="Cookiebot" src="https://consent.cookiebot.com/uc.js" data-cbid="555982fb-7d04-4596-8a45-fa2d446a3892" data-blockingmode="auto" type="text/javascript"></script>
  
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-M223Z398');</script>
    <!-- End Google Tag Manager -->

  <!-- Google tag (gtag.js) — GA4 + Google Ads -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-JJCZ6M3T8Y"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-JJCZ6M3T8Y');
    gtag('config', 'AW-18000536518');
  </script>

  <!-- SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <meta name="author" content="GMV Solutions" />
  <meta name="theme-color" content="#F4521E" />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="REELEVO by GMV Solutions" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={ogTitle} />
  <meta property="og:description" content={ogDescription} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="es_ES" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={ogTitle} />
  <meta name="twitter:description" content={ogDescription} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Schema.org -->
  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}

  <!-- Google Fonts -->
  <link rel="dns-prefetch" href="//consent.cookiebot.com" />
  <link rel="dns-prefetch" href="//consentcdn.cookiebot.com" />
  <link rel="dns-prefetch" href="//www.googletagmanager.com" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&family=DM+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  />

  <!-- Slot for page-specific head content (extra schema, etc.) -->
  <slot name="head" />
</head>

<body>
  {enableEntrySplash && (
    <div class="entry-splash" aria-hidden="true">
      <div class="entry-splash__logo-wrap">
        <img
          class="entry-splash__logo"
          src={entryLogo.src}
          width={entryLogo.width}
          height={entryLogo.height}
          alt=""
          decoding="async"
        />
      </div>
    </div>
  )}

  <div class="site-shell">
    <div class="hero-bg"></div>
    <Header activeNav={activeNav} />

    <main>
      <slot />
    </main>

    <Footer />
  </div>

  {enableEntrySplash && (
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const logoRevealDelay = 220;
        const pulseDuration = 3000;
        const zoomDuration = 920;
        const blackoutHold = 180;

        if (!root.classList.contains('show-entry-splash')) {
          return;
        }

        window.setTimeout(() => {
          root.classList.add('entry-splash-logo-visible');
        }, logoRevealDelay);

        window.setTimeout(() => {
          root.classList.add('entry-splash-zoom');
        }, logoRevealDelay + pulseDuration);

        window.setTimeout(() => {
          root.classList.remove('entry-splash-zoom');
          root.classList.remove('entry-splash-logo-visible');
          root.classList.remove('show-entry-splash');
        }, logoRevealDelay + pulseDuration + zoomDuration + blackoutHold);
      })();
    </script>
  )}
</body>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-M223Z398"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->
</html>
