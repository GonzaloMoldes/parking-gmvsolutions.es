---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  date: string;
  category: string;
  readTime: string;
  schema?: object;
}

const { title, description, date, category, readTime, schema } = Astro.props;

const dateFormatted = new Date(date).toLocaleDateString('es-ES', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout title={title} description={description} schema={schema} activeNav="recursos">
  <article class="article-page">
    <div class="article-container">

      <nav class="article-breadcrumb">
        <a href="/recursos/">Recursos</a>
        <span>→</span>
        <span>{category}</span>
      </nav>

      <header class="article-header">
        <div class="article-category">{category}</div>
        <h1 class="article-title">{title}</h1>
        <div class="article-meta">
          <span class="article-date">{dateFormatted}</span>
          <span class="article-sep">·</span>
          <span class="article-time">⏱️ {readTime} lectura</span>
        </div>
      </header>

      <div class="article-body">
        <slot />
      </div>

      <div class="article-back">
        <a href="/recursos/" class="btn-ghost">← Volver a recursos</a>
      </div>

    </div>
  </article>
</BaseLayout>

<style>
  .article-page {
    padding: 120px 24px 80px;
  }

  .article-container {
    max-width: 760px;
    margin: 0 auto;
  }

  .article-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: .75rem;
    color: var(--gray2);
    margin-bottom: 40px;
  }

  .article-breadcrumb a {
    color: var(--gray);
    text-decoration: none;
    transition: color .2s;
  }

  .article-breadcrumb a:hover {
    color: var(--orange);
  }

  .article-category {
    font-family: 'DM Mono', monospace;
    font-size: .6rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 16px;
  }

  .article-title {
    font-family: 'Oswald', sans-serif;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .02em;
    line-height: 1.1;
    margin-bottom: 24px;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: .82rem;
    color: var(--gray);
    margin-bottom: 56px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border);
  }

  .article-sep { color: var(--gray2); }

  /* Prose */
  .article-body :global(h2) {
    font-family: 'Oswald', sans-serif;
    font-size: 1.3rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .03em;
    margin: 48px 0 16px;
    line-height: 1.2;
  }

  .article-body :global(h2:first-child) {
    margin-top: 0;
  }

  .article-body :global(h3) {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .03em;
    color: rgba(255,255,255,.85);
    margin: 32px 0 12px;
  }

  .article-body :global(p) {
    font-size: .95rem;
    color: rgba(255,255,255,.8);
    line-height: 1.75;
    margin-bottom: 20px;
  }

  .article-body :global(p em) {
    font-size: .82rem;
    color: var(--gray);
    font-style: normal;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    padding-left: 24px;
    margin-bottom: 20px;
  }

  .article-body :global(li) {
    font-size: .95rem;
    color: rgba(255,255,255,.8);
    line-height: 1.7;
    margin-bottom: 8px;
  }

  .article-body :global(strong) {
    color: var(--white);
    font-weight: 500;
  }

  .article-body :global(a) {
    color: var(--orange);
    text-decoration: none;
    border-bottom: 1px solid rgba(244,82,30,.3);
    transition: border-color .2s;
  }

  .article-body :global(a:hover) {
    border-color: var(--orange);
  }

  .article-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 48px 0;
  }

  /* Data card */
  .article-body :global(.data-card) {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-left: 3px solid var(--orange);
    border-radius: 4px;
    padding: 28px 32px;
    margin: 28px 0;
  }

  .article-body :global(.data-card p) {
    font-size: .9rem;
    line-height: 1.7;
    margin-bottom: 12px;
    color: rgba(255,255,255,.85);
  }

  .article-body :global(.data-card p:last-child) {
    margin-bottom: 0;
  }

  .article-body :global(.data-card strong) {
    color: var(--orange);
    font-size: 1rem;
  }

  /* Highlight box */
  .article-body :global(.highlight-box) {
    background: rgba(244,82,30,.08);
    border: 1px solid rgba(244,82,30,.25);
    border-radius: 4px;
    padding: 28px 32px;
    margin: 40px 0;
  }

  .article-body :global(.highlight-box p) {
    font-size: .9rem;
    line-height: 1.7;
    margin-bottom: 12px;
    color: rgba(255,255,255,.85);
  }

  .article-body :global(.highlight-box p:last-child) {
    margin-bottom: 0;
  }

  .article-body :global(.highlight-box strong) {
    color: var(--white);
  }

  .article-body :global(.highlight-box a) {
    color: var(--orange);
    font-weight: 500;
    border-bottom: none;
  }

  .article-back {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }
</style>
