---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  date: string;
  category: string;
  readTime: string;
  canonical?: string;
  schema?: object | object[];
  keywords?: string;
  wordCount?: number;
}

const { title, description, date, category, readTime, canonical, schema, keywords, wordCount } = Astro.props;

const dateFormatted = new Date(date).toLocaleDateString('es-ES', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const breadcrumbSchema = canonical
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Inicio",
          "item": "https://www.gmvsolutions.es/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Blog",
          "item": "https://www.gmvsolutions.es/blog/"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": title,
          "item": canonical
        }
      ]
    }
  : null;

const schemaList = Array.isArray(schema)
  ? (breadcrumbSchema ? [...schema, breadcrumbSchema] : schema)
  : (schema ? (breadcrumbSchema ? [schema, breadcrumbSchema] : [schema]) : (breadcrumbSchema ? [breadcrumbSchema] : undefined));
---

<BaseLayout title={title} description={description} canonical={canonical} schema={schemaList} activeNav="recursos">
  <article class="article-page">
    <div class="article-container">

      <nav class="article-breadcrumb">
        <a href="/">Inicio</a>
        <span>→</span>
        <a href="/blog/">Blog</a>
        <span>→</span>
        <span>{category}</span>
      </nav>

      <header class="article-header">
        <div class="article-category">{category}</div>
        <h1 class="article-title">{title}</h1>
        <div class="article-meta">
          <span class="article-date">{dateFormatted}</span>
          <span class="article-sep">·</span>
          <span class="article-time">⏱️ {readTime} lectura</span>
        </div>
        <div class="article-author">Contenido editorial de GMV Solutions · Documentación operativa industrial para pymes</div>
      </header>

      <div class="article-body">
        <slot />
      </div>

      <div class="article-back">
        <a href="/recursos/" class="btn-ghost">← Volver a recursos</a>
      </div>

    </div>
  </article>
</BaseLayout>

<style>
  .article-page {
    padding: 120px 24px 80px;
  }

  .article-container {
    max-width: 980px;
    margin: 0 auto;
    background: rgba(60, 60, 60, 0.95);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 48px 48px 40px;
  }

  .article-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: .75rem;
    color: var(--gray2);
    margin-bottom: 40px;
  }

  .article-breadcrumb a {
    color: var(--gray);
    text-decoration: none;
    transition: color .2s;
  }

  .article-breadcrumb a:hover {
    color: var(--orange);
  }

  .article-category {
    font-family: 'DM Mono', monospace;
    font-size: .6rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 16px;
  }

  .article-title {
    font-family: 'Oswald', sans-serif;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .02em;
    line-height: 1.1;
    margin-bottom: 24px;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: .82rem;
    color: var(--gray);
    margin-bottom: 56px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border);
  }

  .article-sep { color: var(--gray2); }

  .article-author {
    font-size: .78rem;
    color: var(--gray);
    margin-top: -36px;
    margin-bottom: 40px;
  }

  /* Prose */
  .article-body :global(h2) {
    font-family: 'Oswald', sans-serif;
    font-size: 1.3rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .03em;
    margin: 48px 0 16px;
    line-height: 1.2;
  }

  .article-body :global(h2:first-child) {
    margin-top: 0;
  }

  .article-body :global(h3) {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .03em;
    color: rgba(255,255,255,.85);
    margin: 32px 0 12px;
  }

  .article-body :global(p) {
    font-size: 17px;
    color: rgba(255,255,255,.8);
    line-height: 1.75;
    margin-bottom: 20px;
  }

  .article-body :global(p em) {
    font-size: .82rem;
    color: var(--gray);
    font-style: normal;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    padding-left: 24px;
    margin-bottom: 20px;
  }

  .article-body :global(li) {
    font-size: 17px;
    color: rgba(255,255,255,.8);
    line-height: 1.7;
    margin-bottom: 8px;
  }

  .article-body :global(strong) {
    color: var(--white);
    font-weight: 500;
  }

  .article-body :global(a) {
    color: var(--orange);
    text-decoration: none;
    border-bottom: 1px solid rgba(244,82,30,.3);
    transition: border-color .2s;
  }

  .article-body :global(a:hover) {
    border-color: var(--orange);
  }

  .article-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 48px 0;
  }

  /* Data card */
  .article-body :global(.data-card) {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-left: 3px solid var(--orange);
    border-radius: 4px;
    padding: 28px 32px;
    margin: 28px 0;
  }

  .article-body :global(.data-card p) {
    font-size: .9rem;
    line-height: 1.7;
    margin-bottom: 12px;
    color: rgba(255,255,255,.85);
  }

  .article-body :global(.data-card p:last-child) {
    margin-bottom: 0;
  }

  .article-body :global(.data-card strong) {
    color: var(--orange);
    font-size: 1rem;
  }

  /* Highlight box */
  .article-body :global(.highlight-box) {
    background: rgba(244,82,30,.08);
    border: 1px solid rgba(244,82,30,.25);
    border-radius: 4px;
    padding: 28px 32px;
    margin: 40px 0;
  }

  .article-body :global(.highlight-box p) {
    font-size: .9rem;
    line-height: 1.7;
    margin-bottom: 12px;
    color: rgba(255,255,255,.85);
  }

  .article-body :global(.highlight-box p:last-child) {
    margin-bottom: 0;
  }

  .article-body :global(.highlight-box strong) {
    color: var(--white);
  }

  .article-body :global(.highlight-box a) {
    color: var(--orange);
    font-weight: 500;
    border-bottom: none;
  }

  .article-body :global(.related-links) {
    margin: 48px 0 40px;
    padding: 28px 32px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .article-body :global(.related-links-label) {
    font-family: 'DM Mono', monospace;
    font-size: .62rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 16px;
  }

  .article-body :global(.related-links-grid) {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .article-body :global(.related-link-card) {
    display: block;
    text-decoration: none;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 20px 18px;
    transition: border-color .2s, transform .2s;
  }

  .article-body :global(.related-link-card:hover) {
    border-color: var(--border-hover);
    transform: translateY(-2px);
  }

  .article-body :global(.related-link-kicker) {
    font-family: 'DM Mono', monospace;
    font-size: .62rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--gray2);
    margin-bottom: 10px;
  }

  .article-body :global(.related-link-title) {
    font-family: 'Oswald', sans-serif;
    font-size: .95rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .03em;
    line-height: 1.25;
    margin-bottom: 10px;
    color: var(--white);
  }

  .article-body :global(.related-link-desc) {
    font-size: .82rem;
    line-height: 1.55;
    color: var(--gray);
    margin-bottom: 0;
  }

  .article-back {
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 900px) {
    .article-body :global(.related-links-grid) {
      grid-template-columns: 1fr;
    }
  }
</style>
