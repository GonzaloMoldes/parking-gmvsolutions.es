---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Dashboard de operarios en tiempo real — Software SOP para control de producción | REELEVO";
const description = "Monitor tu planta industrial desde un dashboard: operarios en máquina, disponibles para cobertura de bajas y personal ETT activo. Software SOP con visibilidad total de procedimientos operativos estándar en pymes industriales.";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Dashboard de operarios en tiempo real",
  "description": description,
  "audience": {
    "@type": "Audience",
    "audienceType": "Jefe de producción, responsable de planta industrial"
  },
  "about": {
    "@type": "Thing",
    "name": "Software SOP control operativo"
  }
};
---

<BaseLayout
  title={title}
  description={description}
  schema={schema}
  activeNav=""
>
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="eyebrow fade-up">Dashboard SOP en tiempo real</div>
    <h1 class="fade-up delay-1">Visibilidad total de tu planta:<br><em>operarios en máquina y disponibles</em></h1>
    <p class="fade-up delay-2">
      Dashboard del software SOP REELEVO que muestra en tiempo real qué operarios están
      ejecutando procedimientos operativos estándar, quiénes están disponibles para
      cobertura de bajas y el estado del personal ETT en cada máquina de tu pyme industrial.
    </p>
    <div class="hero-cta-group fade-up delay-3">
      <a href="https://app.gmvsolutions.es/registro" class="btn-primary">Ver demo →</a>
      <a href="https://diagnostico.gmvsolutions.es" class="btn-ghost">Diagnóstico gratuito</a>
    </div>
  </section>

  <div class="divider"></div>

  <!-- MONITOR PRINCIPAL -->
  <section class="section">
    <div class="section-inner">

      <div class="fade-up" style="text-align:center;margin-bottom:48px;">
        <div class="eyebrow">Control operativo industrial</div>
        <h2 class="section-title">Dashboard de planta — <em>estado actual</em></h2>
        <p class="section-sub">
          Monitor especializado para pymes industriales: identifica instantly
          qué operarios están siguiendo SOPs en máquina, quiénes pueden hacer
          cobertura de bajas y el rendimiento del personal ETT.
        </p>
      </div>

      <!-- Barra de estado -->
      <div class="monitor-topbar fade-up delay-1">
        <div class="monitor-info">
          <span class="monitor-badge">🟢 DASHBOARD SOP ACTIVO</span>
          <span class="monitor-title">Planta Industrial Nave 1 — Turno Mañana</span>
        </div>
        <div class="monitor-meta">
          <span>10:23h</span>
          <span>·</span>
          <span>12 operarios en total</span>
          <span>·</span>
          <span>1 incidencia SOP</span>
        </div>
      </div>

      <!-- Las 2 columnas -->
      <div class="monitor-cols fade-up delay-2">

        <!-- COLUMNA IZQUIERDA: Operarios sin máquina -->
        <div class="monitor-col">
          <div class="monitor-col-header sin-maquina">
            <span class="col-icon">⏸</span>
            <div>
              <div class="col-title">Operarios disponibles</div>
              <div class="col-count">4 operarios · listos para cobertura de bajas</div>
            </div>
          </div>

          <div class="operario-card disponible">
            <div class="op-avatar">LR</div>
            <div class="op-info">
              <div class="op-name">Luis Rodríguez</div>
              <div class="op-status">Disponible — certificado múltiples SOPs</div>
              <div class="op-skills">Prensa · Ensamblado · CNC · Soldadura MIG</div>
            </div>
            <div class="op-badge disponible-badge">Disponible</div>
          </div>

          <div class="operario-card descanso">
            <div class="op-avatar">MG</div>
            <div class="op-info">
              <div class="op-name">María García</div>
              <div class="op-status">Descanso — operaria experta</div>
              <div class="op-skills">Línea empaquetado · Control de calidad</div>
            </div>
            <div class="op-badge descanso-badge">Descanso</div>
          </div>

          <div class="operario-card formacion">
            <div class="op-avatar">JM</div>
            <div class="op-info">
              <div class="op-name">Javier Morales</div>
              <div class="op-status">Aprendizaje SOP — Torno CNC básico</div>
              <div class="op-skills">Nuevo operario · En certificación</div>
            </div>
            <div class="op-badge formacion-badge">Formación SOP</div>
          </div>

          <div class="operario-card baja">
            <div class="op-avatar">AC</div>
            <div class="op-info">
              <div class="op-name">Ana Castillo</div>
              <div class="op-status">Baja médica — operaria experta</div>
              <div class="op-skills">Soldadura MIG · Ensamblado avanzado · 15 años exp.</div>
            </div>
            <div class="op-badge baja-badge">Baja médica</div>
          </div>
        </div>

        <!-- SEPARADOR VERTICAL -->
        <div class="monitor-divider"></div>

        <!-- COLUMNA DERECHA: Operarios en máquina -->
        <div class="monitor-col">
          <div class="monitor-col-header en-maquina">
            <span class="col-icon">⚙️</span>
            <div>
              <div class="col-title">Operarios ejecutando SOPs</div>
              <div class="col-count">8 operarios · en procedimientos operativos</div>
            </div>
          </div>

          <div class="operario-card activo">
            <div class="op-avatar">CM</div>
            <div class="op-info">
              <div class="op-name">Carlos Martínez</div>
              <div class="op-status">Prensa 1 — SOP configuración inicial</div>
              <div class="op-machine">🔧 Paso 3 de 5 · 18 min en proceso</div>
            </div>
            <div class="op-badge activo-badge">Ejecutando SOP</div>
          </div>

          <div class="operario-card activo">
            <div class="op-avatar">AL</div>
            <div class="op-info">
              <div class="op-name">Ana López</div>
              <div class="op-status">Línea empaquetado — operaria experta</div>
              <div class="op-machine">✅ Producción estándar · 127% rendimiento</div>
            </div>
            <div class="op-badge experta-badge">Experta</div>
          </div>

          <div class="operario-card alerta">
            <div class="op-avatar">PS</div>
            <div class="op-info">
              <div class="op-name">Pedro Sánchez</div>
              <div class="op-status">Torno CNC — personal ETT</div>
              <div class="op-machine">⚠️ Consultando SOP troubleshooting</div>
            </div>
            <div class="op-badge alerta-badge">ETT - Consultando</div>
          </div>

          <div class="operario-card activo">
            <div class="op-avatar">RF</div>
            <div class="op-info">
              <div class="op-name">Rosa Fernández</div>
              <div class="op-status">Soldadura MIG — procedimiento estándar</div>
              <div class="op-machine">✅ SOP completado · 2h 14min activa</div>
            </div>
            <div class="op-badge activo-badge">SOP estándar</div>
          </div>

          <div class="operario-card activo">
            <div class="op-avatar">TN</div>
            <div class="op-info">
              <div class="op-name">Tomás Navarro</div>
              <div class="op-status">Control calidad — línea B</div>
              <div class="op-machine">✅ Procedimiento normal · 58 min</div>
            </div>
            <div class="op-badge activo-badge">Activo</div>
          </div>

          <div class="operario-card activo">
            <div class="op-avatar">IE</div>
            <div class="op-info">
              <div class="op-name">Isabel Esteve</div>
              <div class="op-status">Prensa 2 — cobertura de baja</div>
              <div class="op-machine">🔄 Siguiendo SOP del experto · paso 2/4</div>
            </div>
            <div class="op-badge sustituta-badge">Cobertura baja</div>
          </div>

          <div class="operario-card activo">
            <div class="op-avatar">DO</div>
            <div class="op-info">
              <div class="op-name">Diego Ortega</div>
              <div class="op-status">Fresadora — operario experto</div>
              <div class="op-machine">✅ Procedimientos optimizados · 1h 32min</div>
            </div>
            <div class="op-badge experta-badge">Experto</div>
          </div>

          <div class="operario-card activo">
            <div class="op-avatar">NV</div>
            <div class="op-info">
              <div class="op-name">Nuria Vidal</div>
              <div class="op-status">Ensamblado final — línea A</div>
              <div class="op-machine">✅ SOP estándar · 45 min activa</div>
            </div>
            <div class="op-badge activo-badge">SOP activo</div>
          </div>
        </div>

      </div>
      <!-- fin monitor-cols -->

    </div>
  </section>

  <div class="divider"></div>

  <!-- BENEFICIOS ESPECÍFICOS -->
  <section class="section section-center">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Valor para pymes industriales</div>
        <h2 class="section-title">Dashboard SOP:<br><em>control sin complejidad</em></h2>
        <p class="section-sub">
          El software SOP REELEVO te da visibilidad completa de tu planta
          sin necesidad de instalar apps, configurar usuarios ni formar al personal.
        </p>
      </div>

      <div class="dolor-grid fade-up delay-1">
        <div class="dolor-item">
          <div class="dolor-num">0<sup>min</sup></div>
          <div class="dolor-label">Tiempo perdido buscando quién puede hacer <strong>cobertura de bajas</strong> con el dashboard activo</div>
        </div>
        <div class="dolor-item">
          <div class="dolor-num">100<sup>%</sup></div>
          <div class="dolor-label">Visibilidad de <strong>personal ETT ejecutando SOPs</strong> en tiempo real</div>
        </div>
        <div class="dolor-item">
          <div class="dolor-num">1<sup>pantalla</sup></div>
          <div class="dolor-label">Para controlar todos los <strong>procedimientos operativos estándar</strong> de tu planta</div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CASOS DE USO -->
  <section class="section">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Casos de uso reales</div>
        <h2 class="section-title">Cuándo necesitas el <em>monitor de operarios</em></h2>
      </div>

      <div class="scenario-grid-2 fade-up delay-1">
        <div class="scenario-card">
          <div class="scenario-tag">Crisis de producción</div>
          <h3 class="scenario-card-title">Baja de último momento</h3>
          <p>
            Miguel no viene y opera la prensa crítica. Con el dashboard ves instantly
            que Luis está disponible y certificado en ese SOP. En 2 clics tienes
            la cobertura resuelta.
          </p>
          <div class="scenario-after">
            <strong>Resultado:</strong> Cero tiempo de parada, producción continua
          </div>
        </div>

        <div class="scenario-card">
          <div class="scenario-tag">Personal ETT</div>
          <h3 class="scenario-card-title">Control de temporales</h3>
          <p>
            El personal ETT no conoce tus procedimientos. El dashboard muestra
            si están siguiendo los SOPs correctamente o si necesitan supervisión
            antes de que paren la línea.
          </p>
          <div class="scenario-after">
            <strong>Resultado:</strong> Personal ETT productivo desde día 1
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-eyebrow fade-up">Para pymes industriales</div>
    <h2 class="cta-title fade-up delay-1">
      Software SOP con <em>dashboard incluido</em>
    </h2>
    <p class="cta-sub fade-up delay-2">
      Prueba el monitor de operarios de REELEVO en tu planta.
      Implementación en 1 día, sin instalar nada, sin formar personal.
    </p>
    <div class="fade-up delay-3" style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
      <a href="https://app.gmvsolutions.es/registro" class="btn-primary">Solicitar demo →</a>
      <a href="/como-funciona/" class="btn-ghost">Cómo funciona REELEVO</a>
    </div>
    <div class="cta-note fade-up delay-4">
      Dashboard incluido · Sin apps · Implementación asistida
    </div>
  </section>

</BaseLayout>

<style>
  /* ── TOPBAR ── */
  .monitor-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 6px 6px 0 0;
    padding: 14px 20px;
  }

  .monitor-info {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .monitor-badge {
    font-family: 'DM Mono', monospace;
    font-size: .6rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--green);
    background: rgba(34, 197, 94, .1);
    border: 1px solid rgba(34, 197, 94, .25);
    padding: 3px 8px;
    border-radius: 2px;
  }

  .monitor-title {
    font-family: 'Oswald', sans-serif;
    font-size: .9rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .04em;
  }

  .monitor-meta {
    display: flex;
    gap: 8px;
    font-family: 'DM Mono', monospace;
    font-size: .65rem;
    letter-spacing: .08em;
    color: var(--gray);
    text-transform: uppercase;
  }

  /* ── 2 COLUMNAS ── */
  .monitor-cols {
    display: grid;
    grid-template-columns: 1fr 1px 1fr;
    background: var(--surface);
    border: 1px solid var(--border);
    border-top: none;
    border-radius: 0 0 6px 6px;
    overflow: hidden;
  }

  .monitor-divider {
    background: var(--border);
    width: 1px;
  }

  /* ── CABECERA DE COLUMNA ── */
  .monitor-col-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    border-bottom: 1px solid var(--border);
  }

  .monitor-col-header.sin-maquina {
    background: rgba(255, 255, 255, .02);
  }

  .monitor-col-header.en-maquina {
    background: rgba(244, 82, 30, .04);
  }

  .col-icon { font-size: 1.2rem; }

  .col-title {
    font-family: 'Oswald', sans-serif;
    font-size: .9rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .05em;
  }

  .col-count {
    font-family: 'DM Mono', monospace;
    font-size: .6rem;
    letter-spacing: .08em;
    color: var(--gray);
    margin-top: 2px;
  }

  /* ── CARDS DE OPERARIO ── */
  .operario-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 20px;
    border-bottom: 1px solid var(--border);
    transition: background .15s;
  }

  .operario-card:last-child { border-bottom: none; }
  .operario-card:hover { background: rgba(255, 255, 255, .025); }

  .operario-card.alerta {
    background: rgba(255, 68, 68, .04);
    border-left: 3px solid #FF4444;
    padding-left: 17px;
  }

  .op-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--surface3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Oswald', sans-serif;
    font-size: .7rem;
    font-weight: 600;
    color: var(--gray);
    flex-shrink: 0;
  }

  .operario-card.activo .op-avatar {
    background: rgba(244, 82, 30, .15);
    color: var(--orange);
  }

  .operario-card.alerta .op-avatar {
    background: rgba(255, 68, 68, .15);
    color: #FF6666;
  }

  .op-info { flex: 1; min-width: 0; }

  .op-name {
    font-size: .85rem;
    font-weight: 500;
    color: var(--white);
    margin-bottom: 2px;
  }

  .op-status {
    font-size: .75rem;
    color: var(--gray);
    margin-bottom: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .op-skills,
  .op-machine {
    font-family: 'DM Mono', monospace;
    font-size: .6rem;
    color: var(--gray2);
    letter-spacing: .04em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── BADGES ── */
  .op-badge {
    font-family: 'DM Mono', monospace;
    font-size: .58rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: 3px 7px;
    border-radius: 2px;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .disponible-badge { background: rgba(34,197,94,.1);   color: var(--green); border: 1px solid rgba(34,197,94,.2); }
  .descanso-badge   { background: rgba(255,255,255,.06); color: var(--gray);  border: 1px solid var(--border); }
  .formacion-badge  { background: rgba(99,102,241,.1);  color: #a5b4fc;      border: 1px solid rgba(99,102,241,.2); }
  .baja-badge       { background: rgba(239,68,68,.08);  color: #f87171;      border: 1px solid rgba(239,68,68,.15); }
  .activo-badge     { background: rgba(244,82,30,.1);   color: var(--orange); border: 1px solid rgba(244,82,30,.2); }
  .experta-badge    { background: rgba(234,179,8,.1);   color: #fbbf24;      border: 1px solid rgba(234,179,8,.2); }
  .alerta-badge     { background: rgba(255,68,68,.12);  color: #ff6666;      border: 1px solid rgba(255,68,68,.2); }
  .sustituta-badge  { background: rgba(99,102,241,.1);  color: #a5b4fc;      border: 1px solid rgba(99,102,241,.2); }

  /* ── RESPONSIVE ── */
  @media (max-width: 860px) {
    .monitor-cols {
      grid-template-columns: 1fr;
    }
    .monitor-divider {
      width: auto;
      height: 1px;
    }
    .monitor-topbar {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
  }
</style>