---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "GembaDocs vs REELEVO — Software documentación y lean manufacturing";
const description = "Comparativa: GembaDocs vs REELEVO. Análisis de enfoque lean, visual work instructions, documentación operativa y precio para pymes.";

const schema = {
  "@context": "https://schema.org",
  "@type": "ComparisonChart",
  "headline": title,
  "description": description,
  "url": "https://gmvsolutions.es/vs-gembadocs/",
  "inLanguage": "es-ES"
};
---

<BaseLayout title={title} description={description} schema={schema} activeNav="">
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="eyebrow fade-up">Comparativa de herramientas</div>
    <h1 class="fade-up delay-1">GembaDocs vs REELEVO<br><em>Documentación visual vs operativa integral</em></h1>
    <p class="fade-up delay-2">GembaDocs enfatiza lean manufacturing y visual management. REELEVO enfatiza onboarding y competencias. Comparativa completa.</p>
  </section>

  <div class="divider"></div>

  <!-- VISIÓN GENERAL -->
  <section class="section">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Visión general</div>
        <h2 class="section-title">Enfoques complementarios</h2>
      </div>

      <div class="vision-grid fade-up delay-1">
        <div class="vision-card">
          <h3>GembaDocs</h3>
          <p class="vision-focus">Enfoque: Visual management + Lean</p>
          <ul>
            <li>Documentación visual de procesos</li>
            <li>Énfasis en gemba walk (observación planta)</li>
            <li>Markdown y colaboración entre equipos</li>
            <li>Orientado a mejora continua</li>
            <li>Mercado: Global pero sin español específico</li>
          </ul>
        </div>

        <div class="vision-card highlight">
          <h3>REELEVO</h3>
          <p class="vision-focus">Enfoque: Onboarding + Competencias</p>
          <ul>
            <li>Procedimientos paso a paso en máquina</li>
            <li>Énfasis en incorporación de operarios</li>
            <li>Gestión de matriz de habilidades</li>
            <li>Cobertura de bajas sin experto</li>
            <li>Mercado: España, pymes industriales</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- COMPARATIVA TÉCNICA -->
  <section class="section">
    <div class="section-inner">
      <div class="fade-up">
        <h2 class="section-title">Características técnicas</h2>
      </div>

      <div class="comparison-table fade-up delay-1">
        <table>
          <thead>
            <tr>
              <th style="width: 35%;">Característica</th>
              <th style="width: 32.5%;">GembaDocs</th>
              <th style="width: 32.5%;">REELEVO</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>Tipo de contenido</strong></td>
              <td>Visual (markdown, imágenes)</td>
              <td class="highlight">Procedimientos paso-a-paso</td>
            </tr>
            <tr>
              <td><strong>Documentación SOP</strong></td>
              <td>✓ Sí (enfoque visual)</td>
              <td class="highlight">✓ Sí (enfoque operativo)</td>
            </tr>
            <tr>
              <td><strong>Onboarding integrado</strong></td>
              <td>Limitado (no es focus)</td>
              <td class="highlight">✓ Central</td>
            </tr>
            <tr>
              <td><strong>Gestión competencias</strong></td>
              <td>No</td>
              <td class="highlight">✓ Sí (matriz habilidades)</td>
            </tr>
            <tr>
              <td><strong>Acceso en máquina</strong></td>
              <td>Browser (requiere navegador)</td>
              <td class="highlight">✓ App nativa</td>
            </tr>
            <tr>
              <td><strong>Gemba walk digital</strong></td>
              <td>✓ Feature central</td>
              <td>Enfoque diferente</td>
            </tr>
            <tr>
              <td><strong>Colaboración equipos</strong></td>
              <td>✓ Fuerte (comentarios, versiones)</td>
              <td>Básica</td>
            </tr>
            <tr>
              <td><strong>Idioma español</strong></td>
              <td>Interfaz en inglés (multiidioma genérico)</td>
              <td class="highlight">✓ 100% Español</td>
            </tr>
            <tr>
              <td><strong>Soporte español</strong></td>
              <td>Soporte general en inglés</td>
              <td class="highlight">✓ Soporte español</td>
            </tr>
            <tr>
              <td><strong>Precio transparente</strong></td>
              <td>Contacto para presupuesto</td>
              <td class="highlight">✓ Desde 49€/mes</td>
            </tr>
            <tr>
              <td><strong>Setup inicial</strong></td>
              <td>Moderado</td>
              <td class="highlight">✓ Rápido (1-2 días)</td>
            </tr>
            <tr>
              <td><strong>Para pymes</strong></td>
              <td>Posible pero no foco</td>
              <td class="highlight">✓ Diseñado para pymes</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ANÁLISIS DETALLADO -->
  <section class="section">
    <div class="section-inner">
      <div class="fade-up">
        <h2 class="section-title">Fortalezas y debilidades</h2>
      </div>

      <div class="strengths-grid fade-up delay-1">
        <div class="strength-card">
          <h3>GembaDocs: Fortalezas</h3>
          <ul>
            <li>Excelente para visual management</li>
            <li>Fuerte énfasis en mejora continua</li>
            <li>Colaboración entre equipos robusta</li>
            <li>Documentación hermosa y visual</li>
            <li>Comunidad lean manufacturing activa</li>
            <li>Control de versiones integrado</li>
          </ul>
        </div>

        <div class="strength-card">
          <h3>GembaDocs: Debilidades</h3>
          <ul>
            <li>Enfoque en documentación, no onboarding</li>
            <li>Sin gestión de competencias</li>
            <li>No hay soporte español</li>
            <li>Interfaz en inglés (barrera pyme españa)</li>
            <li>Precio no publicitado (no asequible pyme)</li>
            <li>Requiere navegador (no app móvil nativa)</li>
            <li>Curva aprendizaje moderada</li>
          </ul>
        </div>

        <div class="strength-card highlight">
          <h3>REELEVO: Fortalezas</h3>
          <ul>
            <li>100% español (interfaz y soporte)</li>
            <li>Precio transparente (49-99€/mes)</li>
            <li>SOP + Onboarding + Competencias integrado</li>
            <li>App móvil accesible en máquina</li>
            <li>Diseñado específicamente para pymes</li>
            <li>Setup ultra-rápido (2 días)</li>
            <li>ROI en 1-2 meses típicamente</li>
          </ul>
        </div>

        <div class="strength-card highlight">
          <h3>REELEVO: Áreas de crecimiento</h3>
          <ul>
            <li>Comunidad más pequeña (en crecimiento)</li>
            <li>Menos enfoque en visual design que GembaDocs</li>
            <li>Menos integración con ERP enterprise</li>
            <li>Colaboración de equipo más básica</li>
            <li>Mercado más enfocado (pymes, no enterprise)</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CASOS DE USO -->
  <section class="section">
    <div class="section-inner">
      <div class="fade-up">
        <h2 class="section-title">¿Cuándo elegir cada uno?</h2>
      </div>

      <div class="decision-grid fade-up delay-1">
        <div class="decision-card">
          <h3>Elige GembaDocs si...</h3>
          <ul>
            <li>Tu prioridad es lean manufacturing</li>
            <li>Necesitas visual management avanzado</li>
            <li>Requieres control de versiones de documentos</li>
            <li>Trabajas con equipos multiidioma (inglés OK)</li>
            <li>Tu modelo es mejora continua gemba first</li>
            <li>Presupuesto IT medio-alto</li>
          </ul>
        </div>

        <div class="decision-card highlight">
          <h3>Elige REELEVO si...</h3>
          <ul>
            <li>Problemas de onboarding y dependencia operaria</li>
            <li>Necesitas cobertura rápida en bajas</li>
            <li>Eres pyme industrial española</li>
            <li>Requerimientos en español críticos</li>
            <li>Presupuesto IT limitado</li>
            <li>Necesitas implementación rápida (días, no semanas)</li>
            <li>Enfoque: transferencia de conocimiento</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-eyebrow fade-up">Para tu pyme</div>
    <h2 class="cta-title fade-up delay-1">
      ¿Necesitas documentación visual o <em>onboarding operativo?</em>
    </h2>
    <p class="cta-sub fade-up delay-2">
      Si tu problema es que los operarios nuevos tardan en aprender y los expertos no documentan procedimientos, REELEVO está hecho para ti. Implementación en 2 días, soporte en español, precio transparente.
    </p>
    <div class="cta-actions fade-up delay-3">
      <a href="https://app.gmvsolutions.es/registro" class="btn-primary">
        Registrarse en REELEVO
      </a>
      <a href="https://diagnostico.gmvsolutions.es" class="btn-ghost">
        Ver mi situación →
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .vision-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-top: 40px;
  }

  .vision-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 28px;
  }

  .vision-card.highlight {
    border-color: var(--orange);
    background: rgba(255, 150, 0, 0.02);
  }

  .vision-focus {
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--orange);
    font-weight: 600;
    margin-bottom: 16px;
  }

  .vision-card ul {
    list-style: none;
    padding: 0;
  }

  .vision-card li {
    padding: 8px 0;
    color: var(--gray);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .vision-card li:before {
    content: "→ ";
    color: var(--orange);
    font-weight: 600;
    margin-right: 8px;
  }

  .comparison-table {
    overflow-x: auto;
    margin-top: 40px;
  }

  .comparison-table table {
    width: 100%;
    border-collapse: collapse;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
  }

  .comparison-table th,
  .comparison-table td {
    padding: 14px;
    text-align: left;
    border-bottom: 1px solid var(--border);
    font-size: 0.9rem;
  }

  .comparison-table th {
    background: var(--surface2);
    font-weight: 600;
  }

  .comparison-table tbody tr:last-child td {
    border-bottom: none;
  }

  .comparison-table td.highlight {
    background: rgba(255, 150, 0, 0.05);
    color: var(--orange);
    font-weight: 500;
  }

  .strengths-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 40px;
  }

  .strength-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 28px;
  }

  .strength-card.highlight {
    border-color: var(--orange);
    background: rgba(255, 150, 0, 0.02);
  }

  .strength-card h3 {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    margin-bottom: 16px;
  }

  .strength-card ul {
    list-style: none;
    padding: 0;
  }

  .strength-card li {
    padding: 8px 0;
    color: var(--gray);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .strength-card li:before {
    content: "✓ ";
    color: var(--orange);
    font-weight: 600;
    margin-right: 8px;
  }

  .decision-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-top: 40px;
  }

  .decision-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 28px;
  }

  .decision-card.highlight {
    border-color: var(--orange);
    background: rgba(255, 150, 0, 0.02);
  }

  .decision-card h3 {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    margin-bottom: 16px;
  }

  .decision-card ul {
    list-style: none;
    padding: 0;
  }

  .decision-card li {
    padding: 8px 0;
    color: var(--gray);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .decision-card li:before {
    content: "✓ ";
    color: var(--orange);
    font-weight: 600;
    margin-right: 8px;
  }

  @media (max-width: 900px) {
    .vision-grid,
    .strengths-grid,
    .decision-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
