---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Cómo funciona REELEVO — Software SOP para documentar procesos industriales paso a paso";
const description = "Así funciona REELEVO: el operario experto captura los procedimientos operativos estándar de cada máquina. El conocimiento queda disponible para cualquier sustituto desde el primer día. Software SOP sin apps, sin usuarios, sin complicaciones.";

const schema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "Cómo usar REELEVO",
  "description": "Guía paso a paso para documentar procesos operativos con REELEVO",
  "step": [
    { "@type": "HowToStep", "text": "El operario experto captura su conocimiento paso a paso" },
    { "@type": "HowToStep", "text": "El conocimiento queda disponible en cada máquina" },
    { "@type": "HowToStep", "text": "Cualquier sustituto accede y opera desde el primer día" }
  ]
};
---

<BaseLayout
  title={title}
  description={description}
  schema={schema}
  activeNav="como-funciona"
>
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="eyebrow fade-up">Flujo completo</div>
    <h1 class="fade-up delay-1">Así funciona <em>REELEVO</em><br>paso a paso.</h1>
    <p class="fade-up delay-2">Tres participantes, tres perspectivas. Los procedimientos operativos estándar del experto llegan al sustituto en segundos, sin fricción, sin cuenta de usuario, sin app que instalar.</p>
  </section>

  <div class="divider"></div>

  <!-- FLUJO PASO A PASO -->
  <section class="section">
    <div class="section-inner">
      <!-- PASO 1: EXPERTO -->
      <div class="step-section fade-up">
        <div class="step-number">1</div>
        <div class="step-content">
          <div class="step-role">👨‍🔧 El operario experto</div>
          <h2 class="section-title">Captura los <em>procedimientos operativos</em></h2>
          <p class="section-sub">
            El operario que sabe documenta cada paso del proceso con sus propias palabras.
            Sin guión, sin producción, en minutos. 20 años de conocimiento tácito convertidos en SOPs accesibles y siempre actualizables.
          </p>

          <div class="scenarios-grid">
            <div class="scenario-card">
              <div class="scenario-tag">Preparación</div>
              <h3 class="scenario-card-title">«Así preparo la máquina»</h3>
              <p>El checklist de preparación, parámetros clave y puntos de atención que solo el experto conoce.</p>
            </div>

            <div class="scenario-card">
              <div class="scenario-tag">Ejecución</div>
              <h3 class="scenario-card-title">«Esto es lo que hago»</h3>
              <p>Cada paso del proceso operativo, con los trucos y detalles que vienen de la experiencia.</p>
            </div>

            <div class="scenario-card">
              <div class="scenario-tag">Problemas</div>
              <h3 class="scenario-card-title">«Si pasa esto, haces esto»</h3>
              <p>Soluciones a los problemas más comunes y cuándo es necesario avisar al supervisor.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="step-arrow fade-up delay-1">
        <svg viewBox="0 0 24 24" style="width:40px;height:40px;fill:var(--orange);">
          <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
        </svg>
      </div>

      <!-- PASO 2: ADMINISTRADOR -->
      <div class="step-section fade-up delay-1">
        <div class="step-number">2</div>
        <div class="step-content">
          <div class="step-role">⚙️ El responsable / supervisor</div>
          <h2 class="section-title">Organiza y distribuye <em>los SOPs</em></h2>
          <p class="section-sub">
            Los procedimientos operativos estándar se organizan por máquina y proceso en el panel.
            Quedan disponibles directamente en cada puesto de trabajo para cualquier operario.
          </p>

          <div class="benefit-list">
            <div class="benefit-row">
              <div class="benefit-icon">📋</div>
              <div>
                <h3 class="benefit-title">Organización automática</h3>
                <p class="benefit-desc">Los procesos se clasifican por máquina y tipo. Sin complicaciones técnicas, sin IT para arrancar.</p>
              </div>
              <div class="benefit-result">
                <div class="benefit-result-label">Beneficio</div>
                <p>Cada máquina tiene su documentación accesible en segundos</p>
              </div>
            </div>

            <div class="benefit-row">
              <div class="benefit-icon">🔓</div>
              <div>
                <h3 class="benefit-title">Acceso sin fricción</h3>
                <p class="benefit-desc">Los operarios acceden con un código de empresa. Sin crear cuentas, sin contraseñas, sin gestión de usuarios.</p>
              </div>
              <div class="benefit-result">
                <div class="benefit-result-label">Beneficio</div>
                <p>Cualquier sustituto opera desde el minuto 1, sin configuración previa</p>
              </div>
            </div>

            <div class="benefit-row">
              <div class="benefit-icon">📊</div>
              <div>
                <h3 class="benefit-title">Visibilidad total</h3>
                <p class="benefit-desc">Dashboard que muestra quién está operando qué máquina, cuándo y con qué resultado.</p>
              </div>
              <div class="benefit-result">
                <div class="benefit-result-label">Beneficio</div>
                <p>Sabes lo que pasa en planta sin preguntar a nadie</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="step-arrow fade-up delay-2">
        <svg viewBox="0 0 24 24" style="width:40px;height:40px;fill:var(--orange);">
          <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
        </svg>
      </div>

      <!-- PASO 3: OPERARIO -->
      <div class="step-section fade-up delay-2">
        <div class="step-number">3</div>
        <div class="step-content">
          <div class="step-role">👤 El sustituto / nuevo operario</div>
          <h2 class="section-title">Opera <em>desde el primer momento</em></h2>
          <p class="section-sub">
            El sustituto accede al proceso de la máquina, introduce el código de empresa
            y sigue las instrucciones paso a paso. Sin cuenta, sin app, sin esperar a nadie.
          </p>

          <div class="scenario-grid">
            <div class="scenario-card">
              <div class="scenario-card-tag">1. Accede al proceso</div>
              <h3 class="scenario-card-title">Desde cualquier móvil</h3>
              <div class="scenario-before">Sin REELEVO: Buscar al supervisor, esperar explicación, preguntar dudas</div>
              <div class="scenario-after">Con REELEVO: Acceso directo → código empresa → instrucciones al instante</div>
            </div>

            <div class="scenario-card">
              <div class="scenario-card-tag">2. Sigue los pasos</div>
              <h3 class="scenario-card-title">Paso a paso</h3>
              <div class="scenario-before">Sin REELEVO: Depender de la memoria, cometer errores, llamar al tutor</div>
              <div class="scenario-after">Con REELEVO: Cada paso explicado por el experto, en orden, sin dudas</div>
            </div>

            <div class="scenario-card">
              <div class="scenario-card-tag">3. Resuelve problemas</div>
              <h3 class="scenario-card-title">Troubleshooting integrado</h3>
              <div class="scenario-before">Sin REELEVO: Parar la línea, llamar al supervisor, esperar ayuda</div>
              <div class="scenario-after">Con REELEVO: Problemas comunes resueltos al instante, aviso al supervisor si lo necesita</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- QUÉ GANAS -->
  <section class="section section-center">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Beneficios del software SOP</div>
        <h2 class="section-title">Procedimientos estándar, <em>resultados reales</em></h2>
        <p class="section-sub">
          REELEVO está diseñado para funcionar con lo que ya tienes.
          Sin instalaciones, sin infraestructura adicional. Arranca sin necesitar a IT.
        </p>
      </div>

      <div class="benefits-grid fade-up delay-1">
        <div class="benefit-card">
          <div class="benefit-card-icon">⚡</div>
          <h3 class="benefit-card-title">Autonomía inmediata</h3>
          <p class="benefit-card-desc">
            El sustituto opera correctamente desde el primer momento.
            Sin tutor, sin esperas, sin improvisar.
          </p>
        </div>

        <div class="benefit-card">
          <div class="benefit-card-icon">🔒</div>
          <h3 class="benefit-card-title">Conocimiento protegido</h3>
          <p class="benefit-card-desc">
            Lo que sabe tu experto ya no vive solo en su cabeza.
            Está documentado, accesible y no se pierde cuando se va.
          </p>
        </div>

        <div class="benefit-card">
          <div class="benefit-card-icon">📊</div>
          <h3 class="benefit-card-title">Datos, no intuiciones</h3>
          <p class="benefit-card-desc">
            Sabes qué procesos se consultan, cuáles generan incidencias
            y qué operarios necesitan más apoyo.
          </p>
        </div>

        <div class="benefit-card">
          <div class="benefit-card-icon">🛡️</div>
          <h3 class="benefit-card-title">Menos errores</h3>
          <p class="benefit-card-desc">
            El proceso se ejecuta siempre igual. Mismo orden, mismos criterios.
            Menos reprocesos, menos riesgo.
          </p>
        </div>

        <div class="benefit-card">
          <div class="benefit-card-icon">✅</div>
          <h3 class="benefit-card-title">Certificación real</h3>
          <p class="benefit-card-desc">
            REELEVO certifica competencias por ejecución,
            no por asistir a una formación.
          </p>
        </div>

        <div class="benefit-card">
          <div class="benefit-card-icon">🔧</div>
          <h3 class="benefit-card-title">Problemas resueltos</h3>
          <p class="benefit-card-desc">
            Troubleshooting paso a paso integrado en cada proceso.
            Aviso automático al supervisor si hace falta.
          </p>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- FAQ -->
  <section class="section section-center">
    <div class="section-inner">
      <div class="fade-up" style="margin-bottom:48px;">
        <div class="eyebrow">Preguntas frecuentes</div>
        <h2 class="section-title">Resolvemos tus dudas</h2>
        <p class="section-sub">
          Las preguntas más habituales sobre implementación, seguridad y funcionamiento.
        </p>
      </div>

      <div class="faq-grid fade-up delay-1">
        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">
            <span>¿Cuánto tiempo lleva implementar REELEVO?</span>
            <svg viewBox="0 0 24 24" stroke="currentColor"><polyline points="6,9 12,15 18,9"></polyline></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              <p>La configuración técnica es <strong>inmediata</strong>. En 1 día tienes la plataforma lista. Después, el tiempo depende de cuántos procesos documentes: un proceso sencillo puede capturarse en 30-60 minutos; uno complejo con múltiples pasos y troubleshooting puede llevar 2-3 horas de trabajo con el experto.</p>
              <p>No hay que instalar software, configurar servidores ni formar a los operarios. Acceden directamente y operan.</p>
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">
            <span>¿Qué pasa si no hay cobertura móvil en la planta?</span>
            <svg viewBox="0 0 24 24" stroke="currentColor"><polyline points="6,9 12,15 18,9"></polyline></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              <p>REELEVO funciona con <strong>cualquier conexión a internet</strong>: 4G, 5G o WiFi de empresa. Los contenidos están optimizados para cargar rápidamente incluso con conexiones lentas.</p>
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">
            <span>¿Los operarios tienen que crearse una cuenta?</span>
            <svg viewBox="0 0 24 24" stroke="currentColor"><polyline points="6,9 12,15 18,9"></polyline></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              <p><strong>No</strong>. Los operarios acceden con un código de empresa. Sin crear cuentas, sin contraseñas, sin gestión de usuarios. Cualquier sustituto opera inmediatamente.</p>
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">
            <span>¿Cómo sabemos quién ha accedido y cuándo?</span>
            <svg viewBox="0 0 24 24" stroke="currentColor"><polyline points="6,9 12,15 18,9"></polyline></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              <p>Aunque no hay cuentas de operario, <strong>REELEVO registra toda la actividad</strong>: qué proceso se ha consultado, cuándo, y si se ha completado correctamente. Trazabilidad total sin comprometer la simplicidad.</p>
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">
            <span>¿Podemos actualizar los procesos fácilmente?</span>
            <svg viewBox="0 0 24 24" stroke="currentColor"><polyline points="6,9 12,15 18,9"></polyline></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              <p><strong>Sí</strong>. Cualquier administrador puede actualizar procesos desde el panel. Los cambios se reflejan automáticamente. El operario siempre accede a la versión más actual.</p>
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">
            <span>¿Es compatible con nuestros sistemas de gestión?</span>
            <svg viewBox="0 0 24 24" stroke="currentColor"><polyline points="6,9 12,15 18,9"></polyline></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              <p>La integración mediante API con ERPs y sistemas de RRHH (Factorial, Personio, SAP...) está en nuestro roadmap. Si tienes una integración específica que necesitas, cuéntanos — lo priorizamos según la demanda real de nuestros clientes.</p>
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">
            <span>¿Puedo exportar mis procesos si dejo de usar REELEVO?</span>
            <svg viewBox="0 0 24 24" stroke="currentColor"><polyline points="6,9 12,15 18,9"></polyline></svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              <p>Sí. Desde el panel de administración puedes exportar en cualquier momento todos los procesos e instrucciones en CSV y Excel. El conocimiento que has documentado es tuyo. En caso de cierre del servicio, avisaríamos con al menos 90 días de antelación y facilitaríamos la exportación completa. Más detalles en nuestra <a href="/sobre-nosotros#portabilidad" style="color:var(--orange)">página de Nosotros</a>.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-eyebrow fade-up">¿Todo claro?</div>
    <h2 class="cta-title fade-up delay-1">
      Empieza hoy mismo
    </h2>
    <p class="cta-sub fade-up delay-2">
      Solicita una demo y te lo enseñamos funcionando en tu tipo de empresa.
    </p>
    <div class="cta-actions fade-up delay-3">
      <a href="https://app.gmvsolutions.es/registro" class="btn-primary">Solicitar demo →</a>
      <a href="/precios" class="btn-ghost">Ver precios</a>
    </div>
    <div class="cta-note fade-up delay-4">
      Sin compromiso · Implementación asistida · Configuración en 1 día
    </div>
  </section>
</BaseLayout>

<style>
  .step-section {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 40px;
    align-items: start;
    margin: 80px 0;
  }

  .step-number {
    width: 80px;
    height: 80px;
    background: var(--orange);
    color: var(--white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Oswald', sans-serif;
    font-size: 2rem;
    font-weight: 700;
  }

  .step-role {
    font-family: 'DM Mono', monospace;
    font-size: .7rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 16px;
  }

  .step-arrow {
    text-align: center;
    margin: 40px 0;
  }

  .scenarios-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 40px;
  }

  @media (max-width: 900px) {
    .step-section {
      grid-template-columns: 1fr;
      gap: 20px;
      text-align: center;
    }
    .scenarios-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .step-section {
      margin: 60px 0;
    }
  }
</style>

<script>
  function toggleFaq(button: HTMLButtonElement) {
    const item = button.closest('.faq-item');
    const isOpen = item?.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(item => {
      item.classList.remove('open');
    });
    if (!isOpen) {
      item?.classList.add('open');
    }
  }
</script>
