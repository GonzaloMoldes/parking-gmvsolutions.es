---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Cómo funciona REELEVO — menos improvisación y más continuidad en planta";
const description = "Descubre cómo REELEVO ayuda a que una baja, una incorporación o un cambio de turno no rompan la operación en planta.";

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "Cómo usar REELEVO",
  "description": "Guía paso a paso para reducir dependencia operativa en planta con REELEVO",
  "url": "https://www.gmvsolutions.es/como-funciona/",
  "step": [
    { "@type": "HowToStep", "text": "El operario experto deja una referencia útil de su trabajo" },
    { "@type": "HowToStep", "text": "La empresa deja el trabajo listo en el puesto" },
    { "@type": "HowToStep", "text": "El sustituto o nuevo arranca con más autonomía y menos espera" }
  ]
};

// GLOSSARY: operario, baja, dependencia operativa, tutor, sustituto, competencias, continuidad
// CONTEXT: operational, marketing
// EN_TERMS: [expert operator, absence, key person risk, mentor, substitute, skills]
// PT_TERMS: [operador experiente, falta, risco de pessoal-chave, mentor, substituto, competências]

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cuánto tiempo lleva implementar REELEVO?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La base técnica puede quedar lista muy rápido y el arranque se hace de forma asistida. Después, el tiempo depende de cuántos procesos priorices y del nivel de acompañamiento que necesite cada puesto."
      }
    },
    {
      "@type": "Question",
      "name": "¿Puedo probarlo antes de contratar?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Puedes registrarte en la plataforma para verla por dentro y comprobar si encaja con tu operativa antes de decidir."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cómo accede el operario al proceso en la máquina?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Cada proceso queda disponible en el puesto de trabajo. El operario entra desde el acceso del puesto, introduce el código de empresa y ve qué tiene que hacer al instante, sin app ni cuenta."
      }
    },
    {
      "@type": "Question",
      "name": "¿En qué dispositivos funciona REELEVO? ¿Necesita una app?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "REELEVO funciona en el navegador de cualquier móvil, tablet u ordenador. No hace falta descargar ninguna app."
      }
    },
    {
      "@type": "Question",
      "name": "¿Los operarios tienen que crearse una cuenta?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Los operarios acceden con un código de empresa, sin cuentas personales, contraseñas ni gestión de usuarios."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué pasa si no hay cobertura móvil en la planta?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "REELEVO puede funcionar con cualquier conexión a internet disponible, ya sea 4G, 5G o WiFi de empresa, y los contenidos están optimizados para cargar rápido incluso con conexiones lentas."
      }
    },
    {
      "@type": "Question",
      "name": "¿Los procesos pueden incluir fotos, vídeos y archivos adjuntos?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Cada paso puede incluir texto, fotos, vídeos cortos y archivos adjuntos para que el proceso sea más claro en el puesto de trabajo."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cómo organizo los procesos si tengo varias secciones o líneas de producción?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Los SOPs se pueden organizar por planta, sección, línea y máquina, de forma que cada equipo encuentre el proceso correcto sin depender de búsquedas largas o carpetas."
      }
    },
    {
      "@type": "Question",
      "name": "¿Se puede usar con operarios que no hablan español?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Los procesos se pueden documentar en distintos idiomas y el uso de vídeo reduce además la dependencia del idioma escrito."
      }
    },
    {
      "@type": "Question",
      "name": "¿Podemos actualizar los procesos fácilmente?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Cualquier administrador puede actualizar procesos desde el panel y los cambios quedan disponibles automáticamente para el operario."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué pasa cuando se actualiza un procedimiento operativo?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "El operario accede siempre a la versión más reciente y REELEVO mantiene un historial de versiones para saber qué cambió, quién lo cambió y cuándo."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cómo sabemos quién ha accedido y cuándo?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "REELEVO deja una base de evidencia sobre qué proceso se ha seguido, cuándo y con qué resultado. Si la empresa necesita seguimiento asociado a persona, puede usar un identificador interno en los flujos donde aplique."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué queda registrado realmente?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "REELEVO puede dejar una base útil sobre el proceso seguido, el puesto o máquina, la fecha y hora, la versión visible y el resultado del flujo. En los modos de seguimiento también puede asociarse a un identificador interno definido por la empresa."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué diferencia hay entre consulta rápida y seguimiento asociado?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La consulta rápida prioriza que alguien encuentre el proceso y desbloquee el puesto con la mínima fricción. El seguimiento asociado añade un identificador interno cuando la empresa necesita acompañar onboarding, seguimiento interno o auditorías."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué pasa si el operario experto no quiere documentar sus procesos?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Es una objeción habitual, pero cuando el experto documenta con sus propias palabras y a su ritmo, su conocimiento se reconoce formalmente y el proceso de captura resulta mucho más natural."
      }
    },
    {
      "@type": "Question",
      "name": "¿Es adecuado para una pyme pequeña o un taller con pocos operarios?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. REELEVO está diseñado específicamente para pymes industriales y talleres de entre 5 y 200 operarios, con precio fijo por empresa y sin necesidad de IT para arrancar."
      }
    },
    {
      "@type": "Question",
      "name": "¿Dónde se almacenan mis datos? ¿Cumple con el RGPD?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Los datos operativos del producto se alojan principalmente en infraestructura dentro de la Unión Europea y REELEVO cumple con el RGPD. Algunos servicios auxiliares del sitio web pueden implicar proveedores internacionales bajo las garantías contractuales adecuadas. Los procesos documentados siguen siendo propiedad de la empresa."
      }
    },
    {
      "@type": "Question",
      "name": "¿Tienen soporte en español? ¿Qué pasa si tenemos un problema en planta?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. El soporte es en español por email y chat, con tiempos de respuesta definidos en horario laboral según el plan contratado."
      }
    },
    {
      "@type": "Question",
      "name": "¿Es compatible con nuestros sistemas de gestión?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "REELEVO puede encajar con software de RRHH y otros sistemas según el caso. Si ya trabajáis con una herramienta concreta, revisamos el encaje durante la implantación."
      }
    },
    {
      "@type": "Question",
      "name": "¿Puedo exportar mis procesos si dejo de usar REELEVO?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Desde el panel se pueden exportar los procesos e instrucciones, y en caso de cierre del servicio se facilitaría la exportación completa con aviso previo."
      }
    }
  ]
};

const schema = [howToSchema, faqSchema];
---

<!-- GLOSSARY: operario, baja, onboarding, competencias, tutor, incorporación, SOP, continuidad -->
<!-- CONTEXT: operational, marketing, product -->
<!-- EN_TERMS: [machine operator, absence, onboarding, skills, mentor, operator onboarding, standard operating procedure, continuity] -->
<!-- PT_TERMS: [operador, falta, integração, competências, mentor, integração de operadores, procedimento operativo padrão, continuidade] -->

<BaseLayout
  title={title}
  description={description}
  schema={schema}
  activeNav="como-funciona"
>
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="eyebrow fade-up">Flujo completo</div>
    <h1 class="fade-up delay-1">Así pasa tu planta de depender del experto<br>a trabajar con <em>más continuidad</em>.</h1>
    <p class="fade-up delay-2">REELEVO ayuda a que una baja, una incorporación o un cambio de turno no rompan la operación. Este es el recorrido desde el conocimiento del experto hasta una ejecución más ordenada en planta.</p>
  </section>

  <div class="divider"></div>

  <!-- FLUJO PASO A PASO -->
  <section class="section">
    <div class="section-inner">
      <!-- PASO 1: EXPERTO -->
      <div class="step-section fade-up">
        <div class="step-number">1</div>
        <div class="step-content">
          <div class="step-role">👨‍🔧 El operario experto</div>
          <h2 class="section-title">Convierte la experiencia del experto en una <em>referencia útil</em></h2>
          <p class="section-sub">
            El operario que sabe deja el proceso explicado con sus propias palabras.
            Sin guión y sin procesos pesados. El conocimiento tácito de fábrica deja de vivir solo en su cabeza.
          </p>

          <div class="scenarios-grid">
            <div class="scenario-card">
              <div class="scenario-tag">Preparación</div>
              <h3 class="scenario-card-title">«Así preparo la máquina»</h3>
              <p>El checklist de preparación, parámetros clave y puntos de atención que solo el experto conoce.</p>
            </div>

            <div class="scenario-card">
              <div class="scenario-tag">Ejecución</div>
              <h3 class="scenario-card-title">«Esto es lo que hago»</h3>
              <p>Cada paso del proceso operativo, con los trucos y detalles que vienen de la experiencia.</p>
            </div>

            <div class="scenario-card">
              <div class="scenario-tag">Problemas</div>
              <h3 class="scenario-card-title">«Si pasa esto, haces esto»</h3>
              <p>Soluciones a los problemas más comunes y cuándo es necesario avisar al supervisor.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="step-arrow fade-up delay-1">
        <svg viewBox="0 0 24 24" style="width:40px;height:40px;fill:var(--orange);">
          <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
        </svg>
      </div>

      <!-- PASO 2: ADMINISTRADOR -->
      <div class="step-section fade-up delay-1">
        <div class="step-number">2</div>
        <div class="step-content">
          <div class="step-role">⚙️ El responsable / supervisor</div>
          <h2 class="section-title">Deja el trabajo listo para <em>quien lo necesite</em></h2>
          <p class="section-sub">
            El responsable organiza los procesos en el panel y los deja disponibles donde se necesitan.
            Así el puesto deja de depender de la memoria del titular o de encontrar a alguien libre para explicarlo.
          </p>

          <div class="benefit-list">
            <div class="benefit-row">
              <div class="benefit-icon">📋</div>
              <div>
                <h3 class="benefit-title">Organización automática</h3>
                <p class="benefit-desc">Los procesos se clasifican por máquina y tipo. Sin complicaciones técnicas, sin IT para arrancar.</p>
              </div>
              <div class="benefit-result">
                <div class="benefit-result-label">Beneficio</div>
                <p>Cada máquina tiene su documentación accesible en segundos</p>
              </div>
            </div>

            <div class="benefit-row">
              <div class="benefit-icon">🔓</div>
              <div>
                <h3 class="benefit-title">Acceso sin fricción</h3>
                <p class="benefit-desc">Los operarios acceden con un código de empresa. Sin crear cuentas, sin contraseñas, sin gestión de usuarios.</p>
              </div>
              <div class="benefit-result">
                <div class="benefit-result-label">Beneficio</div>
                <p>El operario llega al proceso sin configuraciones previas ni gestión de usuarios</p>
              </div>
            </div>

            <div class="benefit-row">
              <div class="benefit-icon">📊</div>
              <div>
                <h3 class="benefit-title">Visibilidad total</h3>
                <p class="benefit-desc">Dashboard que muestra quién está operando qué máquina, cuándo y con qué resultado.</p>
              </div>
              <div class="benefit-result">
                <div class="benefit-result-label">Beneficio</div>
                <p>Sabes lo que pasa en planta sin preguntar a nadie</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="step-arrow fade-up delay-2">
        <svg viewBox="0 0 24 24" style="width:40px;height:40px;fill:var(--orange);">
          <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
        </svg>
      </div>

      <!-- PASO 3: OPERARIO -->
      <div class="step-section fade-up delay-2">
        <div class="step-number">3</div>
        <div class="step-content">
          <div class="step-role">👤 El sustituto / nuevo operario</div>
          <h2 class="section-title">El nuevo arranca con <em>menos espera</em></h2>
          <p class="section-sub">
            El sustituto encuentra qué hacer en el puesto y sigue una referencia clara.
            Sin frenar al equipo, sin depender de esperar a que alguien tenga un rato para enseñarle.
          </p>

          <div class="scenario-grid">
            <div class="scenario-card">
              <div class="scenario-card-tag">1. Accede al proceso</div>
              <h3 class="scenario-card-title">Desde cualquier móvil</h3>
              <div class="scenario-before">Sin REELEVO: Buscar al supervisor, esperar explicación, preguntar dudas</div>
              <div class="scenario-after">Con REELEVO: Encuentra el proceso del puesto y empieza sin esperar</div>
            </div>

            <div class="scenario-card">
              <div class="scenario-card-tag">2. Sigue los pasos</div>
              <h3 class="scenario-card-title">Paso a paso</h3>
              <div class="scenario-before">Sin REELEVO: Depender de la memoria, cometer errores, llamar al tutor</div>
              <div class="scenario-after">Con REELEVO: Cada paso explicado por el experto, en orden, sin dudas</div>
            </div>

            <div class="scenario-card">
              <div class="scenario-card-tag">3. Resuelve problemas</div>
              <h3 class="scenario-card-title">Guía de incidencias integrada</h3>
              <div class="scenario-before">Sin REELEVO: Parar la línea, llamar al supervisor, esperar ayuda</div>
              <div class="scenario-after">Con REELEVO: Problemas comunes resueltos al instante, aviso al supervisor si lo necesita</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- QUÉ GANAS -->
  <section class="section section-center">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Lo que cambia</div>
        <h2 class="section-title">Menos improvisación, <em>resultados reales</em></h2>
        <p class="section-sub">
          REELEVO está diseñado para que el cambio se note en la operación, no solo en la documentación.
          Arranca sin infraestructura adicional y sin convertirlo en un proyecto pesado.
        </p>
      </div>

      <div class="benefits-grid fade-up delay-1">
        <div class="benefit-card">
          <div class="benefit-card-icon">⚡</div>
          <h3 class="benefit-card-title">Autonomía más ordenada</h3>
          <p class="benefit-card-desc">
            El sustituto encuentra el proceso cuando lo necesita.
            Menos dependencia del tutor, menos esperas, menos improvisación.
          </p>
        </div>

        <div class="benefit-card">
          <div class="benefit-card-icon">🔒</div>
          <h3 class="benefit-card-title">Conocimiento protegido</h3>
          <p class="benefit-card-desc">
            Lo que sabe tu experto ya no vive solo en su cabeza.
            Está documentado, accesible y no se pierde cuando se va.
          </p>
        </div>

        <div class="benefit-card">
          <div class="benefit-card-icon">📊</div>
          <h3 class="benefit-card-title">Datos, no intuiciones</h3>
          <p class="benefit-card-desc">
            Sabes qué procesos se consultan, cuáles generan incidencias
            y qué operarios necesitan más apoyo.
          </p>
        </div>

        <div class="benefit-card">
          <div class="benefit-card-icon">🛡️</div>
          <h3 class="benefit-card-title">Menos errores</h3>
          <p class="benefit-card-desc">
            El proceso se ejecuta con el mismo orden y los mismos criterios.
            Menos reprocesos, menos riesgo.
          </p>
        </div>

        <div class="benefit-card">
          <div class="benefit-card-icon">✅</div>
          <h3 class="benefit-card-title">Más claridad sobre lo que ya se ha hecho</h3>
          <p class="benefit-card-desc">
            Queda una base útil para saber qué se ha seguido, cuándo
            y dónde sigue haciendo falta apoyo.
          </p>
        </div>

        <div class="benefit-card">
          <div class="benefit-card-icon">🔧</div>
          <h3 class="benefit-card-title">Guía de incidencias</h3>
          <p class="benefit-card-desc">
            Resolución de incidencias paso a paso integrada en cada proceso.
            Aviso automático al supervisor si hace falta.
          </p>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- COMO QUEDA REGISTRADO -->
  <section class="section section-center" id="registro">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Cómo queda registrado</div>
        <h2 class="section-title">Más que una biblioteca de procesos:<br><em>una base útil de evidencia</em></h2>
        <p class="section-sub">
          REELEVO no solo deja el trabajo disponible en el puesto. También puede dejar una base útil
          para seguimiento interno, formación y revisión operativa sin complicar el acceso en planta.
        </p>
      </div>

      <div class="evidence-grid fade-up delay-1">
        <div class="evidence-card">
          <div class="evidence-kicker">Qué</div>
          <h3 class="evidence-title">Proceso y puesto</h3>
          <p class="evidence-desc">Qué proceso se siguió y en qué puesto, máquina o contexto de trabajo ocurrió.</p>
        </div>
        <div class="evidence-card">
          <div class="evidence-kicker">Cuándo</div>
          <h3 class="evidence-title">Momento y versión</h3>
          <p class="evidence-desc">Fecha, hora y versión visible del proceso para entender con qué referencia se trabajó.</p>
        </div>
        <div class="evidence-card">
          <div class="evidence-kicker">Cómo</div>
          <h3 class="evidence-title">Resultado y apoyo</h3>
          <p class="evidence-desc">Si el flujo quedó completado, si hubo incidencias y dónde sigue haciendo falta apoyo.</p>
        </div>
        <div class="evidence-card">
          <div class="evidence-kicker">Quién</div>
          <h3 class="evidence-title">Cuando aplica</h3>
          <p class="evidence-desc">En los flujos que lo necesitan, la empresa puede asociar el uso a un identificador interno.</p>
        </div>
      </div>

      <div class="mode-grid fade-up delay-2">
        <article class="mode-card">
          <div class="mode-label">Consulta rápida</div>
          <h3 class="mode-title">Cuando lo importante es desbloquear el puesto</h3>
          <p class="mode-desc">
            Prioriza que alguien encuentre qué hacer y arranque con la mínima fricción posible.
            Es útil para cobertura, dudas puntuales y estandarización en el puesto.
          </p>
          <ul class="mode-points">
            <li>Menos espera para empezar</li>
            <li>Más autonomía en el puesto</li>
            <li>Señal básica de uso</li>
          </ul>
        </article>

        <article class="mode-card featured">
          <div class="mode-label">Seguimiento asociado</div>
          <h3 class="mode-title">Cuando necesitas una base más útil de evidencia</h3>
          <p class="mode-desc">
            Añade un identificador interno en los flujos donde la empresa necesita acompañar
            onboarding, seguimiento interno, calidad o auditorías.
          </p>
          <ul class="mode-points">
            <li>Más claridad para formación</li>
            <li>Seguimiento interno más sólido</li>
            <li>Base más útil para revisión operativa</li>
          </ul>
        </article>
      </div>

      <div class="trust-uses fade-up delay-3">
        <div class="trust-use">
          <h3 class="trust-use-title">Formación</h3>
          <p class="trust-use-desc">Ayuda a ver quién sigue necesitando apoyo y quién ya puede trabajar con más autonomía.</p>
        </div>
        <div class="trust-use">
          <h3 class="trust-use-title">Calidad y auditoría interna</h3>
          <p class="trust-use-desc">Aporta una base más útil para revisar qué referencia se siguió y cuándo ocurrió.</p>
        </div>
        <div class="trust-use">
          <h3 class="trust-use-title">Operación</h3>
          <p class="trust-use-desc">Da más contexto para entender repeticiones, incidencias y dependencia de ciertos puestos.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- EXPLORA POR NECESIDAD -->
  <section class="section section-center">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Explora por necesidad</div>
        <h2 class="section-title">Empieza por el escenario que más te duele en planta</h2>
        <p class="section-sub">
          REELEVO conecta el mismo núcleo de producto con problemas distintos:
          cobertura de bajas, onboarding, transferencia de conocimiento, calidad operativa, matriz de habilidades y evaluación de alternativas.
        </p>
      </div>

      <div class="explore-grid fade-up delay-1">
        <a href="/casos-de-uso/cobertura-bajas/" class="explore-card">
          <div class="explore-kicker">Cobertura de bajas</div>
          <h3 class="explore-title">Cuando falta el experto y la línea no puede parar</h3>
          <p class="explore-desc">Cómo poner el proceso del titular en manos del sustituto en segundos.</p>
        </a>

        <a href="/casos-de-uso/onboarding-operarios/" class="explore-card">
          <div class="explore-kicker">Onboarding de operarios</div>
