---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Cómo funciona REELEVO — Documentación operativa en 3 pasos simples";
const description = "El operario experto graba cada paso del proceso. Imprimimos el QR en la máquina. El sustituto escanea y accede a las instrucciones paso a paso. Sin usuarios, sin apps, sin complicaciones.";

const schema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "Cómo usar REELEVO",
  "description": "Guía paso a paso para documentar procesos operativos con REELEVO",
  "step": [
    {
      "@type": "HowToStep",
      "text": "El operario experto graba cada paso del proceso con su móvil"
    },
    {
      "@type": "HowToStep",
      "text": "Subimos los vídeos al panel y generamos el QR para la máquina"
    },
    {
      "@type": "HowToStep",
      "text": "El sustituto escanea el QR y accede a las instrucciones"
    }
  ]
};
---

<BaseLayout
  title={title}
  description={description}
  schema={schema}
  activeNav="como-funciona"
>
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="eyebrow fade-up">Flujo completo</div>
    <h1 class="fade-up delay-1">Así funciona <em>REELEVO</em><br>paso a paso.</h1>
    <p class="fade-up delay-2">Tres participantes, tres perspectivas. El conocimiento del experto llega al sustituto en segundos, sin fricción, sin cuenta de usuario, sin app que instalar.</p>
  </section>

  <div class="divider"></div>

  <!-- FLUJO PASO A PASO -->
  <section class="section">
    <div class="section-inner">
      <!-- PASO 1: EXPERTO -->
      <div class="step-section fade-up">
        <div class="step-number">1</div>
        <div class="step-content">
          <div class="step-role">👨‍🔧 El operario experto</div>
          <h2 class="section-title">Graba su conocimiento</h2>
          <p class="section-sub">
            Con su propio móvil, el operario clave graba cada paso del proceso.
            30-90 segundos por paso, sin prisas, explicando los detalles que importan.
          </p>

          <div class="scenarios-grid">
            <div class="scenario-card">
              <div class="scenario-tag">Preparación</div>
              <h3 class="scenario-card-title">«Así preparo la máquina»</h3>
              <p>Graba el checklist de preparación, parámetros clave, puntos de atención.</p>
            </div>

            <div class="scenario-card">
              <div class="scenario-tag">Ejecución</div>
              <h3 class="scenario-card-title">«Esto es lo que hago»</h3>
              <p>Cada paso del proceso operativo, con los trucos y detalles de la experiencia.</p>
            </div>

            <div class="scenario-card">
              <div class="scenario-tag">Problemas</div>
              <h3 class="scenario-card-title">«Si pasa esto, haces esto»</h3>
              <p>Troubleshooting para los problemas más comunes y cuándo avisar al supervisor.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="step-arrow fade-up delay-1">
        <svg viewBox="0 0 24 24" style="width:40px;height:40px;fill:var(--orange);">
          <path d="M16.01 11H4v2h12.01v3L20 12l-3.99-4z"/>
        </svg>
      </div>

      <!-- PASO 2: ADMINISTRADOR -->
      <div class="step-section fade-up delay-1">
        <div class="step-number">2</div>
        <div class="step-content">
          <div class="step-role">⚙️ El responsable / supervisor</div>
          <h2 class="section-title">Organiza y distribuye</h2>
          <p class="section-sub">
            Los vídeos se suben al panel de administración. Se organizan por
            máquina, se genera el QR y se imprime para pegatinas físicas.
          </p>

          <div class="benefit-list">
            <div class="benefit-row">
              <div class="benefit-icon">📱</div>
              <div>
                <h3 class="benefit-title">Organización automática</h3>
                <p class="benefit-desc">Los vídeos se clasifican por máquina y proceso. Sin complicaciones técnicas.</p>
              </div>
              <div class="benefit-result">
                <div class="benefit-result-label">Resultado</div>
                <p>QR listo para imprimir y pegar en la máquina</p>
              </div>
            </div>

            <div class="benefit-row">
              <div class="benefit-icon">🏷️</div>
              <div>
                <h3 class="benefit-title">QR físico personalizado</h3>
                <p class="benefit-desc">Un QR único por máquina con el código de acceso de la empresa. Pegatina resistente.</p>
              </div>
              <div class="benefit-result">
                <div class="benefit-result-label">Resultado</div>
                <p>Acceso directo sin usuarios ni contraseñas</p>
              </div>
            </div>

            <div class="benefit-row">
              <div class="benefit-icon">📊</div>
              <div>
                <h3 class="benefit-title">Monitor en tiempo real</h3>
                <p class="benefit-desc">Dashboard que muestra quién está operando qué máquina y cuándo.</p>
              </div>
              <div class="benefit-result">
                <div class="benefit-result-label">Resultado</div>
                <p>Visibilidad total de la actividad operativa</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="step-arrow fade-up delay-2">
        <svg viewBox="0 0 24 24" style="width:40px;height:40px;fill:var(--orange);">
          <path d="M16.01 11H4v2h12.01v3L20 12l-3.99-4z"/>
        </svg>
      </div>

      <!-- PASO 3: OPERARIO -->
      <div class="step-section fade-up delay-2">
        <div class="step-number">3</div>
        <div class="step-content">
          <div class="step-role">👤 El sustituto / nuevo operario</div>
          <h2 class="section-title">Opera desde el primer momento</h2>
          <p class="section-sub">
            Escanea el QR de la máquina, introduce el código de empresa de 4 dígitos
            y accede a las instrucciones paso a paso. Sin crear cuenta, sin instalaciones.
          </p>

          <div class="scenario-grid">
            <div class="scenario-card">
              <div class="scenario-card-tag">1. Escanear QR</div>
              <h3 class="scenario-card-title">Con cualquier móvil</h3>
              <div class="scenario-before">Sin REELEVO: Buscar al supervisor, esperar explicación, preguntar dudas</div>
              <div class="scenario-after">Con REELEVO: Escaneo QR → código empresa → instrucciones al instante</div>
            </div>

            <div class="scenario-card">
              <div class="scenario-card-tag">2. Seguir pasos</div>
              <h3 class="scenario-card-title">Vídeo a vídeo</h3>
              <div class="scenario-before">Sin REELEVO: Depender de la memoria, cometer errores, llamar al tutor</div>
              <div class="scenario-after">Con REELEVO: Cada paso explicado por el experto, sin dudas</div>
            </div>

            <div class="scenario-card">
              <div class="scenario-card-tag">3. Resolver problemas</div>
              <h3 class="scenario-card-title">Troubleshooting inline</h3>
              <div class="scenario-before">Sin REELEVO: Parar la línea, llamar al supervisor, esperar ayuda</div>
              <div class="scenario-after">Con REELEVO: Problemas comunes resueltos al instante, aviso automático si necesita ayuda</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- DETALLES TÉCNICOS -->
  <section class="section section-center">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Detalles técnicos</div>
        <h2 class="section-title">Sin complicaciones tecnológicas</h2>
        <p class="section-sub">
          REELEVO está diseñado para funcionar con la tecnología que ya tienes.
          Sin instalaciones, sin infraestructura adicional.
        </p>
      </div>

      <div class="benefits-grid fade-up delay-1">
        <div class="benefit-card">
          <div class="benefit-card-icon">📱</div>
          <h3 class="benefit-card-title">Móvil cualquiera</h3>
          <p class="benefit-card-desc">
            Funciona con cualquier smartphone con cámara.
            iOS o Android. Sin app que instalar.
          </p>
        </div>

        <div class="benefit-card">
          <div class="benefit-card-icon">☁️</div>
          <h3 class="benefit-card-title">En la nube</h3>
          <p class="benefit-card-desc">
            Acceso desde cualquier lugar con internet.
            Copias de seguridad automáticas.
          </p>
        </div>

        <div class="benefit-card">
          <div class="benefit-card-icon">🔒</div>
          <h3 class="benefit-card-title">Seguro y cumpliante</h3>
          <p class="benefit-card-desc">
            Servidores en Europa, RGPD cumpliante.
            Sin almacenar datos personales de operarios.
          </p>
        </div>

        <div class="benefit-card">
          <div class="benefit-card-icon">⚡</div>
          <h3 class="benefit-card-title">Velocidad</h3>
          <p class="benefit-card-desc">
            Los vídeos se cargan inmediatamente.
            Optimizados para conexiones móviles.
          </p>
        </div>

        <div class="benefit-card">
          <div class="benefit-card-icon">🔌</div>
          <h3 class="benefit-card-title">Integraciones</h3>
          <p class="benefit-card-desc">
            API para conectar con tu ERP, sistema de RRHH
            o software de gestión de planta.
          </p>
        </div>

        <div class="benefit-card">
          <div class="benefit-card-icon">📊</div>
          <h3 class="benefit-card-title">Analytics</h3>
          <p class="benefit-card-desc">
            Informes de uso, competencias adquiridas,
            tiempo de acceso por operación.
          </p>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- FAQ -->
  <section class="section">
    <div class="section-inner">
      <div class="fade-up" style="text-align:center;margin-bottom:48px;">
        <div class="eyebrow">Preguntas frecuentes</div>
        <h2 class="section-title">Resolvemos tus dudas</h2>
        <p class="section-sub">
          Las preguntas más habituales sobre implementación, seguridad y funcionamiento técnico.
        </p>
      </div>

      <div class="faq-grid fade-up delay-1">
        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">
            <span>¿Cuánto tiempo lleva implementar REELEVO?</span>
            <svg viewBox="0 0 24 24" stroke="currentColor">
              <polyline points="6,9 12,15 18,9"></polyline>
            </svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              <p>La implementación de REELEVO es <strong>inmediata</strong>. Una vez que el operario experto graba los procesos (30-90 minutos por proceso completo), generamos los QR y en cuestión de horas ya tienes el sistema funcionando en planta.</p>
              <p>No hay que instalar software, configurar servidores ni formar a los operarios en nuevas herramientas. Simplemente escanean y operan.</p>
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">
            <span>¿Qué pasa si no hay cobertura móvil en la planta?</span>
            <svg viewBox="0 0 24 24" stroke="currentColor">
              <polyline points="6,9 12,15 18,9"></polyline>
            </svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              <p>REELEVO funciona con <strong>cualquier conexión a internet</strong>: 4G, 5G, WiFi de empresa, etc. Los vídeos están optimizados para cargar rápidamente incluso con conexiones lentas.</p>
              <p>Si hay zonas sin cobertura, podemos diseñar una solución híbrida con contenido offline para esas áreas específicas.</p>
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">
            <span>¿Los operarios tienen que crearse una cuenta?</span>
            <svg viewBox="0 0 24 24" stroke="currentColor">
              <polyline points="6,9 12,15 18,9"></polyline>
            </svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              <p><strong>No</strong>. Es nuestro diferencial clave. Los operarios escanean el QR, introducen el código de empresa de 4 dígitos, y acceden al contenido. Sin crear cuentas, sin contraseñas, sin gestión de usuarios.</p>
              <p>Esto elimina la fricción de adopción y hace que cualquier sustituto (fijo, ETT, temporal) pueda operar inmediatamente.</p>
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">
            <span>¿Cómo sabemos quién ha accedido y cuándo?</span>
            <svg viewBox="0 0 24 24" stroke="currentColor">
              <polyline points="6,9 12,15 18,9"></polyline>
            </svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              <p>Aunque no hay cuentas de operario, <strong>REELEVO rastrea toda la actividad</strong>: qué QR se ha escaneado, cuándo, qué proceso se ha consultado, y si se ha completado correctamente.</p>
              <p>El dashboard en tiempo real te muestra qué máquinas están siendo operadas y por cuánto tiempo. Sin comprometer la privacidad, con total trazabilidad operativa.</p>
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">
            <span>¿Podemos actualizar los procesos fácilmente?</span>
            <svg viewBox="0 0 24 24" stroke="currentColor">
              <polyline points="6,9 12,15 18,9"></polyline>
            </svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              <p><strong>Sí</strong>. Cualquier administrador puede subir nuevos vídeos, modificar procesos existentes o reorganizar los contenidos desde el panel de administración.</p>
              <p>Los cambios se reflejan automáticamente en todos los QR. No hay que reimprimir pegatinas ni reconfigurar nada. El operario siempre accede a la versión más actual del proceso.</p>
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">
            <span>¿Es compatible con nuestros sistemas de gestión?</span>
            <svg viewBox="0 0 24 24" stroke="currentColor">
              <polyline points="6,9 12,15 18,9"></polyline>
            </svg>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              <p>REELEVO integra con <strong>Factorial, Personio, SAP, Oracle</strong> y la mayoría de sistemas de RRHH y ERP mediante API.</p>
              <p>Esto permite sincronizar competencias adquiridas, horas de formación efectivas y certificaciones automáticas directamente en tu sistema de gestión de personal.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-eyebrow fade-up">¿Todo claro?</div>
    <h2 class="cta-title fade-up delay-1">
      Empieza hoy mismo
    </h2>
    <p class="cta-sub fade-up delay-2">
      Configura tu primer proceso en menos de 1 hora.
      30 días gratis para probarlo en tu planta.
    </p>
    <div class="fade-up delay-3" style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
      <a href="https://app.gmvsolutions.es/registro" class="btn-primary">
        Crear cuenta gratis →
      </a>
      <a href="/precios" class="btn-ghost">
        Ver precios
      </a>
    </div>
    <div class="cta-note fade-up delay-4">
      Sin tarjeta de crédito · Implementación asistida · Configuración en 1 día
    </div>
  </section>
</BaseLayout>

<style>
  /* Step sections */
  .step-section {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 40px;
    align-items: start;
    margin: 80px 0;
  }

  .step-number {
    width: 80px;
    height: 80px;
    background: var(--orange);
    color: var(--white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Oswald', sans-serif;
    font-size: 2rem;
    font-weight: 700;
  }

  .step-role {
    font-family: 'DM Mono', monospace;
    font-size: .7rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 16px;
  }

  .step-arrow {
    text-align: center;
    margin: 40px 0;
  }

  .scenarios-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-top: 40px;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-top: 48px;
  }

  .benefit-card {
    background: var(--surface);
    padding: 32px 28px;
    text-align: center;
  }

  .benefit-card-icon {
    font-size: 2.5rem;
    margin-bottom: 20px;
  }

  .benefit-card-title {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .03em;
    margin-bottom: 12px;
  }

  .benefit-card-desc {
    font-size: .85rem;
    color: var(--gray);
    line-height: 1.65;
  }

  /* FAQ */
  .faq-grid {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-top: 48px;
  }

  .faq-item {
    background: var(--surface);
  }

  .faq-question {
    width: 100%;
    padding: 22px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background .15s;
    color: inherit;
  }

  .faq-question:hover {
    background: rgba(255, 255, 255, .02);
  }

  .faq-question span {
    font-family: 'Oswald', sans-serif;
    font-size: .92rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .03em;
    color: var(--white);
  }

  .faq-question svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    stroke: var(--gray);
    transition: transform .3s;
    fill: none;
    stroke-width: 2;
  }

  .faq-item.open .faq-question svg {
    transform: rotate(180deg);
  }

  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height .35s ease;
  }

  .faq-item.open .faq-answer {
    max-height: 400px;
  }

  .faq-answer-inner {
    padding: 0 32px 24px;
    font-size: .88rem;
    color: var(--gray);
    line-height: 1.7;
    max-width: 680px;
  }

  .faq-answer-inner p {
    margin-bottom: 12px;
  }

  .faq-answer-inner strong {
    color: var(--white);
    font-weight: 500;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .step-section {
      grid-template-columns: 1fr;
      gap: 20px;
      text-align: center;
    }

    .scenarios-grid,
    .benefits-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .step-section {
      margin: 60px 0;
    }

    .faq-question {
      padding: 18px 20px;
    }

    .faq-answer-inner {
      padding: 0 20px 20px;
    }
  }
</style>

<script>
  function toggleFaq(button: HTMLButtonElement) {
    const item = button.closest('.faq-item');
    const isOpen = item?.classList.contains('open');

    // Close all FAQ items
    document.querySelectorAll('.faq-item').forEach(item => {
      item.classList.remove('open');
    });

    // Open clicked item if it wasn't already open
    if (!isOpen) {
      item?.classList.add('open');
    }
  }
</script>