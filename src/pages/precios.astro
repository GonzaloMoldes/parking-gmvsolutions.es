---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Precios REELEVO — menos dependencia operativa desde 49€/mes";
const description = "Precio por empresa para reducir improvisación, ordenar incorporaciones y ganar visibilidad operativa en planta sin pagar por operario.";
const primaryCtaHref = "https://app.gmvsolutions.es/registro";
const secondaryCtaHref = "https://diagnostico.gmvsolutions.es";
const primaryCtaLabel = "Registrarme en REELEVO";

const schema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "REELEVO",
  "description": "Software SOP industrial para reducir improvisación, ordenar incorporaciones y ganar visibilidad operativa en planta",
  "offers": [
    {
      "@type": "Offer",
      "name": "Starter",
      "price": "49",
      "priceCurrency": "EUR",
      "url": "https://app.gmvsolutions.es/registro"
    },
    {
      "@type": "Offer",
      "name": "Profesional",
      "price": "149",
      "priceCurrency": "EUR",
      "url": "https://app.gmvsolutions.es/registro"
    }
  ]
};
---

<!-- GLOSSARY: operario, baja, onboarding, competencias, tutor, incorporación, SOP, continuidad -->
<!-- CONTEXT: operational, marketing, product -->
<!-- EN_TERMS: [machine operator, absence, onboarding, skills, mentor, operator onboarding, standard operating procedure, continuity] -->
<!-- PT_TERMS: [operador, falta, integração, competências, mentor, integração de operadores, procedimento operativo padrão, continuidade] -->

<BaseLayout
  title={title}
  description={description}
  schema={schema}
  activeNav="precios"
>
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="eyebrow fade-up">Precio por empresa</div>
    <h1 class="fade-up delay-1">Pagas por la planta.<br><em>No por cada operario.</em></h1>
    <p class="fade-up delay-2">REELEVO se compra en capas claras: primero continuidad operativa, orden en planta y mejor documentación de procesos de producción, después expansión para producción, formación y calidad, y solo al final requisitos enterprise o despliegues más especiales.</p>
  </section>

  <div class="divider"></div>

  <!-- CAPAS DE VALOR -->
  <section class="section section-center">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Qué compras realmente</div>
        <h2 class="section-title">Primero el <em>core operativo</em>, luego el resto</h2>
        <p class="section-sub">
          REELEVO no se plantea como una suite gigante desde el día 1. Primero resuelve continuidad,
          orden y claridad operativa. Después amplías formación, polivalencia e integración.
        </p>
      </div>

      <div class="pricing-layers fade-up delay-1">
        <article class="pricing-layer">
          <div class="pricing-layer-label">Core operativo</div>
          <h3 class="pricing-layer-title">Menos improvisación y mejor arranque</h3>
          <p class="pricing-layer-desc">
            El trabajo aparece donde hace falta, con una implantación asumible y menos
            dependencia del tutor o del operario titular.
          </p>
        </article>

        <article class="pricing-layer">
          <div class="pricing-layer-label">Expansión</div>
          <h3 class="pricing-layer-title">Más claridad y aprendizaje útil</h3>
          <p class="pricing-layer-desc">
            Más visibilidad para producción y una base más útil para ordenar
            formación, polivalencia y seguimiento interno.
          </p>
        </article>

        <article class="pricing-layer">
          <div class="pricing-layer-label">Enterprise</div>
          <h3 class="pricing-layer-title">Enterprise y requisitos avanzados</h3>
          <p class="pricing-layer-desc">
            Cuando necesitas más escala, seguridad, compliance o integración, se trabaja
            como capa avanzada según alcance y caso de uso.
          </p>
        </article>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- MAPA COMERCIAL -->
  <section class="section section-center">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Cómo se empaqueta</div>
        <h2 class="section-title">Qué entra en <em>cada capa comercial</em></h2>
        <p class="section-sub">
          La idea no es vender una suite inflada desde el día 1.
          La idea es que sepas qué compras ahora, qué puedes ampliar después y qué se revisa solo si de verdad hace falta.
        </p>
      </div>

      <div class="package-grid fade-up delay-1">
        <article class="package-card">
          <div class="package-label">Base incluida</div>
          <h3 class="package-title">Lo que toda planta compra primero</h3>
          <ul class="package-list">
            <li>Menos improvisación en el puesto</li>
            <li>Arranque más ordenado cuando falta alguien</li>
            <li>Trabajo accesible sin fricción innecesaria</li>
            <li>Primer nivel de visibilidad sobre la ejecución</li>
          </ul>
        </article>

        <article class="package-card">
          <div class="package-label">Expansión operativa</div>
          <h3 class="package-title">Lo que amplía valor dentro de la planta</h3>
          <ul class="package-list">
            <li>Más claridad para producción y coordinación del turno</li>
            <li>Más base útil para formación y polivalencia</li>
            <li>Más soporte a calidad y seguimiento interno</li>
            <li>Reporting y visibilidad más completos</li>
          </ul>
        </article>

        <article class="package-card">
          <div class="package-label">Enterprise</div>
          <h3 class="package-title">Lo que aparece cuando el entorno lo pide</h3>
          <ul class="package-list">
            <li>Integraciones, API y requisitos de IT</li>
            <li>SSO o despliegues corporativos</li>
            <li>Acuerdos de soporte más dedicados</li>
            <li>Necesidades avanzadas de reporting o conformidad</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- PLANES -->
  <section class="section" id="planes">
    <div class="section-inner">
      <div class="plans-grid fade-up">
        <!-- STARTER -->
        <div class="plan-card">
          <div class="plan-name">Starter</div>
          <div class="plan-scope">Core comercial</div>
          <div class="plan-price">49€<sub>/mes</sub></div>
          <div class="plan-period">Facturación mensual · Sin compromiso</div>
          <div class="plan-desc">Para una planta o línea que quiere empezar por lo esencial: menos improvisación, mejor arranque en puesto y más orden operativo sin complicarse.</div>
          <div class="plan-features">
            <div class="plan-feature"><span class="check">✓</span>1 planta / centro de trabajo</div>
            <div class="plan-feature"><span class="check">✓</span>Hasta 5 máquinas o puestos</div>
            <div class="plan-feature"><span class="check">✓</span>6 Procesos por máquina</div>
            <div class="plan-feature"><span class="check">✓</span>Operarios ilimitados (sin coste)</div>
            <div class="plan-feature"><span class="check">✓</span>Acceso directo al proceso en el puesto, sin cuenta de operario</div>
            <div class="plan-feature"><span class="check">✓</span>Trabajo guiado paso a paso</div>
            <div class="plan-feature"><span class="check">✓</span>Más claridad básica sobre la ejecución</div>
            <div class="plan-feature"><span class="check">✓</span>Apoyo ante incidencias repetitivas</div>
            <div class="plan-feature"><span class="check">✓</span>Estadísticas básicas de uso</div>
            <div class="plan-feature"><span class="check">✓</span>Exportación CSV</div>
            <div class="plan-feature"><span class="cross">×</span>Múltiples plantas</div>
            <div class="plan-feature"><span class="cross">×</span>Productividad avanzada y reporting</div>
            <div class="plan-feature"><span class="cross">×</span>API de integración</div>
          </div>
          <div class="plan-cta">
            <a href={primaryCtaHref} class="btn-ghost" style="width:100%;text-align:center;font-size:.82rem;padding:14px 20px;display:block;">{primaryCtaLabel}</a>
            <p class="plan-note">El botón te lleva al registro de la plataforma</p>
          </div>
        </div>

        <!-- PROFESIONAL -->
        <div class="plan-card featured">
          <div class="plan-badge">Más popular</div>
          <div class="plan-name">Profesional</div>
          <div class="plan-scope">Core + expansión</div>
          <div class="plan-price">149€<sub>/mes</sub></div>
          <div class="plan-period">Facturación mensual · Sin compromiso</div>
          <div class="plan-desc">Para empresas que además quieren más claridad para producción, menos tiempo perdido y mejor coordinación entre operación, formación y seguimiento.</div>
          <div class="plan-features">
            <div class="plan-feature"><span class="check">✓</span>Hasta 3 plantas / centros</div>
            <div class="plan-feature"><span class="check">✓</span>Hasta 20 máquinas o puestos</div>
            <div class="plan-feature"><span class="check">✓</span>Todo lo del plan Starter</div>
            <div class="plan-feature"><span class="check">✓</span>Más claridad para producción y coordinación del turno</div>
            <div class="plan-feature"><span class="check">✓</span>Seguimiento operativo más útil y reporting</div>
            <div class="plan-feature"><span class="check">✓</span>Más visibilidad para formación y polivalencia</div>
            <div class="plan-feature"><span class="check">✓</span>Exportación CSV y Excel</div>
            <div class="plan-feature"><span class="roadmap">○</span>Posibles integraciones con software de RRHH <span class="plan-badge-roadmap">Según el caso</span></div>
            <div class="plan-feature"><span class="check">✓</span>Soporte prioritario</div>
          </div>
          <div class="plan-cta">
            <a href={primaryCtaHref} class="btn-primary">{primaryCtaLabel}</a>
            <p class="plan-note">Te ayudamos a validar si este es el plan que encaja</p>
          </div>
        </div>

        <!-- ENTERPRISE -->
        <div class="plan-card">
          <div class="plan-name">Enterprise</div>
          <div class="plan-scope">Requisitos avanzados</div>
          <div class="plan-price">A medida</div>
          <div class="plan-period">Contacta para presupuesto personalizado</div>
          <div class="plan-desc">Para grupos industriales o despliegues con requisitos avanzados de integración, seguridad, soporte o compliance.</div>
          <div class="plan-features">
            <div class="plan-feature"><span class="check">✓</span>Todo lo del plan Profesional</div>
            <div class="plan-feature"><span class="check">✓</span>Plantas, máquinas y puestos a medida</div>
            <div class="plan-feature"><span class="check">✓</span>Usuarios administrativos a medida</div>
            <div class="plan-feature"><span class="roadmap">○</span>SSO / directorio corporativo <span class="plan-badge-roadmap">Según el caso</span></div>
            <div class="plan-feature"><span class="roadmap">○</span>API, webhooks e integraciones <span class="plan-badge-roadmap">Según alcance</span></div>
            <div class="plan-feature"><span class="roadmap">○</span>Integraciones ERP o RRHH <span class="plan-badge-roadmap">Según el caso</span></div>
            <div class="plan-feature"><span class="check">✓</span>Necesidades avanzadas de reporting y conformidad</div>
            <div class="plan-feature"><span class="check">✓</span>Acuerdo de soporte dedicado</div>
            <div class="plan-feature"><span class="check">✓</span>Implementación asistida</div>
          </div>
          <div class="plan-cta">
            <a href="mailto:hola@gmvsolutions.es" class="btn-ghost" style="width:100%;text-align:center;font-size:.82rem;padding:14px 20px;display:block;">Hablar con nosotros</a>
            <p class="plan-note">Cuéntanos el alcance y te orientamos</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider" style="max-width:100%;"></div>

  <!-- CALCULADORA ROI -->
  <section class="roi-section" id="roi">
    <div class="roi-inner">
      <div class="eyebrow fade-up">Calculadora de ROI</div>
      <h2 class="section-title fade-up delay-1">¿Cuánto te cuesta seguir <em>operando con improvisación</em>?</h2>
      <p class="section-sub fade-up delay-2">Estimación conservadora del impacto de bajas e incorporaciones cuando el proceso no está claro en el puesto y la operación depende demasiado del tutor o del titular.</p>

      <div class="roi-grid fade-up delay-3">
        <div class="roi-inputs">
          <div class="roi-field">
            <label>Número de trabajadores <span id="lbl-workers">40</span></label>
            <input type="range" min="10" max="200" step="5" value="40" id="sl-workers">
          </div>
          <div class="roi-field">
            <label>Tasa de absentismo (%) <span id="lbl-abs">7</span>%</label>
            <input type="range" min="3" max="15" step="0.5" value="7" id="sl-abs">
          </div>
          <div class="roi-field">
            <label>Coste diario por trabajador (€) <span id="lbl-daily">120</span>€</label>
            <input type="range" min="60" max="300" step="10" value="120" id="sl-daily">
          </div>
          <div class="roi-field">
            <label>Días perdidos por baja sin cubrir <span id="lbl-lost">1.5</span></label>
            <input type="range" min="0.5" max="5" step="0.5" value="1.5" id="sl-lost">
          </div>
          <div style="font-size:.78rem;color:var(--gray2);line-height:1.55;">* Días efectivos de producción reducida por baja no cubierta correctamente hasta que entra el sustituto a pleno rendimiento.</div>
        </div>

        <div class="roi-result">
          <div class="roi-result-row">
            <span class="roi-result-label">Bajas anuales estimadas</span>
            <span class="roi-result-value" id="res-absences">123</span>
          </div>
          <div class="roi-result-row">
            <span class="roi-result-label">Coste directo por baja no cubierta</span>
            <span class="roi-result-value" id="res-perbaja">180€</span>
          </div>
          <div class="roi-result-row">
            <span class="roi-result-label">Impacto total anual estimado</span>
            <span class="roi-result-value" id="res-annual">22.140€</span>
          </div>
          <div class="roi-result-row prominent">
            <span class="roi-result-label">Ahorro estimado con REELEVO (~25%)</span>
            <span class="roi-result-value" id="res-savings">8.856€</span>
          </div>
          <div class="roi-result-summary">
            <div class="roi-result-big">
              <span class="roi-result-big-label">ROI estimado</span>
              <span class="roi-result-big-value" id="res-roi">×5.0</span>
            </div>
            <div class="roi-result-payback" id="res-payback">Recuperas la inversión en aprox. 2.4 meses</div>
          </div>
          <div class="roi-result-note">* REELEVO reduce parte del impacto de las bajas —menos errores, menos tiempo de parada y menos dependencia del tutor— pero no lo elimina. El cálculo usa una hipótesis conservadora de reducción del 25% del coste directo y toma como referencia el plan Profesional anualizado.</div>
          <div style="margin-top:20px;">
            <a href={primaryCtaHref} class="btn-primary" style="font-size:.8rem;padding:12px 24px;">{primaryCtaLabel} →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider" style="max-width:100%;"></div>

  <!-- BAND -->
  <div class="trial-band">
    <div class="trial-title fade-up">Todos los planes parten del mismo <em>núcleo</em></div>
    <div class="trial-bullets fade-up delay-1">
      <div class="trial-bullet"><span>✓</span>Trabajo accesible en el puesto</div>
      <div class="trial-bullet"><span>✓</span>Sin fricción para el operario</div>
      <div class="trial-bullet"><span>✓</span>Más claridad sobre la ejecución</div>
      <div class="trial-bullet"><span>✓</span>Arranque técnico ligero y asistido</div>
      <div class="trial-bullet"><span>✓</span>Soporte en español</div>
    </div>
    <div class="cta-actions fade-up delay-2">
      <a href={primaryCtaHref} class="btn-primary">{primaryCtaLabel} →</a>
      <a href={secondaryCtaHref} class="btn-ghost">Evaluar mi situación</a>
    </div>
  </div>

  <div class="divider" style="max-width:100%;"></div>

  <!-- COMPARATIVA -->
  <section class="section section-center">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Cómo se compra</div>
        <h2 class="section-title">REELEVO vs <em>herramienta enterprise típica</em></h2>
        <p class="section-sub">
          La diferencia no es meter más catálogo desde el minuto uno.
          La diferencia es empezar por continuidad operativa y orden en planta con un modelo asumible.
        </p>
      </div>

      <div class="comp-scroll fade-up delay-1" style="margin-top:48px;">
        <table class="comp-table">
          <thead>
            <tr>
              <th class="comp-feature-col"></th>
              <th class="comp-highlight">REELEVO</th>
              <th>Herramienta enterprise típica</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="comp-label">Modelo de compra</td>
              <td class="comp-highlight">Precio visible por empresa</td>
              <td>Presupuesto y alcance más cerrados tras llamada</td>
            </tr>
            <tr>
              <td class="comp-label">Arranque en planta</td>
              <td class="comp-highlight">Trabajo accesible en el puesto, sin fricción para el operario</td>
              <td>Despliegue y gestión de acceso normalmente más pesados</td>
            </tr>
            <tr>
              <td class="comp-label">Puesta en marcha</td>
              <td class="comp-highlight">Empiezas por procesos o puestos críticos</td>
              <td>Suele pedir un proyecto más amplio desde el inicio</td>
            </tr>
            <tr>
              <td class="comp-label">Valor principal</td>
              <td class="comp-highlight">Menos dependencia y más visibilidad operativa</td>
              <td>Más amplitud de suite, normalmente con más complejidad</td>
            </tr>
            <tr>
              <td class="comp-label">Encaje natural</td>
              <td class="comp-highlight">Pyme industrial que quiere empezar rápido y con foco</td>
              <td>Proyecto corporativo con más presupuesto y más dependencia de despliegue</td>
            </tr>
            <tr>
              <td class="comp-label">Escalado</td>
              <td class="comp-highlight">Productividad, competencia e integraciones según el plan</td>
              <td>Normalmente fuerte en enterprise, pero menos ligero para arrancar</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-eyebrow fade-up">Siguiente paso</div>
    <h2 class="cta-title fade-up delay-1">
      Si quieres verla por dentro,<br><em>regístrate en REELEVO</em>
    </h2>
    <p class="cta-sub fade-up delay-2">
      El botón te lleva al registro de la plataforma. Después podrás entrar,
      revisar el producto y valorar si encaja con tu planta y tus procesos.
    </p>
    <div class="fade-up delay-3" style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
      <a href={primaryCtaHref} class="btn-primary">
        {primaryCtaLabel} →
      </a>
      <a href={secondaryCtaHref} class="btn-ghost">
        Evaluar mi situación
      </a>
    </div>
    <div class="cta-note fade-up delay-4">
      Precio publicado · Implantación asistida · Arranque ligero en planta
    </div>
  </section>
</BaseLayout>

<style>
  .pricing-layers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .pricing-layer {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 28px 24px;
    border-radius: 6px;
    text-align: left;
  }

  .pricing-layer-label {
    font-family: 'DM Mono', monospace;
    font-size: .62rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 12px;
  }

  .pricing-layer-title {
    font-family: 'Oswald', sans-serif;
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: .02em;
    margin-bottom: 12px;
  }

  .pricing-layer-desc {
    font-size: .9rem;
    line-height: 1.65;
    color: var(--gray);
  }

  .package-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .package-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 28px 24px;
    text-align: left;
  }

  .package-label {
    font-family: 'DM Mono', monospace;
    font-size: .62rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 12px;
  }

  .package-title {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: .03em;
    margin-bottom: 12px;
  }

  .package-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .package-list li {
    font-size: .86rem;
    color: var(--gray);
    line-height: 1.65;
    padding: 10px 0;
    border-top: 1px solid var(--border);
  }

  .package-list li:first-child {
    border-top: none;
    padding-top: 0;
  }

  /* Plans */
  .plans-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-top: 48px;
  }

  .plan-card {
    background: var(--surface);
    padding: 40px 32px;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .plan-card.featured {
    border: 2px solid var(--orange);
  }

  .plan-badge {
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--orange);
    color: var(--white);
    font-family: 'DM Mono', monospace;
    font-size: .6rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    padding: 6px 16px;
    font-weight: 500;
  }

  .plan-name {
    font-family: 'Oswald', sans-serif;
    font-size: 1.2rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .05em;
    color: var(--orange);
    margin-bottom: 8px;
  }

  .plan-scope {
    font-family: 'DM Mono', monospace;
    font-size: .62rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 16px;
  }

  .plan-price {
    font-family: 'Oswald', sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 4px;
  }

  .plan-price sub {
    font-size: .6rem;
    color: var(--gray);
  }

  .plan-period {
    font-size: .8rem;
    color: var(--gray2);
    margin-bottom: 20px;
  }

  .plan-desc {
    font-size: .9rem;
    color: var(--gray);
    line-height: 1.65;
    margin-bottom: 28px;
  }

  .plan-features {
    flex: 1;
    margin-bottom: 32px;
  }

  .plan-feature {
