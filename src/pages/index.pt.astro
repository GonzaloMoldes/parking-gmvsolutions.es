<script>
  // Screenshots carousel
  (function () {
    const track = document.getElementById('screenshotsTrack') as HTMLElement | null;
    const wrap = track?.parentElement as HTMLElement | null;
    const slides = document.querySelectorAll<HTMLElement>('.screenshot-slide');
    const dots = document.querySelectorAll<HTMLButtonElement>('.carousel-dot');
    let current = 0;
    const total = slides.length;
    const AUTOPLAY_MS = 10000;
    let timer: ReturnType<typeof setInterval>;
    let resizeTimer: ReturnType<typeof setTimeout>;

    function getWidth() {
      return wrap?.offsetWidth ?? 0;
    }

    function applyWidths() {
      const w = getWidth();
      slides.forEach(s => { s.style.width = w + 'px'; });
      return w;
    }

    function goTo(n: number) {
      current = ((n % total) + total) % total;
      const w = applyWidths();
      if (track) track.style.transform = `translateX(-${current * w}px)`;
      dots.forEach((d, i) => d.classList.toggle('is-active', i === current));
    }

    function startAutoplay() {
      timer = setInterval(() => goTo(current + 1), AUTOPLAY_MS);
    }

    function stopAutoplay() {
      clearInterval(timer);
    }

    if (track && wrap && slides.length > 0) {
      applyWidths();
      goTo(0);
      startAutoplay();

      document.getElementById('carPrev')?.addEventListener('click', () => {
        stopAutoplay();
        goTo(current - 1);
        startAutoplay();
      });

      document.getElementById('carNext')?.addEventListener('click', () => {
        stopAutoplay();
        goTo(current + 1);
        startAutoplay();
      });

      dots.forEach((dot, i) => {
        dot.addEventListener('click', () => {
          stopAutoplay();
          goTo(i);
          startAutoplay();
        });
      });

      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(() => goTo(current), 150);
      });

      wrap.addEventListener('touchstart', () => stopAutoplay(), { passive: true });
      wrap.addEventListener('touchend', () => startAutoplay(), { passive: true });
    }
  })();
</script>

