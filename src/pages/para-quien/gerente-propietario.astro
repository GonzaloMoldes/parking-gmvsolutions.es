---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "REELEVO para Gerentes — menos dependencia operativa y más continuidad";
const description = "REELEVO ayuda a gerencia a reducir dependencia operativa, ganar visibilidad y empezar por puestos críticos sin abrir un proyecto pesado.";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "REELEVO para Gerentes y Propietarios",
  "description": "Solución específica para decisores y propietarios de empresas industriales",
  "audience": {
    "@type": "Audience",
    "audienceType": "Business Owner"
  }
};
---

<!-- GLOSSARY: operario, baja, onboarding, competencias, tutor, incorporación, SOP, continuidad -->
<!-- CONTEXT: operational, marketing, product -->
<!-- EN_TERMS: [machine operator, absence, onboarding, skills, mentor, operator onboarding, standard operating procedure, continuity] -->
<!-- PT_TERMS: [operador, falta, integração, competências, mentor, integração de operadores, procedimento operativo padrão, continuidade] -->

<BaseLayout
  title={title}
  description={description}
  schema={schema}
  activeNav=""
>
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="eyebrow fade-up">Para gerentes y propietarios</div>
    <h1 class="fade-up delay-1"><em>Menos dependencia,</em><br>más continuidad operativa.</h1>
    <p class="fade-up delay-2">REELEVO ayuda a reducir dependencia operativa, ganar continuidad y empezar por lo que más duele en planta sin abrir un proyecto pesado. Precio fijo por empresa y activación asumible.</p>
    <div class="hero-cta-group fade-up delay-3">
      <a href="https://app.gmvsolutions.es/registro" class="btn-primary">Registrarme en REELEVO →</a>
      <a href="https://diagnostico.gmvsolutions.es" class="btn-ghost">Evaluar mi situación</a>
    </div>
    <div class="hero-cta-note fade-up delay-4">Precio publicado · Arranque ligero · Soporte en español</div>
  </section>

  <div class="divider"></div>

  <!-- PRUEBA VISUAL -->
  <section class="section">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Prueba visual</div>
        <h2 class="section-title">Por qué no parece un proyecto <em>pesado</em></h2>
        <p class="section-sub">
          Lo que compra gerencia no es un catálogo infinito de features. Es una forma más simple de
          dar continuidad a la operación y ganar visibilidad sin pagar por cada operario.
        </p>
      </div>

      <div class="proof-grid fade-up delay-1">
        <div class="proof-card proof-shot">
          <div class="proof-frame">
            <img src="/screenshots/sop-operario.png" alt="Acceso al proceso desde el puesto en REELEVO" loading="lazy">
          </div>
          <div class="proof-caption">Captura real del producto: el trabajo aparece en el puesto sin añadir fricción al operario.</div>
        </div>

        <div class="proof-card proof-points">
          <h3>Lo que hace más fácil la decisión</h3>
          <div class="proof-point"><strong>Empiezas por lo crítico:</strong> no hace falta desplegar toda la planta de golpe.</div>
          <div class="proof-point"><strong>Sin coste por operario:</strong> el precio no castiga crecer o incorporar temporal.</div>
          <div class="proof-point"><strong>Más continuidad:</strong> menos dependencia de llamadas y memoria cuando falta alguien.</div>
          <div class="proof-point"><strong>Software real:</strong> la propuesta se puede enseñar ya sobre producto visible, no sobre una promesa abstracta.</div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- EXECUTIVE SUMMARY -->
  <section class="section">
    <div class="section-inner">
      <div class="fade-up" style="text-align:center;margin-bottom:64px;">
        <div class="eyebrow">Visión ejecutiva</div>
        <h2 class="section-title">Qué compra realmente la empresa</h2>
        <p class="section-sub">
          No compras “software para documentar”.
          Compras menos dependencia de personas clave y una operación más ordenada.
        </p>
      </div>

      <div class="executive-grid fade-up delay-1">
        <div class="exec-card problem">
          <div class="exec-icon">❌</div>
          <h3 class="exec-title">Lo que duele hoy</h3>
          <div class="exec-stats">
            <div class="exec-stat">
              <div class="exec-stat-number">Baja</div>
              <div class="exec-stat-label">Una ausencia en el puesto equivocado desordena el turno</div>
            </div>
            <div class="exec-stat">
              <div class="exec-stat-number">Tutor</div>
              <div class="exec-stat-label">Cuando el experto forma, deja de producir</div>
            </div>
          </div>
          <div class="exec-risks">
            <h4>Impacto habitual:</h4>
            <ul>
              <li>Procesos críticos que viven en la cabeza de una persona</li>
              <li>Incorporaciones lentas y dependientes del tutor</li>
              <li>Más improvisación cuando hay rotación o absentismo</li>
              <li>Dificultad para crecer sin sumar complejidad</li>
              <li>Poca visibilidad de qué proceso está realmente cubierto</li>
            </ul>
          </div>
        </div>

        <div class="exec-card solution">
          <div class="exec-icon">✅</div>
          <h3 class="exec-title">Lo que aporta REELEVO</h3>
          <div class="exec-stats">
            <div class="exec-stat">
              <div class="exec-stat-number">49€</div>
              <div class="exec-stat-label">Desde 49 €/mes por empresa</div>
            </div>
            <div class="exec-stat">
              <div class="exec-stat-number">Ligero</div>
              <div class="exec-stat-label">Arranque técnico y operativo</div>
            </div>
          </div>
          <div class="exec-benefits">
            <h4>Valor para gerencia:</h4>
            <ul>
              <li>Menos dependencia en puestos críticos</li>
              <li>Más visibilidad sobre lo que pasa en planta</li>
              <li>Menos dependencia de personas clave</li>
              <li>Onboarding más ordenado y repetible</li>
              <li>Precio fijo y visible desde el principio</li>
              <li>Implantación ligera para una pyme industrial</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="executive-conclusion fade-up delay-2">
        <h3>💼 Lectura rápida</h3>
        <p>
          <strong>REELEVO encaja cuando quieres reducir riesgo operativo</strong>
          sin entrar en un proyecto caro, largo o difícil de justificar.
        </p>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- STATS BANDA -->
  <section class="stat-band">
    <div class="stat-band-inner fade-up">
      <div class="stat-item">
        <div class="stat-num">49€</div>
        <div class="stat-label">Desde 49 €/mes por empresa</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">Ligero</div>
        <div class="stat-label">Arranque técnico y operativo</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">Fijo</div>
        <div class="stat-label">Mismo precio aunque crezca la plantilla</div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- IMPACTO EMPRESARIAL -->
  <section class="section">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Dónde se nota</div>
        <h2 class="section-title">Tres impactos que sí importan a gerencia</h2>
        <p class="section-sub">
          Mensajes simples para valorar si tiene sentido mover esto ahora
          o seguir conviviendo con la improvisación.
        </p>
      </div>

      <div class="risk-matrix fade-up delay-1">
        <div class="risk-card high-risk">
          <div class="risk-level">Continuidad</div>
          <h3 class="risk-title">Menos dependencia de una sola persona</h3>
          <div class="risk-impact">
            <strong>Sin ordenar esto:</strong>
            <ul>
              <li>Una baja o un cambio de puesto tensiona más de la cuenta el turno</li>
              <li>El conocimiento sigue viviendo en conversaciones y costumbres</li>
              <li>La empresa depende demasiado de perfiles concretos</li>
            </ul>
          </div>
      <div class="risk-mitigation">
            <strong>Con REELEVO:</strong>
            <ul>
              <li>✅ Proceso documentado y accesible en el puesto</li>
              <li>✅ Guía de incidencias ligada al trabajo real</li>
              <li>✅ Transferencia de conocimiento más ordenada</li>
            </ul>
          </div>
          <div class="risk-probability">Resultado: <strong>menos fragilidad operativa</strong></div>
        </div>

        <div class="risk-card medium-risk">
          <div class="risk-level">Onboarding</div>
          <h3 class="risk-title">Incorporaciones menos dependientes del tutor</h3>
          <div class="risk-impact">
            <strong>Sin ordenar esto:</strong>
            <ul>
              <li>El experto sigue perdiendo tiempo explicando lo mismo</li>
              <li>Cada incorporación depende demasiado de quién enseña</li>
              <li>Cuesta repetir un estándar de forma consistente</li>
            </ul>
          </div>
          <div class="risk-mitigation">
            <strong>Con REELEVO:</strong>
            <ul>
              <li>✅ El proceso se enseña igual en cada incorporación</li>
              <li>✅ Se reduce la necesidad de tutoría continua</li>
              <li>✅ La formación se apoya más en el sistema y menos en la memoria</li>
            </ul>
          </div>
          <div class="risk-probability">Resultado: <strong>menos tiempo improductivo de los expertos</strong></div>
        </div>

        <div class="risk-card low-risk">
          <div class="risk-level">Escala</div>
          <h3 class="risk-title">Crecimiento sin añadir más complejidad</h3>
          <div class="risk-impact">
            <strong>Sin ordenar esto:</strong>
            <ul>
              <li>Cada nueva incorporación multiplica el esfuerzo interno</li>
              <li>El coste de coordinar personas y procesos crece rápido</li>
              <li>La decisión se retrasa porque parece un proyecto grande</li>
            </ul>
          </div>
          <div class="risk-mitigation">
            <strong>Con REELEVO:</strong>
            <ul>
              <li>✅ Precio fijo por empresa</li>
              <li>✅ Empezar por pocos procesos críticos y ampliar después</li>
              <li>✅ Una implantación asumible para una pyme industrial</li>
            </ul>
          </div>
          <div class="risk-probability">Resultado: <strong>más orden sin complicar la decisión</strong></div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ESCALABILIDAD — Simplificado, sin gráfico -->
  <section class="section section-center">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Modelo de precio</div>
        <h2 class="section-title">Precio fijo. <em>Sin sorpresas.</em></h2>
        <p class="section-sub">
          REELEVO tiene precio por empresa, no por usuario.
          Eso hace más fácil aprobarlo y más sencillo ampliarlo.
        </p>
      </div>

      <div class="benefits-grid fade-up delay-1">
        <div class="benefit-card">
          <div class="benefit-card-icon">💡</div>
          <h3 class="benefit-card-title">Presupuesto claro</h3>
          <p class="benefit-card-desc">Sabes lo que cuesta desde el principio, sin negociación larga ni licencias por cada alta.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-card-icon">📈</div>
          <h3 class="benefit-card-title">Escala sin castigo</h3>
          <p class="benefit-card-desc">Si mañana incorporas más operarios, el coste no se dispara con la plantilla.</p>
        </div>
        <div class="benefit-card">
          <div class="benefit-card-icon">🎯</div>
          <h3 class="benefit-card-title">Proyecto asumible</h3>
          <p class="benefit-card-desc">Empiezas por procesos críticos y amplías cuando te compense, sin sobredimensionar la decisión.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!--
  ═══════════════════════════════════════════
  CASO CEO — COMENTADO
  Descomentar cuando tengamos casos reales documentados.
  ═══════════════════════════════════════════
  -->

  <div class="divider"></div>

  <!-- DECISIÓN -->
  <section class="section section-center">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Cuándo encaja</div>
        <h2 class="section-title">Tiene sentido si este problema ya se nota</h2>
        <p class="section-sub">
          No hace falta convertirlo en un proyecto estratégico enorme.
          Tiene sentido cuando el coste de improvisar ya se nota en el día a día y quieres empezar por algo concreto.
        </p>
      </div>

      <div class="decision-matrix fade-up delay-1">
        <div class="decision-recommendation">
          <h3>✅ Señales claras</h3>
          <div class="recommendation-content">
            <p>
              <strong>REELEVO tiene sentido cuando quieres empezar por algo concreto y útil, no por una transformación gigantesca.</strong>
            </p>
            <div class="recommendation-reasons">
              <div class="reason">
                <strong>Se nota una baja:</strong> hay puestos donde faltar una persona desordena la operación
              </div>
              <div class="reason">
                <strong>Se repite la tutoría:</strong> los expertos siguen dedicando demasiado tiempo a enseñar
              </div>
              <div class="reason">
                <strong>Quieres ordenar procesos críticos:</strong> sin depender de un proyecto IT largo
              </div>
              <div class="reason">
                <strong>Buscas claridad comercial:</strong> precio visible y una implantación asumible
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-eyebrow fade-up">Para decisores</div>
    <h2 class="cta-title fade-up delay-1">
      Reduce el riesgo operativo <em>de forma sostenida</em>
    </h2>
    <p class="cta-sub fade-up delay-2">
      Si quieres entrar en la plataforma, regístrate en REELEVO y valora si tiene sentido en tu planta.
      Empezamos por los procesos críticos y aterrizamos el impacto con tu realidad.
    </p>
    <div class="fade-up delay-3" style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
      <a href="https://app.gmvsolutions.es/registro" class="btn-primary">
        Registrarme en REELEVO →
      </a>
      <a href="/precios/" class="btn-ghost">
        Ver precios
      </a>
    </div>
      <div class="cta-note fade-up delay-4">
      Precio publicado · Implantación ligera · Acceso guiado para validar encaje
      </div>
    </section>
</BaseLayout>

<style>
  .proof-grid {
    display: grid;
    grid-template-columns: 1.05fr .95fr;
    gap: 24px;
    margin-top: 48px;
  }

  .proof-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
  }

  .proof-frame img {
    width: 100%;
    display: block;
  }

  .proof-caption {
    padding: 16px 18px;
    font-size: .8rem;
    color: var(--gray);
    line-height: 1.55;
  }

  .proof-points {
    padding: 28px 24px;
  }

  .proof-points h3 {
    font-family: 'Oswald', sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 18px;
  }

  .proof-point {
    font-size: .88rem;
    line-height: 1.65;
    color: var(--gray);
    padding: 0 0 14px;
    margin-bottom: 14px;
    border-bottom: 1px solid var(--border);
  }

  .proof-point:last-child {
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: none;
  }

  .proof-point strong {
    color: var(--white);
  }

  /* Executive grid */
  .executive-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    margin-top: 48px;
  }

  .exec-card {
    background: var(--surface);
    padding: 32px 28px;
    position: relative;
  }

  .exec-card.problem::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: #FF4444;
  }

  .exec-card.solution::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--green);
  }

  .exec-icon {
    font-size: 3rem;
    margin-bottom: 20px;
    text-align: center;
  }

  .exec-title {
    font-family: 'Oswald', sans-serif;
    font-size: 1.4rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .03em;
    margin-bottom: 24px;
    text-align: center;
  }

  .exec-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 24px;
  }

  .exec-stat {
    background: var(--surface2);
    padding: 16px;
    border-radius: 2px;
    text-align: center;
  }

  .exec-stat-number {
    font-family: 'Oswald', sans-serif;
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--orange);
    line-height: 1;
    margin-bottom: 6px;
  }

  .exec-stat-label {
    font-size: .7rem;
    color: var(--gray);
    line-height: 1.3;
  }

  .exec-risks h4,
  .exec-benefits h4 {
    font-family: 'DM Mono', monospace;
    font-size: .65rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 8px;
  }

  .exec-risks ul,
  .exec-benefits ul {
    list-style: none;
    font-size: .85rem;
    line-height: 1.6;
  }

  .exec-risks li {
    color: var(--gray);
    margin-bottom: 4px;
  }

  .exec-risks li::before {
    content: '−';
    color: var(--gray2);
    margin-right: 8px;
  }

  .exec-benefits li {
    color: rgba(255, 255, 255, .8);
    margin-bottom: 4px;
  }

  .exec-benefits li::before {
    content: '✓';
    color: var(--green);
    margin-right: 8px;
    font-weight: 600;
  }

  .executive-conclusion {
    background: var(--surface);
    padding: 28px;
    border-radius: 4px;
    text-align: center;
    margin-top: 32px;
  }

  .executive-conclusion h3 {
    font-family: 'Oswald', sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 12px;
    color: var(--orange);
  }

  .executive-conclusion p {
    font-size: .95rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, .9);
  }

  .executive-conclusion strong {
    color: var(--white);
    font-weight: 500;
  }

  /* Financial analysis */
  .financial-analysis {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 32px;
    margin-top: 48px;
  }

  .cost-breakdown h3 {
    font-family: 'Oswald', sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 20px;
    color: var(--orange);
  }

  .cost-table-exec {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: 2px;
    background: var(--border);
    margin-bottom: 16px;
  }

  .cost-header {
    display: contents;
  }

  .cost-header > div {
    background: var(--surface2);
    padding: 12px 8px;
    font-family: 'Oswald', sans-serif;
    font-size: .8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .03em;
    text-align: center;
  }

  .cost-row {
    display: contents;
  }

  .cost-row > div {
    background: var(--surface);
    padding: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .8rem;
    text-align: center;
  }

  .cost-item {
    justify-content: flex-start !important;
    text-align: left !important;
    font-weight: 500;
  }

  .cost-reelevo {
    background: rgba(244, 82, 30, 0.06);
    border: 1px solid rgba(244, 82, 30, 0.15);
    font-weight: 500;
  }

  .cost-row.total > div {
    font-weight: 600;
    background: var(--surface2);
  }

  .cost-row.total .cost-reelevo {
    background: rgba(244, 82, 30, 0.1);
  }

  .cost-footnote {
    font-size: .75rem;
    color: var(--gray2);
    line-height: 1.5;
  }

  .roi-comparison h3 {
    font-family: 'Oswald', sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 20px;
    color: var(--orange);
  }

  .roi-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .roi-card {
    background: var(--surface2);
    padding: 20px;
    border-radius: 4px;
    text-align: center;
  }

  .roi-card.winner {
    border: 2px solid var(--green);
    background: rgba(34, 197, 94, 0.06);
  }

  .roi-card.expensive {
    border: 2px solid #FF4444;
    background: rgba(255, 68, 68, 0.06);
  }

  .roi-card.moderate {
    border: 2px solid #FF8800;
    background: rgba(255, 136, 0, 0.06);
  }

  .roi-solution {
    font-family: 'Oswald', sans-serif;
    font-size: .9rem;
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .roi-investment,
  .roi-savings {
    font-size: .75rem;
    color: var(--gray);
    margin-bottom: 4px;
  }

  .roi-percentage {
    font-family: 'Oswald', sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 4px;
  }

  .roi-card.winner .roi-percentage {
    color: var(--green);
  }

  .roi-card.expensive .roi-percentage {
    color: #FF4444;
  }

  .roi-card.moderate .roi-percentage {
    color: #FF8800;
  }

  .roi-payback {
    font-size: .8rem;
    color: var(--gray);
  }

  /* Risk matrix */
  .risk-matrix {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-top: 48px;
  }

  .risk-card {
    background: var(--surface);
    padding: 28px 24px;
    position: relative;
  }

  .risk-card.high-risk::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: #FF4444;
  }

  .risk-card.medium-risk::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
