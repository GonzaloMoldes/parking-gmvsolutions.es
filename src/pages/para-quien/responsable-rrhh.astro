---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "REELEVO — Onboarding software con gestión de competencias | Software RRHH industrial";
const description = "REELEVO es un onboarding software con gestión de competencias para RRHH. Ordena incorporaciones, deja evidencia de ejecución y visualiza competencias operativas en pymes industriales.";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "REELEVO para Responsables de RRHH",
  "description": "Solución específica para responsables de recursos humanos",
  "audience": {
    "@type": "Audience",
    "audienceType": "HR Manager"
  }
};
---

<BaseLayout
  title={title}
  description={description}
  schema={schema}
  activeNav=""
>
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="eyebrow fade-up">Onboarding software para RRHH | Gestión de competencias</div>
    <h1 class="fade-up delay-1">Onboarding software industrial<br><em>con gestión de competencias real.</em></h1>
    <p class="fade-up delay-2">REELEVO es un onboarding software que ordena incorporaciones en planta, reduce tutoría repetitiva y visualiza competencias por operario. Gestión de competencias basada en ejecución, no solo asistencia a formación.</p>
    <div class="hero-cta-group fade-up delay-3">
      <a href="https://app.gmvsolutions.es/registro" class="btn-primary">Registrarme en REELEVO →</a>
      <a href="https://diagnostico.gmvsolutions.es" class="btn-ghost">Evaluar mi situación</a>
    </div>
    <div class="hero-cta-note fade-up delay-4">Sin compromiso · Implementación asistida</div>
  </section>

  <div class="divider"></div>

  <!-- PRUEBA VISUAL -->
  <section class="section">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Prueba visual</div>
        <h2 class="section-title">Qué deja registrado el producto <em>hoy</em></h2>
        <p class="section-sub">
          REELEVO no sustituye una certificación formal. Sí deja una base de evidencia mucho más útil
          que una lista de asistencia cuando quieres ordenar onboarding y tomar mejores decisiones de formación.
        </p>
      </div>

      <div class="proof-grid fade-up delay-1">
        <div class="proof-card proof-shot">
          <div class="proof-frame">
            <img src="/screenshots/admin-dashboard.png" alt="Panel empresa REELEVO para seguimiento operativo y procesos" loading="lazy">
          </div>
          <div class="proof-caption">Captura real del producto: panel empresa para procesos, máquinas y operativa.</div>
        </div>

        <div class="proof-card proof-points">
          <h3>Qué evidencia te deja</h3>
          <div class="proof-point"><strong>Quién:</strong> operario o sesión identificada cuando aplica.</div>
          <div class="proof-point"><strong>Qué:</strong> proceso ejecutado y puesto o máquina asociada.</div>
          <div class="proof-point"><strong>Cuándo:</strong> fecha, hora y seguimiento de ejecución.</div>
          <div class="proof-point"><strong>Resultado:</strong> base más útil para onboarding, polivalencia y competencia visible.</div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- PROBLEMAS DE RRHH -->
  <section class="section">
    <div class="section-inner">
      <div class="fade-up" style="text-align:center;margin-bottom:64px;">
        <div class="eyebrow">Problemas de RRHH</div>
        <h2 class="section-title">Los costes ocultos de la formación tradicional</h2>
        <p class="section-sub">
          Problemas diarios que enfrentan los departamentos de RRHH
          en empresas industriales con alta rotación.
        </p>
      </div>

      <div class="hr-problems fade-up delay-1">
        <div class="problem-card high-impact">
          <div class="problem-icon">💰</div>
          <h3 class="problem-title">Onboarding costoso sin gestión de competencias</h3>
          <div class="problem-stats">
            <div class="problem-stat">Tutoría</div>
            <div class="problem-stat-label">Onboarding repetitivo sin seguimiento de competencias</div>
          </div>
          <div class="problem-description">
            <h4>Situación actual:</h4>
            <ul>
              <li>Tu onboarding depende de tutores disponibles</li>
              <li>Sin gestión de competencias clara: no sabes quién domina qué</li>
              <li>Inconsistencias en onboarding según quién enseña</li>
              <li>Registro de competencias incompleto o inexistente</li>
              <li>Repetir onboarding si el empleado cambia de puesto</li>
            </ul>
          </div>
          <div class="problem-solution">
            <h4>Con REELEVO:</h4>
            <ul>
              <li>Onboarding software con pasos guiados en planta</li>
              <li>Gestión de competencias por ejecución real</li>
              <li>Onboarding consistente entre diferentes incorporaciones</li>
              <li>Evidencia clara de competencias adquiridas</li>
              <li>Gestión de competencias escalable por puestos</li>
            </ul>
          </div>
        </div>

        <div class="problem-card medium-impact">
          <div class="problem-icon">📋</div>
          <h3 class="problem-title">Gestión de competencias invisible</h3>
          <div class="problem-stats">
            <div class="problem-stat">Excel</div>
            <div class="problem-stat-label">Gestión de competencias en papel, hojas y memoria</div>
          </div>
          <div class="problem-description">
            <h4>Situación actual:</h4>
            <ul>
              <li>No hay gestión de competencias clara por operario</li>
              <li>Certificaciones basadas en asistencia, no en competencia real</li>
              <li>Cuesta demostrar qué ejecución realmente tiene cada persona</li>
              <li>Datos de competencias dispersos en Excel, papel, memoria</li>
              <li>Imposible hacer seguimiento actualizado de competencias</li>
            </ul>
          </div>
          <div class="problem-solution">
            <h4>Con REELEVO:</h4>
            <ul>
              <li>Gestión de competencias basada en ejecución real</li>
              <li>Evidencia operativa clara de competencias por persona</li>
              <li>Más claridad para auditorías y cumplimiento</li>
              <li>Integración posible con software de RRHH según el caso</li>
              <li>Gestión de competencias actualizada automáticamente</li>
            </ul>
          </div>
        </div>

        <div class="problem-card high-impact">
          <div class="problem-icon">🔄</div>
          <h3 class="problem-title">Rotación y personal temporal</h3>
          <div class="problem-stats">
            <div class="problem-stat">ETT</div>
            <div class="problem-stat-label">Cada incorporación vuelve a tensionar el sistema</div>
          </div>
          <div class="problem-description">
            <h4>Situación actual:</h4>
            <ul>
              <li>Cada ETT necesita formación desde cero</li>
              <li>Inversión en formación que «se va» con la persona</li>
              <li>Imposible rentabilizar formación con alta rotación</li>
              <li>Dependencia excesiva de personal fijo para formar</li>
              <li>Sin escalabilidad para picos de demanda</li>
            </ul>
          </div>
          <div class="problem-solution">
            <h4>Con REELEVO:</h4>
            <ul>
              <li>Más facilidad para incorporar ETT con menos tutoría</li>
              <li>Formación más reutilizable y menos improvisada</li>
              <li>Mejor aprovechamiento del conocimiento interno</li>
              <li>Menor dependencia del personal fijo para enseñar siempre lo mismo</li>
              <li>Más capacidad para absorber picos estacionales</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CERTIFICACIÓN SISTEMA -->
  <section class="section">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Trazabilidad operativa</div>
        <h2 class="section-title">Registro verificable de <em>ejecución real</em></h2>
        <p class="section-sub">
          No sustituye una certificación formal de competencias. Aporta evidencia
          operativa más cercana al trabajo real que una simple asistencia a formación.
        </p>
      </div>

      <div class="certification-comparison fade-up delay-1">
        <div class="cert-traditional">
          <h3>❌ Registro tradicional</h3>
          <div class="cert-process">
            <div class="cert-step">
              <div class="cert-step-icon">📚</div>
              <div class="cert-step-text">Asistencia a curso teórico</div>
            </div>
            <div class="cert-arrow">→</div>
            <div class="cert-step">
              <div class="cert-step-icon">📝</div>
              <div class="cert-step-text">Test teórico</div>
            </div>
            <div class="cert-arrow">→</div>
            <div class="cert-step">
              <div class="cert-step-icon">✅</div>
              <div class="cert-step-text">Firma o validación manual</div>
            </div>
          </div>
          <div class="cert-problems">
            <h4>Problemas:</h4>
            <ul>
              <li>No garantiza competencia práctica real</li>
              <li>Basada en memorización, no en ejecución</li>
              <li>Sin conexión con el puesto real de trabajo</li>
              <li>No refleja la capacidad operativa</li>
              <li>Válida en el momento, no actualizable</li>
            </ul>
          </div>
        </div>

        <div class="cert-reelevo">
          <h3>✅ Registro REELEVO</h3>
          <div class="cert-process">
            <div class="cert-step">
              <div class="cert-step-icon">📱</div>
              <div class="cert-step-text">Acceso a instrucciones reales</div>
            </div>
            <div class="cert-arrow">→</div>
            <div class="cert-step">
              <div class="cert-step-icon">⚙️</div>
              <div class="cert-step-text">Ejecución en máquina real</div>
            </div>
            <div class="cert-arrow">→</div>
            <div class="cert-step">
              <div class="cert-step-icon">📊</div>
              <div class="cert-step-text">Registro por ejecución</div>
            </div>
          </div>
          <div class="cert-benefits">
            <h4>Ventajas:</h4>
            <ul>
              <li>Aporta evidencia operativa más cercana a la competencia práctica</li>
              <li>Basada en ejecución real, no en teoría</li>
              <li>Conectada directamente con el puesto</li>
              <li>Refleja mejor la capacidad operativa real</li>
              <li>Actualizable automáticamente</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="certification-data fade-up delay-2">
        <div class="cert-data-card">
          <h4>📊 Lo que registra REELEVO automáticamente:</h4>
          <div class="cert-data-grid">
            <div class="cert-data-item">
              <strong>Quién:</strong> Identificación del operario
            </div>
            <div class="cert-data-item">
              <strong>Qué:</strong> Proceso específico ejecutado
            </div>
            <div class="cert-data-item">
              <strong>Cuándo:</strong> Fecha y hora de ejecución
            </div>
            <div class="cert-data-item">
              <strong>Dónde:</strong> Máquina/puesto de trabajo
            </div>
            <div class="cert-data-item">
              <strong>Cómo:</strong> Pasos completados correctamente
            </div>
            <div class="cert-data-item">
              <strong>Resultado:</strong> Éxito/problema/tiempo empleado
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- INTEGRACIÓN CON SISTEMAS HR -->
  <section class="section">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Encaje e integraciones</div>
        <h2 class="section-title">Encaje con software de RRHH</h2>
        <p class="section-sub">
          REELEVO puede convivir con vuestro software de RRHH. Si necesitáis exportación
          o integración, el alcance se revisa caso a caso. Hablamos de entornos ya implantados
          en la empresa, no de una integración estándar cerrada para todos los clientes.
        </p>
      </div>

      <div class="integration-grid fade-up delay-1">
        <div class="integration-card featured">
          <div class="integration-logo">🔗</div>
          <h3 class="integration-name">Software de RRHH</h3>
          <div class="integration-status">A revisar según el caso</div>
          <div class="integration-features">
            <h4>Qué significa:</h4>
            <ul>
              <li>REELEVO puede encajar en tu flujo de RRHH</li>
              <li>La activación se revisa según vuestra operativa</li>
              <li>El alcance se define durante la implantación</li>
              <li>Se comunica de forma realista desde el inicio</li>
            </ul>
          </div>
        </div>

        <div class="integration-card featured">
          <div class="integration-logo">📊</div>
          <h3 class="integration-name">Sistema actual de RRHH</h3>
          <div class="integration-status">Entorno evaluable</div>
          <div class="integration-features">
            <h4>Ejemplo de integración:</h4>
            <ul>
              <li>Puede formar parte de vuestro flujo si ya trabajáis con una herramienta consolidada</li>
              <li>El alcance real se valida antes de activarlo</li>
              <li>Se adapta al caso de uso de onboarding y seguimiento interno</li>
              <li>Se revisa junto con vuestro equipo durante la implantación</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="integration-demo fade-up delay-2">
        <h3>🔄 Cómo encaja en tu proceso</h3>
        <div class="integration-flow">
          <div class="flow-step">
            <div class="flow-number">1</div>
            <div class="flow-content">
              <h4>Operario ejecuta proceso</h4>
              <p>Completa el procedimiento siguiendo REELEVO</p>
            </div>
          </div>
          <div class="flow-arrow">→</div>
          <div class="flow-step">
            <div class="flow-number">2</div>
            <div class="flow-content">
              <h4>REELEVO registra evidencias</h4>
              <p>La plataforma deja una base útil de evidencia sobre la ejecución realizada</p>
            </div>
          </div>
          <div class="flow-arrow">→</div>
          <div class="flow-step">
            <div class="flow-number">3</div>
            <div class="flow-content">
              <h4>Integración si aplica</h4>
              <p>El flujo con tu software de RRHH se revisa y configura según el caso</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- STATS BANDA -->
  <section class="stat-band">
    <div class="stat-band-inner fade-up">
      <div class="stat-item">
        <div class="stat-num">Onboarding</div>
        <div class="stat-label">Más orden en nuevas incorporaciones y menos dependencia del tutor</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">Trazabilidad</div>
        <div class="stat-label">Registro de ejecución para acompañar onboarding y auditorías</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">Competencias</div>
        <div class="stat-label">Más visibilidad sobre qué procesos domina cada persona</div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!--
  ═══════════════════════════════════════════
  CASO DE ÉXITO — COMENTADO
  Descomentar cuando tengamos casos reales documentados.
  ═══════════════════════════════════════════
  -->

  <div class="divider"></div>

  <!-- PLAN DE IMPLEMENTACIÓN -->
  <section class="section">
    <div class="section-inner">
      <div class="fade-up" style="text-align:center;margin-bottom:48px;">
        <div class="eyebrow">Plan de implementación</div>
        <h2 class="section-title">Implementación asistida para RRHH</h2>
        <p class="section-sub">
          Plan específico para departamentos de recursos humanos.
          Incluye revisión del encaje con tu software de RRHH y formación del equipo.
        </p>
      </div>

      <div class="implementation-plan fade-up delay-1">
        <div class="plan-phase">
          <div class="phase-header">
            <div class="phase-number">1</div>
            <h3>Semana 1: Análisis y configuración</h3>
          </div>
          <div class="phase-content">
            <div class="phase-tasks">
              <h4>Tareas REELEVO:</h4>
              <ul>
                <li>Análisis de puestos críticos y competencias requeridas</li>
                <li>Configuración de perfiles de usuario (operario/supervisor/RRHH)</li>
                <li>Revisión del encaje con vuestro software de RRHH</li>
                <li>Configuración de reporting automático</li>
              </ul>
            </div>
            <div class="phase-hr">
              <h4>Tu participación:</h4>
              <ul>
                <li>2h reunión inicial con el equipo de REELEVO</li>
                <li>Compartir el software de RRHH que utilizáis y sus requisitos (si aplica)</li>
                <li>Revisión y aprobación plan de competencias</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="plan-phase">
          <div class="phase-header">
            <div class="phase-number">2</div>
            <h3>Semana 2: Documentación y pruebas</h3>
          </div>
          <div class="phase-content">
            <div class="phase-tasks">
              <h4>Tareas REELEVO:</h4>
              <ul>
                <li>Captura de procesos con operarios expertos</li>
                <li>Configuración del seguimiento de ejecución</li>
                <li>Validación del flujo con software de RRHH, si aplica</li>
                <li>Verificación de flujo completo de datos</li>
              </ul>
            </div>
            <div class="phase-hr">
              <h4>Tu participación:</h4>
              <ul>
                <li>Coordinación con jefe de producción para captura de procesos</li>
                <li>Revisión de datos de prueba en vuestro sistema</li>
                <li>Validación de certificaciones generadas</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="plan-phase">
          <div class="phase-header">
            <div class="phase-number">3</div>
            <h3>Semana 3: Rollout y formación</h3>
          </div>
          <div class="phase-content">
            <div class="phase-tasks">
              <h4>Tareas REELEVO:</h4>
              <ul>
                <li>Activación del acceso en puestos documentados</li>
                <li>Formación a equipo RRHH en dashboard y reportes</li>
                <li>Primera incorporación asistida con REELEVO</li>
                <li>Configuración alertas y notificaciones</li>
              </ul>
            </div>
            <div class="phase-hr">
              <h4>Tu participación:</h4>
              <ul>
                <li>Asistencia a formación (1h sesión)</li>
                <li>Acompañamiento primera incorporación</li>
                <li>Validación de proceso completo</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="plan-phase ongoing">
          <div class="phase-header">
            <div class="phase-number">∞</div>
            <h3>Soporte continuo</h3>
          </div>
          <div class="phase-content">
            <div class="phase-tasks">
              <h4>Incluido sin coste adicional:</h4>
              <ul>
                <li>Soporte técnico prioritario para RRHH</li>
                <li>Seguimiento de integraciones activas, cuando apliquen</li>
                <li>Informes mensuales de competencias y uso</li>
                <li>Consultoría en optimización de procesos RRHH</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-eyebrow fade-up">Para responsables de RRHH</div>
    <h2 class="cta-title fade-up delay-1">
      Ordena el onboarding y gana<br><em>visibilidad sobre competencias</em>
    </h2>
    <p class="cta-sub fade-up delay-2">
      Si quieres entrar en la plataforma, regístrate en REELEVO y comprueba el impacto real en tus métricas de RRHH.
      Implementación asistida y revisión de integración con tu software de RRHH.
    </p>
    <div class="fade-up delay-3" style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
      <a href="https://app.gmvsolutions.es/registro" class="btn-primary">
        Registrarme en REELEVO →
      </a>
      <a href="https://diagnostico.gmvsolutions.es" class="btn-ghost">
        Evaluar mi situación
      </a>
    </div>
    <div class="cta-note fade-up delay-4">
      Exportaciones e integraciones se revisan caso a caso · Sin promesas cerradas antes de validar encaje
    </div>
  </section>
</BaseLayout>

<style>
  .proof-grid {
    display: grid;
    grid-template-columns: 1.1fr .9fr;
    gap: 24px;
    margin-top: 48px;
  }

  .proof-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
  }

  .proof-frame img {
    width: 100%;
    display: block;
  }

  .proof-caption {
    padding: 16px 18px;
    font-size: .8rem;
    color: var(--gray);
    line-height: 1.55;
  }

  .proof-points {
    padding: 28px 24px;
  }

  .proof-points h3 {
    font-family: 'Oswald', sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 18px;
  }

  .proof-point {
    font-size: .88rem;
    line-height: 1.65;
    color: var(--gray);
    padding: 0 0 14px;
    margin-bottom: 14px;
    border-bottom: 1px solid var(--border);
  }

  .proof-point:last-child {
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: none;
  }

  .proof-point strong {
    color: var(--white);
  }

  /* HR Problems */
  .hr-problems {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-top: 48px;
  }

  .problem-card {
    background: var(--surface);
    padding: 28px 24px;
    position: relative;
  }

  .problem-card.high-impact::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: #FF4444;
  }

  .problem-card.medium-impact::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: #FF8800;
  }

  .problem-icon {
    font-size: 2.5rem;
    margin-bottom: 16px;
  }

  .problem-title {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .03em;
    margin-bottom: 16px;
    line-height: 1.2;
  }

  .problem-stats {
    background: var(--surface2);
    padding: 16px;
    border-radius: 2px;
    text-align: center;
    margin-bottom: 20px;
  }

  .problem-stat {
    font-family: 'Oswald', sans-serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--orange);
    line-height: 1;
    margin-bottom: 4px;
  }

  .problem-stat-label {
    font-size: .7rem;
    color: var(--gray);
    line-height: 1.3;
  }

  .problem-description,
  .problem-solution {
    margin-bottom: 16px;
  }

  .problem-description h4,
  .problem-solution h4 {
    font-family: 'DM Mono', monospace;
    font-size: .65rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

