---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Recursos — Guías de documentación operativa, SOPs y gestión del absentismo industrial";
const description = "Guías prácticas sobre procedimientos operativos estándar (SOP), gestión del absentismo laboral, onboarding de operarios y transferencia de conocimiento en pymes industriales españolas.";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "headline": "Recursos sobre documentación operativa industrial",
  "description": description,
  "author": {
    "@type": "Organization",
    "name": "GMV Solutions"
  }
};
---

<BaseLayout
  title={title}
  description={description}
  schema={schema}
  activeNav="recursos"
>
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="eyebrow fade-up">Centro de conocimiento</div>
    <h1 class="fade-up delay-1">Recursos y <em>guías prácticas</em><br>para tu planta.</h1>
    <p class="fade-up delay-2">Herramientas gratuitas y guías sobre documentación operativa, gestión del absentismo y cómo dejar de depender de una sola persona.</p>
    <div class="hero-cta-group fade-up delay-3">
      <a href="https://diagnostico.gmvsolutions.es" class="btn-primary">Calcular mi riesgo operativo →</a>
    </div>
    <div class="hero-cta-note fade-up delay-4">Evaluación gratuita en 2 minutos</div>
  </section>

  <div class="divider"></div>

  <!-- ARTÍCULOS -->
  <section class="section" id="articulos">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Artículos</div>
        <h2 class="section-title">Últimos artículos publicados</h2>
        <p class="section-sub">
          Análisis y guías sobre documentación operativa, absentismo
          y gestión del conocimiento en pymes industriales españolas.
        </p>
      </div>

      <div class="articles-grid fade-up delay-1">
        <a href="/recursos/que-es-un-sop-industrial/" class="article-card">
          <div class="article-card-category">Procedimientos operativos estándar</div>
          <h3 class="article-card-title">Qué es un SOP industrial y cómo implementarlo en tu planta</h3>
          <p class="article-card-desc">Guía completa sobre procedimientos operativos estándar para pymes industriales. Qué son, por qué importan, cómo crearlos y qué herramientas usar.</p>
          <div class="article-card-meta">
            <span>18 mar. 2026</span>
            <span>·</span>
            <span>⏱️ 12 min.</span>
          </div>
          <div class="article-card-link">Leer artículo →</div>
        </a>

        <a href="/recursos/coste-absentismo-pymes-industriales/" class="article-card">
          <div class="article-card-category">Gestión del absentismo</div>
          <h3 class="article-card-title">Coste real del absentismo en pymes industriales españolas</h3>
          <p class="article-card-desc">Análisis con datos propios del coste directo e indirecto del absentismo laboral. Cuánto cuesta cada baja no cubierta y cómo reducir el impacto.</p>
          <div class="article-card-meta">
            <span>15 mar. 2026</span>
            <span>·</span>
            <span>⏱️ 10 min.</span>
          </div>
          <div class="article-card-link">Leer artículo →</div>
        </a>

        <a href="/recursos/documentar-conocimiento-operarios-expertos/" class="article-card">
          <div class="article-card-category">Transferencia de conocimiento</div>
          <h3 class="article-card-title">Cómo documentar el conocimiento de tus operarios expertos</h3>
          <p class="article-card-desc">Guía práctica para capturar el conocimiento tácito de operarios veteranos antes de que se vayan. Metodología paso a paso con errores comunes.</p>
          <div class="article-card-meta">
            <span>10 mar. 2026</span>
            <span>·</span>
            <span>⏱️ 14 min.</span>
          </div>
          <div class="article-card-link">Leer artículo →</div>
        </a>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- GUÍAS PRÁCTICAS — Próximamente -->
  <section class="section" id="guias">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Guías prácticas</div>
        <h2 class="section-title">Aprende paso a paso</h2>
        <p class="section-sub">
          Guías directas al grano, sin teoría innecesaria.
          Lo que necesitas saber para documentar tu planta.
        </p>
      </div>

      <div class="coming-soon-block fade-up delay-1">
        <div class="coming-soon-icon">📖</div>
        <h3 class="coming-soon-title">Próximamente</h3>
        <p class="coming-soon-desc">
          Estamos preparando guías prácticas sobre documentación operativa,
          onboarding de operarios, gestión del absentismo y transferencia de conocimiento.<br><br>
          Si quieres que te avisemos cuando las publiquemos, déjanos tu email.
        </p>
        <a href="mailto:hola@gmvsolutions.es?subject=Avísame de próximas guías" class="btn-ghost">
          Quiero que me aviséis →
        </a>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- WEBINARS — Próximamente -->
  <section class="section section-center" id="webinars">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Formación</div>
        <h2 class="section-title">Webinars y eventos</h2>
        <p class="section-sub">
          Sesiones formativas online gratuitas sobre documentación operativa
          y gestión del conocimiento industrial.
        </p>
      </div>

      <div class="coming-soon-block fade-up delay-1">
        <div class="coming-soon-icon">🎙️</div>
        <h3 class="coming-soon-title">Próximamente</h3>
        <p class="coming-soon-desc">
          Estamos preparando nuestros primeros webinars sobre documentación operativa,
          gestión del absentismo y onboarding de operarios.<br><br>
          Si quieres que te avisemos cuando publiquemos fechas, déjanos tu email.
        </p>
        <a href="mailto:hola@gmvsolutions.es?subject=Avísame de próximos webinars" class="btn-ghost">
          Quiero que me aviséis →
        </a>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- HERRAMIENTAS — Calculadoras -->
  <section class="section" id="herramientas">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Herramientas gratuitas</div>
        <h2 class="section-title">Calculadoras</h2>
        <p class="section-sub">
          Herramientas online para evaluar tu situación actual
          y ver cuánto te está costando la dependencia operativa.
        </p>
      </div>

      <div class="tools-grid fade-up delay-1">
        <div class="tool-card featured">
          <div class="tool-tag">Más usada</div>
          <div class="tool-icon">📊</div>
          <h3 class="tool-title">Calculadora de riesgo operativo</h3>
          <p class="tool-desc">
            16 preguntas sobre tu planta. Resultado inmediato con tu nivel de riesgo
            y un plan de acción personalizado.
          </p>
          <div class="tool-features">
            <div class="tool-feature">✓ Evaluación en 2 minutos</div>
            <div class="tool-feature">✓ Informe personalizado</div>
            <div class="tool-feature">✓ Benchmark con el sector</div>
            <div class="tool-feature">✓ ROI estimado</div>
          </div>
          <div class="tool-cta">
            <a href="https://diagnostico.gmvsolutions.es" class="btn-primary">Hacer diagnóstico →</a>
          </div>
        </div>

        <div class="tool-card">
          <div class="tool-icon">💰</div>
          <h3 class="tool-title">Calculadora de ROI</h3>
          <p class="tool-desc">
            Calcula cuánto te ahorrarías con REELEVO en función
            del tamaño de tu equipo y tu tasa de absentismo.
          </p>
          <div class="tool-features">
            <div class="tool-feature">✓ Personalizada por datos reales</div>
            <div class="tool-feature">✓ Tiempo de amortización</div>
            <div class="tool-feature">✓ Ahorro anual estimado</div>
          </div>
          <div class="tool-cta">
            <a href="/precios#roi" class="btn-ghost">Calcular ROI →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-eyebrow fade-up">¿Tienes una pregunta?</div>
    <h2 class="cta-title fade-up delay-1">
      Hablemos de tu <em>situación</em>
    </h2>
    <p class="cta-sub fade-up delay-2">
      Cada empresa es diferente. Cuéntanos tu caso
      y te ayudamos a encontrar la mejor solución.
    </p>
    <div class="cta-actions fade-up delay-3">
      <a href="https://diagnostico.gmvsolutions.es" class="btn-primary">
        Evaluar mi situación →
      </a>
      <a href="mailto:hola@gmvsolutions.es" class="btn-ghost">
        Consulta directa
      </a>
    </div>
    <div class="cta-note fade-up delay-4">
      Respuesta en menos de 4 horas · Sin compromiso
    </div>
  </section>

</BaseLayout>

<style>
  /* Tools grid */
  .tools-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 24px;
    margin-top: 48px;
  }

  .tool-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    transition: border-color .25s;
  }

  .tool-card:hover {
    border-color: var(--border-hover);
  }

  .tool-card.featured {
    border-color: var(--orange);
  }

  .tool-tag {
    font-family: 'DM Mono', monospace;
    font-size: .6rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 16px;
  }

  .tool-icon {
    font-size: 2.5rem;
    margin-bottom: 20px;
  }

  .tool-title {
    font-family: 'Oswald', sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .03em;
    margin-bottom: 12px;
  }

  .tool-desc {
    font-size: .9rem;
    color: var(--gray);
    line-height: 1.65;
    margin-bottom: 24px;
  }

  .tool-features {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 28px;
    flex: 1;
  }

  .tool-feature {
    font-size: .82rem;
    color: rgba(255, 255, 255, .75);
    line-height: 1.4;
  }

  .tool-feature .check { color: var(--green); }

  /* Guides grid */
  .guides-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .guide-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 32px 28px;
    transition: border-color .25s;
  }

  .guide-card:hover {
    border-color: var(--border-hover);
  }

  .guide-category {
    font-family: 'DM Mono', monospace;
    font-size: .6rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 12px;
  }

  .guide-title {
    font-family: 'Oswald', sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .02em;
    margin-bottom: 12px;
    line-height: 1.2;
  }

  .guide-desc {
    font-size: .88rem;
    color: var(--gray);
    line-height: 1.65;
    margin-bottom: 16px;
  }

  .guide-meta {
    display: flex;
    gap: 16px;
    margin-bottom: 16px;
  }

  .guide-time, .guide-difficulty {
    font-size: .75rem;
    color: var(--gray2);
  }

  .guide-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .guide-topics span {
    font-family: 'DM Mono', monospace;
    font-size: .65rem;
    color: var(--gray);
    background: var(--surface2);
    padding: 4px 10px;
    border-radius: 3px;
  }

  .guides-cta {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 40px;
    text-align: center;
    margin-top: 32px;
  }

  .guides-cta h3 {
    font-family: 'Oswald', sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .03em;
    margin-bottom: 8px;
  }

  .guides-cta p {
    font-size: .9rem;
    color: var(--gray);
    margin-bottom: 24px;
    line-height: 1.6;
  }

  /* Studies */
  .studies-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 48px;
    text-align: left;
  }

  .study-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 36px 32px;
  }

  .study-type {
    font-family: 'DM Mono', monospace;
    font-size: .6rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 16px;
  }

  .study-title {
    font-family: 'Oswald', sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .02em;
    margin-bottom: 20px;
    line-height: 1.2;
  }

  .study-stats {
    display: flex;
    gap: 24px;
    margin-bottom: 20px;
  }

  .study-stat { text-align: center; }

  .study-stat-number {
    font-family: 'Oswald', sans-serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--orange);
    line-height: 1;
  }

  .study-stat-label {
    font-size: .7rem;
    color: var(--gray);
    margin-top: 4px;
    line-height: 1.3;
  }

  .study-desc {
    font-size: .9rem;
    color: var(--gray);
    line-height: 1.65;
    margin-bottom: 20px;
  }

  .study-highlights h4 {
    font-family: 'DM Mono', monospace;
    font-size: .65rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 8px;
  }

  .study-highlights ul {
    list-style: none;
    font-size: .8rem;
    line-height: 1.6;
  }

  .study-highlights li {
    margin-bottom: 4px;
    color: rgba(255, 255, 255, .8);
  }

  .study-highlights li::before {
    content: '→';
    color: var(--orange);
    margin-right: 8px;
    font-weight: 500;
  }

  .study-highlights strong {
    color: var(--white);
    font-weight: 500;
  }

  /* Coming soon — guías y webinars */
  .coming-soon-block {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 64px 40px;
    text-align: center;
    margin-top: 48px;
  }

  .coming-soon-icon {
    font-size: 3rem;
    margin-bottom: 24px;
  }

  .coming-soon-title {
    font-family: 'Oswald', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .04em;
    color: var(--orange);
    margin-bottom: 16px;
  }

  .coming-soon-desc {
    font-size: .95rem;
    color: var(--gray);
    line-height: 1.7;
    max-width: 500px;
    margin: 0 auto 32px;
  }

  /* Webinars — Próximamente */
  .webinars-coming-soon {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 64px 40px;
    text-align: center;
    margin-top: 48px;
  }

  /* Articles grid */
  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .article-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 32px 28px;
    text-decoration: none;
    color: inherit;
    transition: border-color .25s;
  }

  .article-card:hover {
    border-color: var(--border-hover);
  }

  .article-card-category {
    font-family: 'DM Mono', monospace;
    font-size: .6rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 12px;
  }

  .article-card-title {
    font-family: 'Oswald', sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .02em;
    margin-bottom: 12px;
    line-height: 1.2;
  }

  .article-card-desc {
    font-size: .88rem;
    color: var(--gray);
    line-height: 1.65;
    margin-bottom: 20px;
    flex: 1;
  }

  .article-card-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: .75rem;
    color: var(--gray2);
    margin-bottom: 20px;
  }

  .article-card-link {
    font-family: 'DM Mono', monospace;
    font-size: .7rem;
    letter-spacing: .08em;
    color: var(--orange);
    text-transform: uppercase;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .tools-grid,
    .articles-grid,
    .guides-grid,
    .studies-grid {
      grid-template-columns: 1fr;
    }

    .study-stats {
      justify-content: center;
    }
  }
</style>
