---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Recursos — Guías de documentación operativa, SOPs y gestión del absentismo industrial";
const description = "Guías prácticas sobre procedimientos operativos estándar (SOP), gestión del absentismo laboral, onboarding de operarios y transferencia de conocimiento en pymes industriales españolas.";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "headline": "Recursos sobre documentación operativa industrial",
  "description": description,
  "author": {
    "@type": "Organization",
    "name": "GMV Solutions"
  }
};
---

<BaseLayout
  title={title}
  description={description}
  schema={schema}
  activeNav="recursos"
>
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="eyebrow fade-up">Centro de conocimiento</div>
    <h1 class="fade-up delay-1">Recursos y <em>guías prácticas</em><br>para tu planta.</h1>
    <p class="fade-up delay-2">Herramientas gratuitas y guías sobre documentación operativa, gestión del absentismo y cómo dejar de depender de una sola persona.</p>
    <div class="hero-cta-group fade-up delay-3">
      <a href="https://diagnostico.gmvsolutions.es" class="btn-primary">Calcular mi riesgo operativo →</a>
    </div>
    <div class="hero-cta-note fade-up delay-4">Evaluación gratuita en 2 minutos</div>
  </section>

  <div class="divider"></div>

  <!-- HERRAMIENTAS GRATUITAS -->
  <section class="section">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Herramientas gratuitas</div>
        <h2 class="section-title">Calcula el impacto real</h2>
        <p class="section-sub">
          Herramientas online para evaluar tu situación actual
          y ver cuánto te está costando la dependencia operativa.
        </p>
      </div>

      <div class="tools-grid fade-up delay-1">
        <div class="tool-card featured">
          <div class="tool-tag">Más usada</div>
          <div class="tool-icon">📊</div>
          <h3 class="tool-title">Calculadora de riesgo operativo</h3>
          <p class="tool-desc">
            16 preguntas sobre tu planta. Resultado inmediato con tu nivel de riesgo
            y un plan de acción personalizado.
          </p>
          <div class="tool-features">
            <div class="tool-feature">✓ Evaluación en 2 minutos</div>
            <div class="tool-feature">✓ Informe personalizado</div>
            <div class="tool-feature">✓ Benchmark con el sector</div>
            <div class="tool-feature">✓ ROI estimado</div>
          </div>
          <div class="tool-cta">
            <a href="https://diagnostico.gmvsolutions.es" class="btn-primary">Hacer diagnóstico →</a>
          </div>
        </div>

        <div class="tool-card">
          <div class="tool-icon">💰</div>
          <h3 class="tool-title">Calculadora de ROI</h3>
          <p class="tool-desc">
            Calcula cuánto te ahorrarías con REELEVO en función
            del tamaño de tu equipo y tu tasa de absentismo.
          </p>
          <div class="tool-features">
            <div class="tool-feature">✓ Personalizada por datos reales</div>
            <div class="tool-feature">✓ Tiempo de amortización</div>
            <div class="tool-feature">✓ Ahorro anual estimado</div>
          </div>
          <div class="tool-cta">
            <a href="/precios#roi" class="btn-ghost">Calcular ROI →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- GUÍAS PRÁCTICAS -->
  <section class="section" id="guias">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Guías prácticas</div>
        <h2 class="section-title">Aprende paso a paso</h2>
        <p class="section-sub">
          Guías directas al grano, sin teoría innecesaria.
          Lo que necesitas saber para documentar tu planta.
        </p>
      </div>

      <div class="guides-grid fade-up delay-1">
        <div class="guide-card">
          <div class="guide-category">Documentación operativa</div>
          <h3 class="guide-title">Cómo documentar procesos críticos en 1 hora</h3>
          <p class="guide-desc">
            Metodología práctica para identificar y documentar los procesos
            que más impacto tienen en tu producción.
          </p>
          <div class="guide-meta">
            <span class="guide-time">⏱️ 15 min. lectura</span>
            <span class="guide-difficulty">🟢 Básico</span>
          </div>
          <div class="guide-topics">
            <span>Identificación de procesos críticos</span>
            <span>Técnicas de captura</span>
            <span>Organización por prioridad</span>
          </div>
        </div>

        <div class="guide-card">
          <div class="guide-category">Gestión absentismo</div>
          <h3 class="guide-title">Plan de contingencia para bajas inesperadas</h3>
          <p class="guide-desc">
            Protocolo para minimizar el impacto cuando el operario clave
            no viene a trabajar. Paso a paso.
          </p>
          <div class="guide-meta">
            <span class="guide-time">⏱️ 12 min. lectura</span>
            <span class="guide-difficulty">🟡 Intermedio</span>
          </div>
          <div class="guide-topics">
            <span>Matriz de dependencias</span>
            <span>Plan de sustitutos</span>
            <span>Comunicación de emergencia</span>
          </div>
        </div>

        <div class="guide-card">
          <div class="guide-category">Onboarding operarios</div>
          <h3 class="guide-title">Onboarding de operarios en 3 días sin tutor</h3>
          <p class="guide-desc">
            Sistema para que las nuevas incorporaciones rindan rápido
            sin que nadie deje su puesto para enseñar.
          </p>
          <div class="guide-meta">
            <span class="guide-time">⏱️ 18 min. lectura</span>
            <span class="guide-difficulty">🟡 Intermedio</span>
          </div>
          <div class="guide-topics">
            <span>Plan de 72 horas</span>
            <span>Certificación progresiva</span>
            <span>Métricas de seguimiento</span>
          </div>
        </div>

        <div class="guide-card">
          <div class="guide-category">Personal ETT</div>
          <h3 class="guide-title">Que el personal temporal rinda desde el primer turno</h3>
          <p class="guide-desc">
            Cómo conseguir que el personal ETT opere correctamente
            sin comprometer calidad ni seguridad.
          </p>
          <div class="guide-meta">
            <span class="guide-time">⏱️ 10 min. lectura</span>
            <span class="guide-difficulty">🟢 Básico</span>
          </div>
          <div class="guide-topics">
            <span>Protocolo de acogida</span>
            <span>Supervisión remota</span>
            <span>Evaluación express</span>
          </div>
        </div>

        <div class="guide-card">
          <div class="guide-category">Transferencia conocimiento</div>
          <h3 class="guide-title">Captura el conocimiento antes de que se vaya</h3>
          <p class="guide-desc">
            Cómo extraer y documentar lo que saben tus operarios veteranos
            antes de que se jubilen o cambien de empresa.
          </p>
          <div class="guide-meta">
            <span class="guide-time">⏱️ 20 min. lectura</span>
            <span class="guide-difficulty">🟠 Avanzado</span>
          </div>
          <div class="guide-topics">
            <span>Sesiones de captura</span>
            <span>Técnicas de entrevista</span>
            <span>Validación cruzada</span>
          </div>
        </div>

        <div class="guide-card">
          <div class="guide-category">ROI y métricas</div>
          <h3 class="guide-title">Cómo medir el ROI de la documentación operativa</h3>
          <p class="guide-desc">
            Métricas y metodología para demostrar a dirección que esto
            merece la inversión. Con números, no con opiniones.
          </p>
          <div class="guide-meta">
            <span class="guide-time">⏱️ 16 min. lectura</span>
            <span class="guide-difficulty">🟡 Intermedio</span>
          </div>
          <div class="guide-topics">
            <span>KPIs fundamentales</span>
            <span>Antes vs después</span>
            <span>Presentación a dirección</span>
          </div>
        </div>
      </div>

      <div class="guides-cta fade-up delay-2">
        <h3>¿Necesitas una guía para tu caso concreto?</h3>
        <p>Cuéntanos tu situación y preparamos contenido adaptado a tu sector.</p>
        <a href="mailto:hola@gmvsolutions.es?subject=Solicitud de guía personalizada" class="btn-ghost">Pedir guía personalizada →</a>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ESTUDIOS Y DATOS -->
  <section class="section section-center">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Datos del sector</div>
        <h2 class="section-title">Números que importan</h2>
        <p class="section-sub">
          Datos actualizados sobre absentismo, rotación y costes operativos
          en la industria española.
        </p>
      </div>

      <div class="studies-grid fade-up delay-1">
        <div class="study-card">
          <div class="study-type">Estudio propio</div>
          <h3 class="study-title">Encuesta REELEVO 2025: Dependencia operativa en pymes industriales</h3>
          <div class="study-stats">
            <div class="study-stat">
              <div class="study-stat-number">347</div>
              <div class="study-stat-label">empresas encuestadas</div>
            </div>
            <div class="study-stat">
              <div class="study-stat-number">40%</div>
              <div class="study-stat-label">llaman al experto cuando falta</div>
            </div>
            <div class="study-stat">
              <div class="study-stat-number">7,2%</div>
              <div class="study-stat-label">tasa de absentismo media</div>
            </div>
          </div>
          <p class="study-desc">
            Primer estudio sobre la dependencia de perfiles técnicos clave
            en pymes manufactureras españolas de 10-200 empleados.
          </p>
          <div class="study-highlights">
            <h4>Conclusiones principales:</h4>
            <ul>
              <li>El 87% identifica la dependencia de operarios clave como riesgo alto</li>
              <li>Pérdida media de 3,2 horas por baja no cubierta correctamente</li>
              <li>Solo el 23% tiene procesos documentados y actualizados</li>
            </ul>
          </div>
        </div>

        <div class="study-card">
          <div class="study-type">Análisis sectorial</div>
          <h3 class="study-title">Coste del absentismo en la industria manufacturera española</h3>
          <div class="study-stats">
            <div class="study-stat">
              <div class="study-stat-number">€2.1k</div>
              <div class="study-stat-label">coste por empleado/año</div>
            </div>
            <div class="study-stat">
              <div class="study-stat-number">14%</div>
              <div class="study-stat-label">del tiempo se va en tutorizar</div>
            </div>
          </div>
          <p class="study-desc">
            Análisis del impacto económico real del absentismo laboral
            en diferentes sectores industriales.
          </p>
          <div class="study-highlights">
            <h4>Por sectores:</h4>
            <ul>
              <li><strong>Automoción:</strong> 8,1% tasa absentismo — €2.4k/empleado</li>
              <li><strong>Alimentario:</strong> 6,8% tasa absentismo — €1.9k/empleado</li>
              <li><strong>Metal/mecánica:</strong> 7,5% tasa absentismo — €2.2k/empleado</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!--
  ═══════════════════════════════════════════
  CASOS DE ÉXITO — COMENTADO
  Los casos actuales son inventados. Descomentar
  cuando tengamos casos reales documentados.
  ═══════════════════════════════════════════

  <section class="section">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Casos reales</div>
        <h2 class="section-title">Casos de éxito documentados</h2>
        <p class="section-sub">
          Historias reales de pymes industriales que han resuelto su dependencia operativa.
        </p>
      </div>
      <div class="cases-grid fade-up delay-1">
        — Aquí irán los casos reales cuando los tengamos —
      </div>
    </div>
  </section>

  <div class="divider"></div>
  -->

  <!-- WEBINARS — Próximamente -->
  <section class="section section-center">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Formación</div>
        <h2 class="section-title">Webinars y eventos</h2>
        <p class="section-sub">
          Sesiones formativas online gratuitas sobre documentación operativa
          y gestión del conocimiento industrial.
        </p>
      </div>

      <div class="webinars-coming-soon fade-up delay-1">
        <div class="coming-soon-icon">🎙️</div>
        <h3 class="coming-soon-title">Próximamente</h3>
        <p class="coming-soon-desc">
          Estamos preparando nuestros primeros webinars sobre documentación operativa,
          gestión del absentismo y onboarding de operarios.<br><br>
          Si quieres que te avisemos cuando publiquemos fechas, déjanos tu email.
        </p>
        <a href="mailto:hola@gmvsolutions.es?subject=Avísame de próximos webinars" class="btn-ghost">
          Quiero que me aviséis →
        </a>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-eyebrow fade-up">¿Tienes una pregunta?</div>
    <h2 class="cta-title fade-up delay-1">
      Hablemos de tu <em>situación</em>
    </h2>
    <p class="cta-sub fade-up delay-2">
      Cada empresa es diferente. Cuéntanos tu caso
      y te ayudamos a encontrar la mejor solución.
    </p>
    <div class="cta-actions fade-up delay-3">
      <a href="https://diagnostico.gmvsolutions.es" class="btn-primary">
        Evaluar mi situación →
      </a>
      <a href="mailto:hola@gmvsolutions.es" class="btn-ghost">
        Consulta directa
      </a>
    </div>
    <div class="cta-note fade-up delay-4">
      Respuesta en menos de 4 horas · Sin compromiso
    </div>
  </section>

</BaseLayout>

<style>
  /* Tools grid */
  .tools-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 24px;
    margin-top: 48px;
  }

  .tool-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    transition: border-color .25s;
  }

  .tool-card:hover {
    border-color: var(--border-hover);
  }

  .tool-card.featured {
    border-color: var(--orange);
  }

  .tool-tag {
    font-family: 'DM Mono', monospace;
    font-size: .6rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 16px;
  }

  .tool-icon {
    font-size: 2.5rem;
    margin-bottom: 20px;
  }

  .tool-title {
    font-family: 'Oswald', sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .03em;
    margin-bottom: 12px;
  }

  .tool-desc {
    font-size: .9rem;
    color: var(--gray);
    line-height: 1.65;
    margin-bottom: 24px;
  }

  .tool-features {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 28px;
    flex: 1;
  }

  .tool-feature {
    font-size: .82rem;
    color: rgba(255, 255, 255, .75);
    line-height: 1.4;
  }

  .tool-feature .check { color: var(--green); }

  /* Guides grid */
  .guides-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .guide-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 32px 28px;
    transition: border-color .25s;
  }

  .guide-card:hover {
    border-color: var(--border-hover);
  }

  .guide-category {
    font-family: 'DM Mono', monospace;
    font-size: .6rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 12px;
  }

  .guide-title {
    font-family: 'Oswald', sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .02em;
    margin-bottom: 12px;
    line-height: 1.2;
  }

  .guide-desc {
    font-size: .88rem;
    color: var(--gray);
    line-height: 1.65;
    margin-bottom: 16px;
  }

  .guide-meta {
    display: flex;
    gap: 16px;
    margin-bottom: 16px;
  }

  .guide-time, .guide-difficulty {
    font-size: .75rem;
    color: var(--gray2);
  }

  .guide-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .guide-topics span {
    font-family: 'DM Mono', monospace;
    font-size: .65rem;
    color: var(--gray);
    background: var(--surface2);
    padding: 4px 10px;
    border-radius: 3px;
  }

  .guides-cta {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 40px;
    text-align: center;
    margin-top: 32px;
  }

  .guides-cta h3 {
    font-family: 'Oswald', sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .03em;
    margin-bottom: 8px;
  }

  .guides-cta p {
    font-size: .9rem;
    color: var(--gray);
    margin-bottom: 24px;
    line-height: 1.6;
  }

  /* Studies */
  .studies-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 48px;
    text-align: left;
  }

  .study-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 36px 32px;
  }

  .study-type {
    font-family: 'DM Mono', monospace;
    font-size: .6rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 16px;
  }

  .study-title {
    font-family: 'Oswald', sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .02em;
    margin-bottom: 20px;
    line-height: 1.2;
  }

  .study-stats {
    display: flex;
    gap: 24px;
    margin-bottom: 20px;
  }

  .study-stat { text-align: center; }

  .study-stat-number {
    font-family: 'Oswald', sans-serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--orange);
    line-height: 1;
  }

  .study-stat-label {
    font-size: .7rem;
    color: var(--gray);
    margin-top: 4px;
    line-height: 1.3;
  }

  .study-desc {
    font-size: .9rem;
    color: var(--gray);
    line-height: 1.65;
    margin-bottom: 20px;
  }

  .study-highlights h4 {
    font-family: 'DM Mono', monospace;
    font-size: .65rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 8px;
  }

  .study-highlights ul {
    list-style: none;
    font-size: .8rem;
    line-height: 1.6;
  }

  .study-highlights li {
    margin-bottom: 4px;
    color: rgba(255, 255, 255, .8);
  }

  .study-highlights li::before {
    content: '→';
    color: var(--orange);
    margin-right: 8px;
    font-weight: 500;
  }

  .study-highlights strong {
    color: var(--white);
    font-weight: 500;
  }

  /* Webinars — Próximamente */
  .webinars-coming-soon {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 64px 40px;
    text-align: center;
    margin-top: 48px;
  }

  .coming-soon-icon {
    font-size: 3rem;
    margin-bottom: 24px;
  }

  .coming-soon-title {
    font-family: 'Oswald', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .04em;
    color: var(--orange);
    margin-bottom: 16px;
  }

  .coming-soon-desc {
    font-size: .95rem;
    color: var(--gray);
    line-height: 1.7;
    max-width: 500px;
    margin: 0 auto 32px;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .tools-grid,
    .guides-grid,
    .studies-grid {
      grid-template-columns: 1fr;
    }

    .study-stats {
      justify-content: center;
    }
  }
</style>
