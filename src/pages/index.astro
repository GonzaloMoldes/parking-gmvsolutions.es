---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "REELEVO — Software SOP industrial para pymes | Documenta procesos críticos";
const description = "REELEVO es un software SOP industrial para pymes que documenta procesos críticos, acelera el onboarding y reduce la dependencia de operarios clave.";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "REELEVO",
    "url": "https://gmvsolutions.es"
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": "https://gmvsolutions.es/#organization",
    "name": "GMV Solutions",
    "alternateName": "REELEVO",
    "url": "https://gmvsolutions.es",
    "logo": "https://gmvsolutions.es/logo.svg",
    "description": "REELEVO es un software SOP industrial para pymes que documenta procesos críticos, acelera el onboarding y reduce la dependencia de operarios clave con procesos accesibles en cada máquina.",
    "email": "hola@gmvsolutions.es",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Rua Marola",
      "addressLocality": "A Coruña",
      "postalCode": "15002",
      "addressCountry": "ES"
    },
    "foundingDate": "2025",
    "areaServed": "ES",
    "knowsAbout": [
      "Software SOP industrial",
      "Procedimientos operativos estándar",
      "Documentación operativa",
      "Gestión del conocimiento industrial",
      "Onboarding de operarios",
      "Cobertura de bajas en producción",
      "Personal ETT en fábrica",
      "Pymes industriales españolas"
    ],
    "sameAs": [
      "https://www.linkedin.com/company/gmvsolutions"
    ]
  }
];
---

<BaseLayout title={title} description={description} schema={schema} activeNav="">

  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="hero-eyebrow fade-up">Software SOP · Procedimientos operativos estándar para la industria</div>
    <h1 class="hero-title fade-up delay-1">
      Documenta procesos críticos<br>
      y reduce la dependencia<br>
      <em>de operarios clave</em>.
    </h1>
    <p class="hero-sub fade-up delay-2">
      REELEVO es un software SOP industrial para pymes que documenta procesos críticos, acelera el onboarding y reduce la dependencia de operarios clave.<br>
      <strong>Convierte el conocimiento del experto en procesos accesibles en cada máquina</strong> para cubrir bajas, ordenar incorporaciones y trabajar con más continuidad operativa.
    </p>
    <div class="hero-actions fade-up delay-3">
      <a href="https://app.gmvsolutions.es/registro" class="btn-primary">Solicitar demo</a>
      <a href="https://diagnostico.gmvsolutions.es" class="btn-ghost">Evaluar mi situación →</a>
    </div>
    <div class="hero-proof fade-up delay-4">
      <div class="hero-proof-item">
        <div class="hero-proof-num">49€</div>
        <div class="hero-proof-label">desde al mes por empresa</div>
      </div>
      <div class="hero-proof-item">
        <div class="hero-proof-num">1 día</div>
        <div class="hero-proof-label">configuración técnica inicial</div>
      </div>
      <div class="hero-proof-item">
        <div class="hero-proof-num">Fijo</div>
        <div class="hero-proof-label">precio por empresa, no por operario</div>
      </div>
    </div>
  </section>


    <div class="divider"></div>

    <!-- ═══ EL PROBLEMA ═══ -->
    <section class="section" id="casos">
      <div class="section-inner">
        <div class="casos-header fade-up">
          <div class="eyebrow">El día a día</div>
          <h2 class="section-title">¿Te suena esto?</h2>
          <p class="section-sub">
            Son las dos situaciones que más se repiten en cualquier planta, taller o fábrica.
            Y las que más dinero cuestan sin que nadie las mida.
          </p>
        </div>

        <div class="casos fade-up delay-1">
          <div class="caso">
            <div class="caso-tag">El experto no ha venido</div>
            <h3 class="caso-title">
              «Javi está de baja.<br>
              ¿Quién arranca<br>
              la llenadora?»
            </h3>
            <p class="caso-desc">
              Es martes a las 6:30. Javi lleva 15 años en esa máquina y hoy está en urgencias.
              Su sustituto no domina el proceso. La línea no arranca hasta que alguien
              encuentre la solución o hasta que Javi coja el teléfono.
            </p>
            <ul class="caso-benefits">
              <li>2-4 horas de línea parada buscando quién sabe</li>
              <li>Presión sobre el resto del equipo para cubrir</li>
              <li>Errores por improvisar sin instrucciones claras</li>
              <li>Llamadas al experto durante su baja para salir del paso</li>
              <li>Pedidos retrasados y clientes que no esperan</li>
            </ul>
          </div>

          <div class="caso">
            <div class="caso-tag">Incorporación nueva</div>
            <h3 class="caso-title">
              «Es su primer día.<br>
              Alguien tiene que<br>
              enseñarle.»
            </h3>
            <p class="caso-desc">
              Llega alguien nuevo — fijo, personal de ETT, lo que sea — y necesita aprender el puesto.
              Uno de tus mejores operarios deja su máquina para hacer de tutor durante días.
              Dos personas ocupadas, un solo puesto produciendo.
            </p>
            <ul class="caso-benefits">
              <li>Tu mejor operario pierde tiempo productivo enseñando</li>
              <li>Dos personas para un solo puesto durante días</li>
              <li>El aprendizaje depende de quién enseña y cómo</li>
              <li>Mayor riesgo de errores mientras dura la formación</li>
              <li>En campañas o picos, el problema se multiplica con cada ETT nuevo</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- ═══ DATOS ═══ -->
    <section class="section section-center">
      <div class="section-inner">
        <div class="fade-up">
          <div class="eyebrow">Lo que dicen los números</div>
          <h2 class="section-title">El coste que nadie mide</h2>
          <p class="section-sub">
            Son datos del sector industrial español. La mayoría de pymes industriales y talleres
            asumen esto como "normal". No lo es.
          </p>
        </div>

        <div class="dolor-grid fade-up delay-1">
          <div class="dolor-item">
            <div class="dolor-num">7,2<sup>%</sup></div>
            <div class="dolor-label">
              <strong>Tasa de absentismo</strong> media en pymes industriales.
              1 de cada 14 trabajadores falta cada día.
            </div>
          </div>
          <div class="dolor-item">
            <div class="dolor-num">3-5</div>
            <div class="dolor-label">
              <strong>Días de aprendizaje</strong> hasta que una incorporación nueva
              rinde como el operario titular.
            </div>
          </div>
          <div class="dolor-item">
            <div class="dolor-num">40<sup>%</sup></div>
            <div class="dolor-label">
              <strong>De jefes de planta</strong> llaman directamente al experto
              cuando alguien falta. Aunque esté de baja.
            </div>
          </div>
        </div>

        <div class="dolor-cta fade-up delay-2">
          <a href="https://diagnostico.gmvsolutions.es" class="btn-primary">
            Evaluar mi situación →
          </a>
          <div class="dolor-cta-note">
            Calculadora gratuita · Resultado en 2 minutos
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- ═══ CÓMO FUNCIONA ═══ -->
    <section class="section section-center">
      <div class="section-inner">
        <div class="fade-up">
          <div class="eyebrow">Software SOP industrial</div>
          <h2 class="section-title">Procedimientos operativos estándar <em>que funcionan</em></h2>
          <p class="section-sub">
            Así funciona REELEVO en planta: el experto captura lo que sabe,
            la documentación queda accesible en cada máquina y el operario encuentra el proceso correcto cuando lo necesita.
          </p>
        </div>

        <div class="steps-grid fade-up delay-1">
          <div class="step-card">
            <div class="step-card-icon">🧠</div>
            <h3 class="step-card-title">1. Captura el conocimiento</h3>
            <p class="step-card-desc">
              El operario experto documenta cada paso del proceso
              con sus propias palabras. En minutos, no en semanas.
            </p>
          </div>
          <div class="step-card">
            <div class="step-card-icon">📲</div>
            <h3 class="step-card-title">2. SOPs en cada máquina</h3>
            <p class="step-card-desc">
              Los procedimientos quedan accesibles directamente en cada puesto.
              Actualizados y listos para consulta en el momento de trabajar.
            </p>
          </div>
          <div class="step-card">
            <div class="step-card-icon">⚡</div>
            <h3 class="step-card-title">3. El operario accede en el puesto</h3>
            <p class="step-card-desc">
              El sustituto escanea el código QR en la máquina
              y sigue las instrucciones paso a paso. Sin cuentas de operario ni apps que instalar.
            </p>
          </div>
        </div>

        <div class="steps-cta fade-up delay-2">
          <a href="/como-funciona/" class="btn-ghost">Ver el flujo completo →</a>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- ═══ PRODUCTO EN ACCIÓN ═══ -->
    <section class="section section-center" id="producto">
      <div class="section-inner">
        <div class="fade-up">
          <div class="eyebrow">El producto</div>
          <h2 class="section-title">Esto es lo que <em>verás en tu planta</em></h2>
          <p class="section-sub">
            Así se ve REELEVO en planta: panel para el responsable,
            instrucciones para el operario y trazabilidad completa de la ejecución.
          </p>
        </div>

        <div class="screenshots-wrap fade-up delay-1">
          <div class="screenshots-track" id="screenshotsTrack">
            <div class="screenshot-slide">
              <div class="screenshot-frame">
                <img src="/screenshots/admin-dashboard.png" alt="Panel de administración REELEVO — gestión de procesos y máquinas" loading="lazy">
              </div>
              <div class="screenshot-caption">Panel de administración — gestión de procesos, máquinas y actividad de la planta</div>
            </div>
            <div class="screenshot-slide">
              <div class="screenshot-frame">
                <img src="/screenshots/sop-operario.png" alt="Vista operario REELEVO — instrucciones paso a paso" loading="lazy">
              </div>
              <div class="screenshot-caption">Vista del operario — instrucciones paso a paso, sin cuenta, desde cualquier dispositivo</div>
            </div>
            <div class="screenshot-slide">
              <div class="screenshot-frame">
                <img src="/screenshots/monitor-actividad.png" alt="Monitor de actividad REELEVO" loading="lazy">
              </div>
              <div class="screenshot-caption">Monitor de actividad — seguimiento en tiempo real de operaciones por máquina</div>
            </div>
          </div>
          <button class="carousel-btn carousel-prev" id="carPrev" aria-label="Anterior">←</button>
          <button class="carousel-btn carousel-next" id="carNext" aria-label="Siguiente">→</button>
          <div class="carousel-dots" id="carDots">
            <button class="carousel-dot is-active" aria-label="Pantalla 1"></button>
            <button class="carousel-dot" aria-label="Pantalla 2"></button>
            <button class="carousel-dot" aria-label="Pantalla 3"></button>
          </div>
        </div>

        <div class="screenshots-cta fade-up delay-2">
          <a href="https://app.gmvsolutions.es/registro" class="btn-ghost">Ver demo en directo →</a>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- ═══ PARA QUIÉN ═══ -->
    <section class="section" id="perfiles">
      <div class="section-inner">
        <div class="perfiles-header fade-up">
          <div class="eyebrow">¿Para quién es esto?</div>
          <h2 class="section-title">Cada persona ve un valor distinto</h2>
          <p class="section-sub">
            REELEVO encaja con prioridades distintas dentro de la planta.
            Producción gana cobertura y visibilidad, RRHH gana onboarding y gerencia gana continuidad operativa.
          </p>
        </div>

        <div class="perfiles-grid fade-up delay-1">
          <div class="perfil-card">
            <div class="perfil-card-icon">👷</div>
            <h3 class="perfil-card-title">Jefe de producción</h3>
            <p class="perfil-card-desc">
              Tu línea no puede depender de una sola persona.
              Con REELEVO, producción gana cobertura, visibilidad y procesos listos en el puesto.
            </p>
            <a href="/para-quien/jefe-de-produccion/" class="perfil-card-link">Ver cómo te ayuda →</a>
          </div>

          <div class="perfil-card">
            <div class="perfil-card-icon">👥</div>
            <h3 class="perfil-card-title">Responsable RRHH</h3>
            <p class="perfil-card-desc">
              Onboarding estandarizado que no depende de quién enseña.
              Certificación por ejecución real, no por horas de formación.
            </p>
            <a href="/para-quien/responsable-rrhh/" class="perfil-card-link">Ver cómo te ayuda →</a>
          </div>

          <div class="perfil-card">
            <div class="perfil-card-icon">💼</div>
            <h3 class="perfil-card-title">Gerente / Propietario</h3>
            <p class="perfil-card-desc">
              Menos dependencia operativa, precio fijo por empresa y una implantación ligera.
              Un proyecto asumible para ordenar procesos críticos sin complicar la decisión.
            </p>
            <a href="/para-quien/gerente-propietario/" class="perfil-card-link">Ver cómo te ayuda →</a>
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- ═══ BENEFICIOS ═══ -->
    <section class="section section-center" id="beneficios">
      <div class="section-inner">
        <div class="fade-up">
          <div class="eyebrow">Beneficios del software SOP</div>
          <h2 class="section-title">Impacto operativo desde el arranque</h2>
          <p class="section-sub">
            No hace falta convertirlo en un proyecto pesado. Puedes empezar por procesos críticos
            y tenerlos accesibles en planta desde las primeras semanas.
          </p>
        </div>

        <div class="benefits-grid fade-up delay-1">
          <div class="benefit-card">
            <div class="benefit-card-icon">⚡</div>
            <h3 class="benefit-card-title">Acceso sin fricción</h3>
            <p class="benefit-card-desc">
              El operario encuentra el proceso cuando lo necesita.
              Menos esperas, menos dependencia del tutor, menos improvisación.
            </p>
          </div>

          <div class="benefit-card">
            <div class="benefit-card-icon">📱</div>
            <h3 class="benefit-card-title">Sin usuarios ni apps</h3>
            <p class="benefit-card-desc">
              Acceso por código QR en cada máquina o enlace directo. Sin cuentas que crear,
              sin apps que instalar. Arranca sin necesitar a IT.
            </p>
          </div>

          <div class="benefit-card">
            <div class="benefit-card-icon">💰</div>
            <h3 class="benefit-card-title">Precio fijo</h3>
            <p class="benefit-card-desc">
              Desde 49€/mes por empresa. Da igual que sean
              5 operarios o 500. Sin costes ocultos.
            </p>
          </div>

          <div class="benefit-card">
            <div class="benefit-card-icon">📊</div>
            <h3 class="benefit-card-title">Sabes qué pasa</h3>
            <p class="benefit-card-desc">
              Quién opera qué máquina, cuándo y con qué resultado.
              Datos reales, no intuiciones.
            </p>
          </div>

          <div class="benefit-card">
            <div class="benefit-card-icon">✅</div>
            <h3 class="benefit-card-title">Registro verificable</h3>
            <p class="benefit-card-desc">
              REELEVO registra quién ejecutó qué proceso y cuándo.
              Trazabilidad real, no presencia en una formación.
            </p>
          </div>

          <div class="benefit-card">
            <div class="benefit-card-icon">🔧</div>
            <h3 class="benefit-card-title">Incidencias guiadas</h3>
            <p class="benefit-card-desc">
              Guía de incidencias paso a paso integrada.
              Si no basta, aviso automático al supervisor por WhatsApp.
            </p>
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- ═══ PRUEBA SOCIAL ═══ -->
    <section class="section section-center" id="piloto">
      <div class="section-inner">
        <div class="fade-up">
          <div class="eyebrow">Primeros pasos</div>
          <h2 class="section-title">Primeras implantaciones <em>en marcha</em></h2>
          <p class="section-sub">
            REELEVO está trabajando con las primeras implantaciones en plantas industriales españolas.
            Si quieres valorar encaje para tu caso, hablamos.
          </p>
        </div>

        <div class="pilot-block fade-up delay-1">
          <div class="pilot-card">
            <div class="pilot-card-top">
              <div class="pilot-icon">🏭</div>
              <div>
                <div class="pilot-label">Piloto activo · Q1 2026</div>
                <div class="pilot-title">Empresa de producción industrial · Galicia</div>
              </div>
            </div>
            <p class="pilot-desc">Documentando los procesos críticos de primera línea de producción. Objetivo: cobertura de bajas en operaciones clave sin depender del operario titular.</p>
          </div>
          <div class="pilot-note">
            <p>Ofrecemos implementación asistida uno a uno. <a href="mailto:hola@gmvsolutions.es">Escríbenos</a> si quieres hablar de tu situación.</p>
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- ═══ CTA FINAL ═══ -->
    <section class="cta-section">
      <div class="cta-eyebrow fade-up">¿Te interesa?</div>
      <h2 class="cta-title fade-up delay-1">
        Empieza por los procesos críticos<br><em>de tu planta</em>
      </h2>
      <p class="cta-sub fade-up delay-2">
        Solicita una demo para ver cómo REELEVO encaja en tu operativa,
        o evalúa tu situación para priorizar por dónde empezar.
      </p>
      <div class="cta-actions fade-up delay-3">
        <a href="https://app.gmvsolutions.es/registro" class="btn-primary">
          Solicitar demo
        </a>
        <a href="https://diagnostico.gmvsolutions.es" class="btn-ghost">
          Evaluar mi situación →
        </a>
      </div>
      <div class="cta-note fade-up delay-4">
        Precio publicado · Implementación asistida
      </div>
    </section>


</BaseLayout>

<style>
  .casos-header,
  .perfiles-header {
    text-align: center;
    margin-bottom: 48px;
  }
  .casos-header .eyebrow,
  .perfiles-header .eyebrow {
    justify-content: center;
  }
  .casos-header .eyebrow::after,
  .perfiles-header .eyebrow::after {
    content: '';
    width: 28px;
    height: 1px;
    background: var(--orange);
  }
  .casos-header .section-sub,
  .perfiles-header .section-sub {
    margin: 0 auto;
  }

  .dolor-cta {
    text-align: center;
    margin-top: 48px;
  }
  .dolor-cta-note {
    font-family: 'DM Mono', monospace;
    font-size: .6rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--gray2);
    margin-top: 16px;
  }

  .steps-cta {
    text-align: center;
    margin-top: 48px;
  }

  /* Screenshots carousel */
  .screenshots-wrap {
    position: relative;
    margin: 48px 0 0;
    overflow: hidden;
  }

  .screenshots-track {
    display: flex;
    transition: transform .4s ease;
    will-change: transform;
  }

  .screenshot-slide {
    flex-shrink: 0;
    /* width set by JS to match wrapper exactly */
  }

  .screenshot-frame {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }

  .screenshot-frame img {
    width: 100%;
    height: auto;
    display: block;
  }

  .screenshot-caption {
    font-size: .82rem;
    color: var(--gray);
    text-align: center;
    margin-top: 16px;
    line-height: 1.5;
  }

  .carousel-btn {
    position: absolute;
    top: 40%;
    transform: translateY(-50%);
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--white);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background .2s, border-color .2s;
    z-index: 2;
  }

  .carousel-btn:hover {
    background: var(--surface);
    border-color: var(--border-hover);
  }

  .carousel-prev { left: 8px; }
  .carousel-next { right: 8px; }

  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
  }

  .carousel-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--border);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background .2s;
  }

  .carousel-dot.is-active {
    background: var(--orange);
  }

  .screenshots-cta {
    margin-top: 32px;
    text-align: center;
  }

  /* Pilot section */
  .pilot-block {
    max-width: 680px;
    margin: 48px auto 0;
    text-align: left;
  }

  .pilot-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 32px;
    margin-bottom: 20px;
  }

  .pilot-card-top {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 16px;
  }

  .pilot-icon {
    font-size: 2rem;
    flex-shrink: 0;
  }

  .pilot-label {
    font-family: 'DM Mono', monospace;
    font-size: .6rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 4px;
  }

  .pilot-title {
    font-size: .95rem;
    font-weight: 500;
    color: var(--white);
  }

  .pilot-desc {
    font-size: .88rem;
    color: var(--gray);
    line-height: 1.65;
  }

  .pilot-note {
    font-size: .85rem;
    color: var(--gray);
    line-height: 1.6;
    text-align: center;
  }

  .pilot-note a {
    color: var(--orange);
    text-decoration: none;
  }

  .pilot-note a:hover {
    text-decoration: underline;
  }
</style>

<script>
  // Screenshots carousel
  (function () {
    const track = document.getElementById('screenshotsTrack') as HTMLElement | null;
    const wrap = track?.parentElement as HTMLElement | null;
    const slides = document.querySelectorAll<HTMLElement>('.screenshot-slide');
    const dots = document.querySelectorAll<HTMLButtonElement>('.carousel-dot');
    let current = 0;
    const total = slides.length;
    const AUTOPLAY_MS = 10000;
    let timer: ReturnType<typeof setInterval>;
    let resizeTimer: ReturnType<typeof setTimeout>;

    function getWidth() {
      return wrap?.offsetWidth ?? 0;
    }

    function applyWidths() {
      const w = getWidth();
      slides.forEach(s => { s.style.width = w + 'px'; });
      return w;
    }

    function goTo(n: number) {
      current = ((n % total) + total) % total;
      const w = applyWidths();
      if (track) track.style.transform = `translateX(-${current * w}px)`;
      dots.forEach((d, i) => d.classList.toggle('is-active', i === current));
    }

    function startAutoplay() {
      timer = setInterval(() => goTo(current + 1), AUTOPLAY_MS);
    }

    function resetAutoplay() {
      clearInterval(timer);
      startAutoplay();
    }

    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => goTo(current), 100);
    });

    document.getElementById('carPrev')?.addEventListener('click', () => { goTo(current - 1); resetAutoplay(); });
    document.getElementById('carNext')?.addEventListener('click', () => { goTo(current + 1); resetAutoplay(); });
    dots.forEach((d, i) => d.addEventListener('click', () => { goTo(i); resetAutoplay(); }));

    goTo(0);
    startAutoplay();
  })();
</script>
