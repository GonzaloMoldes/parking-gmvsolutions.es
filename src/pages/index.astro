---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "REELEVO — Onboarding software para pymes industriales | Gestión de competencias en planta";
const description = "REELEVO es una plataforma de recursos humanos con onboarding software industrial. Ordena incorporaciones, gestiona competencias, mejora documentación de procesos y reduce dependencia de operarios clave en planta.";
const canonical = "https://www.gmvsolutions.es/";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "REELEVO",
    "url": "https://www.gmvsolutions.es"
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": "https://www.gmvsolutions.es/#organization",
    "name": "GMV Solutions",
    "alternateName": "REELEVO",
    "url": "https://www.gmvsolutions.es",
    "logo": "https://www.gmvsolutions.es/favicon.svg",
    "description": "REELEVO ayuda a las pymes industriales a reducir la dependencia de personas clave, ordenar incorporaciones y ganar más visibilidad sobre lo que pasa en planta.",
    "email": "hola@gmvsolutions.es",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Rua Marola",
      "addressLocality": "A Coruña",
      "postalCode": "15002",
      "addressCountry": "ES"
    },
    "foundingDate": "2025",
    "areaServed": "ES",
    "knowsAbout": [
      "Software SOP industrial",
      "Procedimientos operativos estándar",
      "Documentación operativa",
      "Continuidad operativa en planta",
      "Visibilidad operativa industrial",
      "Reducción de dependencia operativa",
      "Aprendizaje operativo en planta",
      "Onboarding de operarios",
      "Cobertura de bajas en producción",
      "Personal ETT en fábrica",
      "Pymes industriales españolas"
    ],
    "sameAs": [
      "https://www.linkedin.com/company/gmvsolutions"
    ]
  }
];
---

<!-- GLOSSARY: operario, baja, onboarding, competencias, dependencia, tutor, incorporación, continuidad -->
<!-- CONTEXT: marketing, operational -->
<!-- EN_TERMS: [machine operator, absence, onboarding, skills, key person risk, mentor, operator onboarding, continuity] -->
<!-- PT_TERMS: [operador, falta, integração, competências, risco de pessoal-chave, mentor, integração de operadores, continuidade] -->

<BaseLayout title={title} description={description} canonical={canonical} schema={schema} activeNav="">

  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="hero-eyebrow fade-up">Onboarding software industrial · Software de recursos humanos · menos improvisación</div>
    <h1 class="hero-title fade-up delay-1">
      Onboarding software para pymes industriales<br>
      con gestión de competencias<br>
      <em>en planta</em>.
    </h1>
    <p class="hero-sub fade-up delay-2">
      REELEVO es un onboarding software diseñado para pymes industriales. Ordena incorporaciones, gestiona competencias operativas, reduce dependencia de operarios clave y mejora documentación de procesos.<br>
      <strong>Producción gana contexto para decidir, RRHH ordena mejor el onboarding, la empresa visualiza qué competencias tiene cada equipo y se refuerza la documentación en planta</strong>.
    </p>
    <div class="hero-actions fade-up delay-3">
      <a href="https://app.gmvsolutions.es/registro" class="btn-primary">Registrarme en REELEVO</a>
      <a href="https://diagnostico.gmvsolutions.es" class="btn-ghost">Evaluar mi situación →</a>
    </div>
    <div class="hero-proof fade-up delay-4">
      <div class="hero-proof-item">
        <div class="hero-proof-num">Continuidad</div>
        <div class="hero-proof-label">menos dependencia cuando falta el titular</div>
      </div>
      <div class="hero-proof-item">
        <div class="hero-proof-num">Visibilidad</div>
        <div class="hero-proof-label">más claridad sobre lo que pasa en planta</div>
      </div>
      <div class="hero-proof-item">
        <div class="hero-proof-num">49€</div>
        <div class="hero-proof-label">desde al mes por empresa</div>
      </div>
    </div>
  </section>


    <div class="divider"></div>

    <!-- ═══ EL PROBLEMA ═══ -->
    <section class="section" id="casos">
      <div class="section-inner">
        <div class="casos-header fade-up">
          <div class="eyebrow">El día a día</div>
          <h2 class="section-title">¿Te suena esto?</h2>
          <p class="section-sub">
            Son dos momentos donde más se nota si el proceso vive en la planta
            o sigue viviendo solo en la cabeza de alguien.
          </p>
        </div>

        <div class="casos fade-up delay-1">
          <div class="caso">
            <div class="caso-tag">El experto no ha venido</div>
            <h3 class="caso-title">
              «Javi está de baja.<br>
              ¿Quién arranca<br>
              la llenadora?»
            </h3>
            <p class="caso-desc">
              Es martes a las 6:30. Javi lleva 15 años en esa máquina y hoy está en urgencias.
              Su sustituto no domina el proceso. La línea no arranca hasta que alguien
              encuentre la solución o hasta que Javi coja el teléfono.
            </p>
            <ul class="caso-benefits">
              <li>2-4 horas de línea parada buscando quién sabe</li>
              <li>Presión sobre el resto del equipo para cubrir</li>
              <li>Errores por improvisar sin instrucciones claras</li>
              <li>Llamadas al experto durante su baja para salir del paso</li>
              <li>Pedidos retrasados y clientes que no esperan</li>
            </ul>
          </div>

          <div class="caso">
            <div class="caso-tag">Incorporación nueva</div>
            <h3 class="caso-title">
              «Es su primer día.<br>
              Alguien tiene que<br>
              enseñarle.»
            </h3>
            <p class="caso-desc">
              Llega alguien nuevo — fijo, personal de ETT, lo que sea — y necesita aprender el puesto.
              Uno de tus mejores operarios deja su máquina para hacer de tutor durante días.
              Dos personas ocupadas, un solo puesto produciendo.
            </p>
            <ul class="caso-benefits">
              <li>Tu mejor operario pierde tiempo productivo enseñando</li>
              <li>Dos personas para un solo puesto durante días</li>
              <li>El aprendizaje depende de quién enseña y cómo</li>
              <li>Mayor riesgo de errores mientras dura la formación</li>
              <li>En campañas o picos, el problema se multiplica con cada ETT nuevo</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- ═══ DATOS ═══ -->
    <section class="section section-center">
      <div class="section-inner">
        <div class="fade-up">
          <div class="eyebrow">Lo que dicen los números</div>
          <h2 class="section-title">El coste que nadie mide</h2>
          <p class="section-sub">
            Son datos del sector industrial español. La mayoría de pymes industriales y talleres
            asumen esto como "normal". No lo es.
          </p>
        </div>

        <div class="dolor-grid fade-up delay-1">
          <div class="dolor-item">
            <div class="dolor-num">7,2<sup>%</sup></div>
            <div class="dolor-label">
              <strong>Tasa de absentismo</strong> media en pymes industriales.
              1 de cada 14 trabajadores falta cada día.
            </div>
          </div>
          <div class="dolor-item">
            <div class="dolor-num">3-5</div>
            <div class="dolor-label">
              <strong>Días de aprendizaje</strong> hasta que una incorporación nueva
              rinde como el operario titular.
            </div>
          </div>
          <div class="dolor-item">
            <div class="dolor-num">40<sup>%</sup></div>
            <div class="dolor-label">
              <strong>De jefes de planta</strong> llaman directamente al experto
              cuando alguien falta. Aunque esté de baja.
            </div>
          </div>
        </div>

        <div class="dolor-cta fade-up delay-2">
          <a href="https://diagnostico.gmvsolutions.es" class="btn-primary">
            Evaluar mi situación →
          </a>
          <div class="dolor-cta-note">
            Calculadora gratuita · Resultado en 2 minutos
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- ═══ 4 PILARES ═══ -->
    <section class="section section-center">
      <div class="section-inner">
        <div class="fade-up">
          <div class="eyebrow">El valor real del producto</div>
          <h2 class="section-title">Cuatro beneficios que sí se notan <em>en planta</em></h2>
          <p class="section-sub">
            REELEVO no se queda en documentar procesos. Ayuda a que el trabajo salga con menos
            improvisación, más claridad y una transferencia de conocimiento mucho más útil.
          </p>
        </div>

        <div class="steps-grid steps-grid-four fade-up delay-1">
          <div class="step-card">
            <div class="step-card-icon">📲</div>
            <h3 class="step-card-title">1. Onboarding ordenado desde el primer día</h3>
            <p class="step-card-desc">
              El nuevo operario encuentra instrucciones claras en el puesto. Tu onboarding software reduce tutoría repetitiva y acelera la incorporación con menos dependencia del experto.
            </p>
          </div>
          <div class="step-card">
            <div class="step-card-icon">🧾</div>
            <h3 class="step-card-title">2. Más claridad para decidir mejor</h3>
            <p class="step-card-desc">
              Producción gana contexto sobre lo que se está haciendo y dónde se atasca el turno,
              sin depender solo de llamadas, partes o memoria.
            </p>
          </div>
          <div class="step-card">
            <div class="step-card-icon">📊</div>
            <h3 class="step-card-title">3. Gestión de competencias y onboarding</h3>
            <p class="step-card-desc">
              Visualiza competencias por operario y proceso. El onboarding gana consistencia y dejas de depender de memoria. Cada incorporación queda documentada.
            </p>
          </div>
          <div class="step-card">
            <div class="step-card-icon">✅</div>
            <h3 class="step-card-title">4. Onboarding industrial con trazabilidad</h3>
            <p class="step-card-desc">
              Lo que ocurre en planta deja evidencia de ejecución. Mejor datos para onboarding, reducción de dependencia de operarios clave y operación más ordenada.
            </p>
          </div>
        </div>

        <div class="steps-cta fade-up delay-2">
          <a href="/como-funciona/" class="btn-ghost">Ver el flujo completo →</a>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <!-- ═══ PRODUCTO EN ACCIÓN ═══ -->
    <section class="section section-center" id="producto">
      <div class="section-inner">
        <div class="fade-up">
          <div class="eyebrow">El producto</div>
          <h2 class="section-title">Esto es lo que <em>verás en tu planta</em></h2>
