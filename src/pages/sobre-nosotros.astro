---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Sobre GMV Solutions — El equipo detrás de REELEVO";
const description = "Conoce al equipo de GMV Solutions, la empresa detrás de REELEVO. Experiencia en industria, valores y compromiso con las pymes industriales españolas.";

const aboutPageSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "Sobre GMV Solutions",
  "description": description,
  "url": "https://www.gmvsolutions.es/sobre-nosotros/",
  "publisher": {
    "@type": "Organization",
    "name": "GMV Solutions",
    "url": "https://www.gmvsolutions.es"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Dónde se almacenan mis datos?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Los datos operativos del producto se alojan principalmente en infraestructura dentro de la Unión Europea. Algunos servicios auxiliares del sitio web pueden implicar proveedores internacionales, siempre bajo las garantías contractuales adecuadas."
      }
    },
    {
      "@type": "Question",
      "name": "¿Puedo exportar todos mis procesos documentados?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Desde el panel de administración se pueden exportar procesos, pasos e instrucciones en CSV y Excel, y los datos siguen siendo propiedad de la empresa."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué pasa si REELEVO deja de operar?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "En caso de cierre del servicio, se avisaría con un mínimo de 90 días y se facilitaría la exportación completa de todos los datos y procesos."
      }
    },
    {
      "@type": "Question",
      "name": "¿Durante cuánto tiempo se guardan los registros de actividad?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Los registros de actividad se conservan mientras la empresa esté suscrita y durante 12 meses adicionales tras la baja, con posibilidad de exportar el histórico."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué queda registrado realmente?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "REELEVO puede dejar una base útil sobre el proceso seguido, el puesto o máquina, la fecha y hora, la versión visible y el resultado del flujo. Cuando la empresa necesita más seguimiento, puede asociar el flujo a un identificador interno."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué diferencia hay entre consulta rápida y seguimiento asociado?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La consulta rápida prioriza que alguien encuentre el proceso y desbloquee el puesto con la mínima fricción. El seguimiento asociado añade un identificador interno cuando la empresa necesita acompañar onboarding, calidad, auditorías o seguimiento interno."
      }
    },
    {
      "@type": "Question",
      "name": "¿Necesitamos IT para arrancar?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Para las funciones básicas no hace falta IT. Solo puede ser necesaria una apertura de dominio si la red corporativa tiene restricciones de firewall o proxy."
      }
    }
  ]
};

const schema = [aboutPageSchema, faqSchema];
---

<!-- GLOSSARY: operario, baja, onboarding, competencias, tutor, incorporación, SOP, continuidad -->
<!-- CONTEXT: operational, marketing, product -->
<!-- EN_TERMS: [machine operator, absence, onboarding, skills, mentor, operator onboarding, standard operating procedure, continuity] -->
<!-- PT_TERMS: [operador, falta, integração, competências, mentor, integração de operadores, procedimento operativo padrão, continuidade] -->

<BaseLayout
  title={title}
  description={description}
  schema={schema}
  activeNav="nosotros"
>
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="eyebrow fade-up">El equipo</div>
    <h1 class="fade-up delay-1">Detrás de REELEVO<br><em>hay personas, no una corporación.</em></h1>
    <p class="fade-up delay-2">Somos un equipo pequeño, cercano y con foco muy concreto: ayudar a pymes industriales españolas a reducir dependencia operativa sin meterlas en un proyecto pesado ni venderles una suite inflada.</p>
  </section>

  <div class="divider"></div>

  <!-- QUIÉNES SOMOS -->
  <section class="section" id="quienes">
    <div class="section-inner">
      <div class="about-grid fade-up">
        <div class="about-text">
          <div class="eyebrow">Nuestra historia</div>
          <h2 class="section-title">Por qué construimos REELEVO</h2>
          <p>
            Trabajando con empresas industriales españolas, vimos repetidamente el mismo problema:
            plantas que funcionaban bien mientras el operario de siempre estaba presente,
            y que se frenaban en seco cuando faltaba.
          </p>
          <p>
            El conocimiento que hacía funcionar la planta vivía en la cabeza de unas pocas personas.
            No en documentos, no en sistemas. En personas. Y eso es un riesgo enorme que nadie medía.
          </p>
          <p>
            Las soluciones existentes eran para Fortune 500: caras, lentas de implementar, y diseñadas
            para empresas con departamento de IT y seis meses de proyecto. No para la pyme de 40 personas
            en Pontevedra que necesita solucionar esto la semana que viene.
          </p>
          <p>
            Por eso construimos REELEVO: una herramienta diseñada específicamente para pymes industriales
            españolas. Simple, honesta en precio y pensada para ponerse en marcha rápido.
          </p>
        </div>
        <div class="about-values">
          <div class="value-card">
            <div class="value-icon">🎯</div>
            <h3 class="value-title">Problema real, solución real</h3>
            <p class="value-desc">No construimos funcionalidades porque queden bien en una demo. Construimos lo que resuelve el problema en planta, el lunes por la mañana.</p>
          </div>
          <div class="value-card">
            <div class="value-icon">🤝</div>
            <h3 class="value-title">Cercanía sin letra pequeña</h3>
            <p class="value-desc">Precio publicado, sin sorpresas. Funcionalidades que existen, no prometidas. Si algo no está construido, lo decimos.</p>
          </div>
          <div class="value-card">
            <div class="value-icon">🏭</div>
            <h3 class="value-title">Hecho para la industria española</h3>
            <p class="value-desc">No somos una startup americana adaptada al español. Entendemos la realidad de la pyme industrial española: sus recursos, sus tiempos y su cultura.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- TESIS DE COMPAÑÍA -->
  <section class="section section-center" id="tesis">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Tesis de compañía</div>
        <h2 class="section-title">Por qué creemos que podemos<br><em>ganar en este nicho</em></h2>
        <p class="section-sub">
          No intentamos ser un software para todo tipo de fábrica.
          Queremos resolver muy bien un problema concreto de la pyme industrial: continuidad operativa, onboarding y claridad en planta.
        </p>
      </div>

      <div class="authority-grid fade-up delay-1">
        <article class="authority-card">
          <h3 class="authority-title">Foco estrecho</h3>
          <p class="authority-desc">Nos centramos en pymes industriales españolas, no en despliegues genéricos para cualquier corporación o cualquier mercado.</p>
        </article>
        <article class="authority-card">
          <h3 class="authority-title">Producto antes que discurso</h3>
          <p class="authority-desc">Preferimos enseñar una capacidad real y sus límites antes que vender un roadmap ambicioso que ventas tenga que corregir después.</p>
        </article>
        <article class="authority-card">
          <h3 class="authority-title">Implantación asumible</h3>
          <p class="authority-desc">La apuesta es empezar por pocos puestos o procesos críticos, demostrar encaje rápido y ampliar solo cuando el valor ya es visible.</p>
        </article>
        <article class="authority-card">
          <h3 class="authority-title">Relación directa</h3>
          <p class="authority-desc">Quien habla contigo entiende el producto y el problema. Eso recorta ruido, acelera decisiones y evita capas innecesarias.</p>
        </article>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- SEGURIDAD Y DATOS -->
  <section class="section section-center" id="seguridad">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Seguridad y datos</div>
        <h2 class="section-title">Tu conocimiento operativo <em>está protegido</em></h2>
        <p class="section-sub">
          Sabemos que vas a confiar en REELEVO el conocimiento crítico de tu empresa.
          Aquí te explicamos cómo lo protegemos.
        </p>
      </div>

      <div class="security-grid fade-up delay-1">
        <div class="security-card">
          <div class="security-icon">🔒</div>
          <h3 class="security-title">Almacenamiento seguro</h3>
          <p class="security-desc">Los datos se almacenan en infraestructura cloud gestionada (UE), con cifrado en reposo y en tránsito. Aislamiento completo entre empresas mediante Row-Level Security.</p>
        </div>
        <div class="security-card">
          <div class="security-icon">💾</div>
          <h3 class="security-title">Continuidad y recuperación</h3>
          <p class="security-desc">La infraestructura gestionada incorpora mecanismos de copia y recuperación. Si tu caso requiere más detalle, te explicamos el alcance real antes de contratar.</p>
        </div>
        <div class="security-card">
          <div class="security-icon">🇪🇺</div>
          <h3 class="security-title">Cumplimiento GDPR</h3>
          <p class="security-desc">La infraestructura principal del producto se apoya en la Unión Europea y el tratamiento se ajusta al RGPD. Cuando intervienen proveedores internacionales auxiliares, aplicamos las garantías contractuales correspondientes.</p>
        </div>
        <div class="security-card">
          <div class="security-icon">👤</div>
          <h3 class="security-title">Mínimo dato de operario</h3>
          <p class="security-desc">Los operarios acceden con código de empresa, sin cuenta personal. Buscamos minimizar el dato personal y limitarlo a la identificación operativa básica necesaria para registrar la ejecución cuando aplique.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CONFIANZA OPERATIVA -->
  <section class="section section-center" id="confianza-operativa">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Confianza operativa</div>
        <h2 class="section-title">Qué deja REELEVO y <em>para qué te sirve</em></h2>
        <p class="section-sub">
          REELEVO no es solo una biblioteca de procesos. También puede dejar una base útil
          para operación, formación, calidad y seguimiento interno.
        </p>
      </div>

      <div class="trust-grid fade-up delay-1">
        <div class="trust-card">
          <div class="trust-label">Qué queda</div>
          <h3 class="trust-title">Proceso, momento y resultado</h3>
          <p class="trust-desc">Qué proceso se siguió, en qué puesto o máquina, cuándo ocurrió y cómo acabó el flujo.</p>
        </div>
        <div class="trust-card">
          <div class="trust-label">Quién</div>
          <h3 class="trust-title">Cuando el flujo lo necesita</h3>
          <p class="trust-desc">Si la empresa necesita más seguimiento, puede asociar el uso a un identificador interno de trabajo.</p>
        </div>
        <div class="trust-card">
          <div class="trust-label">Para qué sirve</div>
          <h3 class="trust-title">Formación, calidad y operación</h3>
          <p class="trust-desc">Aporta una base más útil para onboarding, auditoría interna, revisión de incidencias y seguimiento operativo.</p>
        </div>
      </div>

      <div class="trust-compare fade-up delay-2">
        <article class="trust-compare-card">
          <div class="trust-label">Consulta rápida</div>
          <h3 class="trust-title">Cuando lo importante es desbloquear el puesto</h3>
          <p class="trust-desc">Prioriza velocidad y adopción: alguien encuentra qué hacer y arranca con la mínima fricción posible.</p>
        </article>
        <article class="trust-compare-card featured">
          <div class="trust-label">Seguimiento asociado</div>
          <h3 class="trust-title">Cuando necesitas una base más útil de evidencia</h3>
          <p class="trust-desc">Añade seguimiento con identificador interno para flujos donde necesitas más claridad en formación, calidad o auditorías.</p>
        </article>
      </div>

      <div class="trust-note fade-up delay-3">
        REELEVO no sustituye por sí solo una certificación formal ni el criterio del responsable.
        Sí aporta una base mucho más útil que una simple asistencia o una explicación verbal.
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- SOPORTE Y ACOMPAÑAMIENTO -->
  <section class="section section-center" id="acompanamiento">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Soporte y acompañamiento</div>
        <h2 class="section-title">Qué puedes esperar de REELEVO<br><em>antes y después de arrancar</em></h2>
        <p class="section-sub">
          La confianza no se construye solo con infraestructura. También importa saber cómo se arranca,
          qué soporte vas a tener y dónde ponemos los límites del servicio.
        </p>
      </div>

      <div class="continuity-grid fade-up delay-1">
        <article class="continuity-card">
          <h3 class="continuity-title">Arranque asistido</h3>
          <p class="continuity-desc">Te ayudamos a aterrizar los primeros procesos críticos para que el valor se vea pronto y no se convierta en un proyecto teórico.</p>
        </article>
        <article class="continuity-card">
          <h3 class="continuity-title">Soporte en español</h3>
          <p class="continuity-desc">El acompañamiento comercial y operativo se hace en español, con una conversación directa y sin pasar por capas innecesarias.</p>
        </article>
        <article class="continuity-card">
          <h3 class="continuity-title">Requisitos claros</h3>
          <p class="continuity-desc">Si para tu entorno hace falta revisar red, permisos o una integración concreta, lo dejamos claro antes de comprometer fechas o alcance.</p>
        </article>
        <article class="continuity-card">
          <h3 class="continuity-title">Límites explícitos</h3>
          <p class="continuity-desc">No vendemos una promesa legal o sectorial que el producto no pueda sostener. Preferimos encajar bien el caso antes que sobredimensionarlo.</p>
        </article>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- FAQ PORTABILIDAD -->
  <section class="section" id="portabilidad">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Portabilidad y continuidad</div>
        <h2 class="section-title">Preguntas sobre <em>tus datos y continuidad</em></h2>
        <p class="section-sub">
          Las preguntas que se hace cualquier empresa antes de confiar su conocimiento operativo a un proveedor.
        </p>
      </div>

      <div class="faq-list fade-up delay-1">
        <div class="faq-item-static">
          <h3 class="faq-q">¿Dónde se almacenan mis datos?</h3>
          <p class="faq-a">Los datos operativos del producto se alojan principalmente en infraestructura dentro de la Unión Europea. Algunos servicios auxiliares del sitio web o de analítica pueden implicar proveedores internacionales, siempre bajo las garantías contractuales adecuadas y con el alcance limitado a su función.</p>
        </div>
        <div class="faq-item-static">
          <h3 class="faq-q">¿Puedo exportar todos mis procesos documentados?</h3>
          <p class="faq-a">Sí. Desde el panel de administración puedes exportar en cualquier momento todos los procesos, pasos e instrucciones en formato CSV y Excel (plan Profesional). Los datos son tuyos y siempre accesibles.</p>
        </div>
        <div class="faq-item-static">
          <h3 class="faq-q">¿Qué pasa si REELEVO deja de operar?</h3>
          <p class="faq-a">En caso de cierre del servicio, avisaríamos con un mínimo de 90 días de antelación y facilitaríamos la exportación completa de todos tus datos y procesos. El conocimiento que has documentado siempre será tuyo, no queda cautivo en nuestra plataforma.</p>
        </div>
        <div class="faq-item-static">
          <h3 class="faq-q">¿Durante cuánto tiempo se guardan los registros de actividad?</h3>
          <p class="faq-a">Los registros de actividad (quién consultó qué proceso y cuándo) se conservan durante el tiempo que estés suscrito, más 12 meses adicionales tras la baja. Puedes exportar el histórico completo en cualquier momento.</p>
        </div>
        <div class="faq-item-static">
          <h3 class="faq-q">¿Qué queda registrado realmente?</h3>
          <p class="faq-a">REELEVO puede dejar una base útil sobre el proceso seguido, el puesto o máquina, la fecha y hora, la versión visible y el resultado del flujo. Cuando la empresa necesita más seguimiento, puede asociar el flujo a un identificador interno.</p>
        </div>
        <div class="faq-item-static">
          <h3 class="faq-q">¿Qué diferencia hay entre consulta rápida y seguimiento asociado?</h3>
          <p class="faq-a">La consulta rápida prioriza que alguien encuentre el proceso y desbloquee el puesto con la mínima fricción. El seguimiento asociado añade un identificador interno cuando la empresa necesita acompañar onboarding, calidad, auditorías o seguimiento interno.</p>
        </div>
        <div class="faq-item-static">
          <h3 class="faq-q">¿Necesitamos IT para arrancar?</h3>
          <p class="faq-a">Para las funciones básicas no necesitas IT. Si tu red corporativa tiene restricciones de firewall o proxy, puede ser necesaria una apertura de dominio, algo que se resuelve en minutos con cualquier técnico de red. Las integraciones con ERP o sistemas de RRHH sí requieren colaboración de IT.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-eyebrow fade-up">¿Hablamos?</div>
    <h2 class="cta-title fade-up delay-1">
      Cuéntanos tu situación.<br><em>Sin presión, sin script de ventas.</em>
    </h2>
    <p class="cta-sub fade-up delay-2">
      Somos un equipo pequeño. Si contactas, hablará contigo alguien que entiende el producto
      y el problema que intentas resolver.
    </p>
    <div class="cta-actions fade-up delay-3">
      <a href="mailto:hola@gmvsolutions.es" class="btn-primary">
        Escribirnos directamente →
      </a>
      <a href="https://app.gmvsolutions.es/registro" class="btn-ghost">
        Registrarme en REELEVO
      </a>
    </div>
    <div class="cta-note fade-up delay-4">
      Respuesta en menos de 24h · Sin compromiso
    </div>
  </section>
</BaseLayout>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .about-text p {
    font-size: .9rem;
    color: var(--gray);
    line-height: 1.75;
    margin-bottom: 16px;
  }

  .about-values {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .value-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 24px;
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .value-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .value-title {
    font-family: 'Oswald', sans-serif;
    font-size: .95rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .03em;
    margin-bottom: 6px;
  }

  .value-desc {
    font-size: .85rem;
    color: var(--gray);
    line-height: 1.6;
  }

  .authority-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .authority-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 28px 24px;
    text-align: left;
  }

  .authority-title {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: .03em;
    margin-bottom: 10px;
  }

  .authority-desc {
    font-size: .86rem;
    color: var(--gray);
    line-height: 1.65;
  }

  /* Security grid */
  .security-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .security-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 32px 28px;
  }

  .security-icon {
    font-size: 2rem;
    margin-bottom: 16px;
  }

  .security-title {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .03em;
    margin-bottom: 10px;
  }

  .security-desc {
    font-size: .88rem;
    color: var(--gray);
    line-height: 1.65;
  }

  .trust-grid,
  .trust-compare {
    display: grid;
    gap: 24px;
    margin-top: 48px;
  }

  .trust-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .trust-compare {
    grid-template-columns: repeat(2, 1fr);
    margin-top: 24px;
  }

  .trust-card,
  .trust-compare-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 28px 24px;
    text-align: left;
  }

  .trust-compare-card.featured {
    border-color: rgba(244,82,30,.35);
    box-shadow: inset 0 0 0 1px rgba(244,82,30,.12);
  }

  .trust-label {
    font-family: 'DM Mono', monospace;
    font-size: .62rem;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 12px;
  }

  .trust-title {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: .03em;
    margin-bottom: 10px;
    color: var(--white);
  }

  .trust-desc {
    font-size: .86rem;
    color: var(--gray);
    line-height: 1.65;
  }

  .trust-note {
    max-width: 760px;
    margin: 24px auto 0;
    padding: 20px 22px;
    background: rgba(255,255,255,.03);
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: .86rem;
    color: var(--gray);
    line-height: 1.7;
    text-align: left;
  }

  .continuity-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-top: 44px;
  }

  .continuity-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 28px 24px;
    text-align: left;
  }

  .continuity-title {
