---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Dozuki vs REELEVO — Comparativa de software SOP para pymes industriales";
const description = "Comparativa detallada: Dozuki vs REELEVO. Análisis de funcionalidades, precio, idioma y enfoque. ¿Cuál es mejor para tu pyme industrial española?";

const schema = {
  "@context": "https://schema.org",
  "@type": "ComparisonChart",
  "headline": title,
  "description": description,
  "url": "https://www.gmvsolutions.es/vs-dozuki/",
  "inLanguage": "es-ES",
  "about": [
    {
      "@type": "SoftwareApplication",
      "name": "REELEVO"
    },
    {
      "@type": "SoftwareApplication",
      "name": "Dozuki"
    }
  ]
};
---

<!-- GLOSSARY: operario, baja, onboarding, competencias, tutor, incorporación, SOP, continuidad -->
<!-- CONTEXT: operational, marketing, product -->
<!-- EN_TERMS: [machine operator, absence, onboarding, skills, mentor, operator onboarding, standard operating procedure, continuity] -->
<!-- PT_TERMS: [operador, falta, integração, competências, mentor, integração de operadores, procedimento operativo padrão, continuidade] -->

<BaseLayout title={title} description={description} schema={schema} activeNav="">
  <!-- PAGE HERO -->
  <section class="page-hero">
    <div class="eyebrow fade-up">Comparativa de herramientas</div>
    <h1 class="fade-up delay-1">Dozuki vs REELEVO<br><em>¿Cuál es mejor para tu pyme?</em></h1>
    <p class="fade-up delay-2">Análisis completo de software SOP industrial: funcionalidades, precio, idioma y enfoque de mercado.</p>
  </section>

  <div class="divider"></div>

  <!-- COMPARATIVA DIRECTA -->
  <section class="section" id="comparativa">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Comparación directa</div>
        <h2 class="section-title">Caracteristicas clave</h2>
      </div>

      <div class="comparison-table fade-up delay-1">
        <table>
          <thead>
            <tr>
              <th style="width: 30%;">Característica</th>
              <th style="width: 35%;">Dozuki</th>
              <th style="width: 35%;">REELEVO</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>Idioma interfaz</strong></td>
              <td>English (multiidioma limitado)</td>
              <td class="highlight">✓ Spanish (native)</td>
            </tr>
            <tr>
              <td><strong>Precio publicado</strong></td>
              <td>No publicado (demo/contacto)</td>
              <td class="highlight">✓ Transparente (desde 49€/mes)</td>
            </tr>
            <tr>
              <td><strong>Especialización</strong></td>
              <td>Global enterprise</td>
              <td class="highlight">✓ Pymes industriales españolas</td>
            </tr>
            <tr>
              <td><strong>Documentación SOP</strong></td>
              <td>✓ Sí</td>
              <td class="highlight">✓ Sí</td>
            </tr>
            <tr>
              <td><strong>Gestión competencias</strong></td>
              <td>No incluido</td>
              <td class="highlight">✓ Matriz de habilidades</td>
            </tr>
            <tr>
              <td><strong>Onboarding operarios</strong></td>
              <td>No específico</td>
              <td class="highlight">✓ Diseñado para operarios</td>
            </tr>
            <tr>
              <td><strong>Acceso en planta</strong></td>
              <td>Web + app</td>
              <td class="highlight">✓ Web + app + acceso offline</td>
            </tr>
            <tr>
              <td><strong>Soporte atención</strong></td>
              <td>English principalmente</td>
              <td class="highlight">✓ Español</td>
            </tr>
            <tr>
              <td><strong>Curva aprendizaje</strong></td>
              <td>Media-Alta (enterprise)</td>
              <td class="highlight">✓ Baja (pymes)</td>
            </tr>
            <tr>
              <td><strong>Capacitación inicial</strong></td>
              <td>Contacto para info</td>
              <td class="highlight">✓ Incluida</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ANÁLISIS DETALLADO -->
  <section class="section">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Análisis detallado</div>
        <h2 class="section-title">Dónde difieren</h2>
      </div>

      <div class="comparison-cards fade-up delay-1">
        <div class="comparison-card">
          <h3>Dozuki: Fortalezas</h3>
          <ul>
            <li>Líder global en software SOP</li>
            <li>Amplia base de usuarios internacionales</li>
            <li>Integración con muchos sistemas enterprise</li>
            <li>Comunidad activa con recursos</li>
            <li>Bueno para empresas grandes multiidioma</li>
          </ul>
        </div>

        <div class="comparison-card">
          <h3>Dozuki: Debilidades</h3>
          <ul>
            <li>Precio no transparente</li>
            <li>Diseñado para manufactura global, no pymes</li>
            <li>Interfaz en inglés (barrera en España)</li>
            <li>Soporte en inglés principalmente</li>
            <li>Curva aprendizaje alta para operarios</li>
            <li>Overkill de features para pymes</li>
          </ul>
        </div>

        <div class="comparison-card">
          <h3>REELEVO: Fortalezas</h3>
          <ul>
            <li>Precio transparente (49€-99€/mes)</li>
            <li>Diseñado para pymes industriales españolas</li>
            <li>Interfaz 100% en español</li>
            <li>Soporte 100% en español</li>
            <li>Incluye gestión de competencias</li>
            <li>Simple para operarios (acceso en máquina)</li>
            <li>Onboarding integrado</li>
          </ul>
        </div>

        <div class="comparison-card">
          <h3>REELEVO: Desarrollo</h3>
          <ul>
            <li>Comunidad más pequeña (en crecimiento)</li>
            <li>Menos integraciones enterprise (no las necesita pyme típica)</li>
            <li>Enfoque exclusivo en pymes (no es escala para multinacionales)</li>
            <li>Más reciente que Dozuki en mercado</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CASOS DE USO -->
  <section class="section">
    <div class="section-inner">
      <div class="fade-up">
        <h2 class="section-title">¿Cuándo elegir cada uno?</h2>
      </div>

      <div class="use-case-grid fade-up delay-1">
        <div class="use-case-card">
          <h3>Elige Dozuki si...</h3>
          <ul>
            <li>Eres una empresa grande (500+ empleados)</li>
            <li>Tienes operaciones en múltiples países</li>
            <li>Necesitas integraciones complejas enterprise</li>
            <li>Tienes presupuesto ilimitado IT</li>
            <li>Tu equipo es multiidioma y prefiere inglés</li>
          </ul>
        </div>

        <div class="use-case-card highlight">
          <h3>Elige REELEVO si...</h3>
          <ul>
            <li>Eres pyme industrial (10-200 empleados)</li>
            <li>Operas principalmente en España</li>
            <li>Necesitas precio transparente y predecible</li>
            <li>Tus operarios son hispanohablantes</li>
            <li>Quieres onboarding + SOP + competencias</li>
            <li>Necesitas implementación rápida</li>
            <li>Presupuesto IT limitado</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ANÁLISIS ECONÓMICO -->
  <section class="section">
    <div class="section-inner">
      <div class="fade-up">
        <h2 class="section-title">Análisis de coste</h2>
      </div>

      <div class="cost-comparison fade-up delay-1">
        <div class="cost-card">
          <h4>DOZUKI</h4>
          <p class="cost-amount">Precio: No publicado</p>
          <p class="cost-note">Típicamente: 200-500€/mes (mínimo)</p>
          <ul>
            <li>Configuración inicial: $2,000-5,000</li>
            <li>Capacitación: Adicional</li>
            <li>Soporte: Según plan</li>
          </ul>
        </div>

        <div class="cost-card highlight">
          <h4>REELEVO</h4>
          <p class="cost-amount">Desde 49€/mes</p>
          <p class="cost-note">Transparente y escalable</p>
          <ul>
            <li>Setup: Incluido</li>
            <li>Capacitación: Incluida</li>
            <li>Soporte: Incluido en español</li>
            <li>Sin contratos a largo plazo</li>
          </ul>
        </div>
      </div>

      <div class="roi-note fade-up delay-2">
        <p><strong>Nota sobre ROI:</strong> Para una pyme industrial de 50 empleados con 5 operarios en puestos críticos, la documentación de procesos con REELEVO típicamente se paga en 1-2 meses evitando paradas por falta de cobertura.</p>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-eyebrow fade-up">Siguiente paso</div>
    <h2 class="cta-title fade-up delay-1">
      ¿Listo para probar <em>REELEVO</em>?
    </h2>
    <p class="cta-sub fade-up delay-2">
      REELEVO está diseñado específicamente para pymes industriales españolas. Sin sorpresas de precio, con soporte en español y enfoque operativo.
    </p>
    <div class="cta-actions fade-up delay-3">
      <a href="https://app.gmvsolutions.es/registro" class="btn-primary">
        Registrarse gratis
      </a>
      <a href="https://diagnostico.gmvsolutions.es" class="btn-ghost">
        Ver caso de tu sector →
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .comparison-table {
    overflow-x: auto;
    margin-top: 40px;
  }

  .comparison-table table {
    width: 100%;
    border-collapse: collapse;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
  }

  .comparison-table th,
  .comparison-table td {
    padding: 16px;
    text-align: left;
    border-bottom: 1px solid var(--border);
  }

  .comparison-table th {
    background: var(--surface2);
    font-weight: 600;
    font-size: 0.9rem;
  }

  .comparison-table tbody tr:last-child td {
    border-bottom: none;
  }

  .comparison-table td.highlight {
    background: rgba(255, 150, 0, 0.05);
    color: var(--orange);
    font-weight: 500;
  }

  .comparison-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 40px;
  }

  .comparison-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 28px;
  }

  .comparison-card h3 {
    font-family: 'Oswald', sans-serif;
    font-size: 1.1rem;
    margin-bottom: 16px;
    color: var(--text);
  }

  .comparison-card ul {
    list-style: none;
    padding: 0;
  }

  .comparison-card li {
    padding: 8px 0;
    color: var(--gray);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .comparison-card li:before {
    content: "→ ";
    color: var(--orange);
    font-weight: 600;
    margin-right: 8px;
  }

  .use-case-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 40px;
  }

  .use-case-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 28px;
  }

  .use-case-card.highlight {
    border-color: var(--orange);
    background: rgba(255, 150, 0, 0.02);
  }

  .use-case-card h3 {
    font-family: 'Oswald', sans-serif;
    font-size: 1.1rem;
    margin-bottom: 16px;
  }

  .use-case-card.highlight h3 {
    color: var(--orange);
  }

  .use-case-card ul {
    list-style: none;
    padding: 0;
  }

  .use-case-card li {
    padding: 8px 0;
    color: var(--gray);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .use-case-card li:before {
    content: "✓ ";
    color: var(--orange);
    font-weight: 600;
    margin-right: 8px;
  }

  .cost-comparison {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 40px;
  }

  .cost-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 28px;
  }

  .cost-card.highlight {
    border-color: var(--orange);
    background: rgba(255, 150, 0, 0.02);
  }

  .cost-card h4 {
    font-family: 'Oswald', sans-serif;
    font-size: 1rem;
    margin-bottom: 12px;
  }

  .cost-amount {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--orange);
    margin-bottom: 4px;
  }

  .cost-note {
    font-size: 0.85rem;
    color: var(--gray2);
    margin-bottom: 16px;
  }

  .cost-card ul {
    list-style: none;
    padding: 0;
    font-size: 0.9rem;
    color: var(--gray);
  }

  .cost-card li {
    padding: 6px 0;
    border-top: 1px solid var(--border);
    padding-top: 12px;
  }

  .cost-card li:first-child {
    border: none;
    padding-top: 0;
  }

  .roi-note {
    background: rgba(255, 150, 0, 0.08);
    border-left: 4px solid var(--orange);
    padding: 20px;
    border-radius: 4px;
    margin-top: 40px;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .comparison-cards,
    .use-case-grid,
    .cost-comparison {
      grid-template-columns: 1fr;
    }

    .comparison-table {
      font-size: 0.85rem;
    }

    .comparison-table th,
    .comparison-table td {
      padding: 12px;
    }
  }
</style>
