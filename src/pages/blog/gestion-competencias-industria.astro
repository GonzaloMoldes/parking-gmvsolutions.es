    background: var(--surface2);
    border-radius: 4px;
    padding: 12px;
    font-size: .9rem;
    margin-top: 16px;
    text-align: left;
  }

  .niveles-tabla {
    display: grid;
    gap: 20px;
    margin: 32px 0;
  }

  .nivel {
    background: var(--surface);
    border-left: 4px solid var(--orange);
    border-radius: 4px;
    padding: 24px;
  }

  .nivel-badge {
    display: inline-block;
    background: var(--orange);
    color: var(--white);
    padding: 4px 12px;
    border-radius: 20px;
    font-size: .75rem;
