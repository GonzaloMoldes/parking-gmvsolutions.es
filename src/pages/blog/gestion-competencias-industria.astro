    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .caso-header h3 {
    margin: 0;
  }

  .caso-badge {
    font-size: .8rem;
    background: var(--surface2);
    padding: 4px 12px;
    border-radius: 4px;
  }

  .cta-box {
    background: var(--surface2);
    border: 2px solid var(--orange);
    border-radius: 8px;
    padding: 40px;
    text-align: center;
    margin: 48px 0;
  }

  .btn-secondary {
    display: inline-block;
    background: var(--orange);
    color: var(--white);
    padding: 12px 28px;
    border-radius: 4px;
