---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "REELEVO — Industrial onboarding software for SMEs | Skills management on the shop floor";
const description = "REELEVO is an HR platform with industrial onboarding software. Streamline new operator training, manage production skills, improve process documentation, and reduce key person risk on the factory floor.";
const canonical = "https://www.gmvsolutions.es/en/";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "REELEVO",
    "url": "https://www.gmvsolutions.es/en"
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": "https://www.gmvsolutions.es/en#organization",
    "name": "GMV Solutions",
    "alternateName": "REELEVO",
    "url": "https://www.gmvsolutions.es/en",
    "logo": "https://www.gmvsolutions.es/favicon.svg",
    "description": "REELEVO helps industrial SMEs reduce dependency on key personnel, streamline operator training, and gain more visibility into what's happening on the shop floor.",
    "email": "hola@gmvsolutions.es",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Rua Marola",
      "addressLocality": "A Coruña",
      "postalCode": "15002",
      "addressCountry": "ES"
    },
    "foundingDate": "2025",
    "areaServed": "ES",
    "knowsAbout": [
      "Industrial SOP software",
      "Standard Operating Procedures",
      "Operational documentation",
      "Operational continuity on shop floor",
      "Industrial operational visibility",
      "Reduction of operational dependency",
      "Operational learning on the floor",
      "Operator onboarding",
      "Absence coverage in production",
      "Temp workers in manufacturing",
      "Spanish industrial SMEs"
    ],
    "sameAs": [
      "https://www.linkedin.com/company/gmvsolutions"
    ]
  }
];
---

<BaseLayout title={title} description={description} canonical={canonical} schema={schema} activeNav="">

  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="hero-eyebrow fade-up">Industrial onboarding software · HR software · More structured execution</div>
    <h1 class="hero-title fade-up delay-1">
      Onboarding software for industrial SMEs<br>
      with skills management<br>
      <em>on the shop floor</em>.
    </h1>
    <p class="hero-sub fade-up delay-2">
      REELEVO is an onboarding platform built for industrial SMEs. Streamline operator training, manage production skills, reduce key person risk, and improve process documentation.<br>
      <strong>Production gains context for better decisions, HR organizes training more effectively, the company understands what skills each team has and strengthens documentation on the shop floor</strong>.
    </p>
    <div class="hero-actions fade-up delay-3">
      <a href="https://app.gmvsolutions.es/registro" class="btn-primary">Sign up for REELEVO</a>
      <a href="https://diagnostico.gmvsolutions.es/?lang=en" class="btn-ghost">Assess my situation →</a>
    </div>
    <div class="hero-proof fade-up delay-4">
      <div class="hero-proof-item">
        <div class="hero-proof-num">Continuity</div>
        <div class="hero-proof-label">less dependency when your best operator is unavailable</div>
      </div>
      <div class="hero-proof-item">
        <div class="hero-proof-num">Visibility</div>
        <div class="hero-proof-label">clarity about what's really happening on the shop floor</div>
      </div>
      <div class="hero-proof-item">
        <div class="hero-proof-num">€49</div>
        <div class="hero-proof-label">per month per company</div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ═══ THE PROBLEM ═══ -->
  <section class="section" id="casos">
    <div class="section-inner">
      <div class="casos-header fade-up">
        <div class="eyebrow">Day to day</div>
        <h2 class="section-title">Does this sound familiar?</h2>
        <p class="section-sub">
          Two moments that show whether your processes live on the shop floor
          or still only in someone's head.
        </p>
      </div>

      <div class="casos fade-up delay-1">
        <div class="caso">
          <div class="caso-tag">Your expert is out</div>
          <h3 class="caso-title">
            «Javi is on sick leave.<br>
            Who starts up<br>
            the filling line?»
          </h3>
          <p class="caso-desc">
            It's Tuesday at 6:30 AM. Javi has been running that machine for 15 years and he's in urgent care right now.
            His substitute doesn't know the process. The line won't start until someone figures it out or until Javi answers his phone.
          </p>
          <ul class="caso-benefits">
            <li>2-4 hours of line downtime searching for answers</li>
            <li>Pressure on the team to cover</li>
            <li>Errors from improvising without clear instructions</li>
            <li>Calls to your expert while he's on sick leave just to get by</li>
            <li>Late orders and frustrated customers</li>
          </ul>
        </div>

        <div class="caso">
          <div class="caso-tag">New operator arrives</div>
          <h3 class="caso-title">
            «It's their first day.<br>
            Someone has to<br>
            train them.»
          </h3>
          <p class="caso-desc">
            A new person arrives — permanent hire, temp worker, whoever — and needs to learn the role.
            One of your best operators steps away from their machine to mentor for days.
            Two people tied up, one position producing.
          </p>
          <ul class="caso-benefits">
            <li>Your best operator loses productivity while training</li>
            <li>Two people doing the work of one for days</li>
            <li>Learning depends on who trains and how they teach it</li>
            <li>Higher error risk during training</li>
            <li>In busy seasons or peak demand, the problem multiplies with each new temp worker</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ═══ DATA ═══ -->
  <section class="section section-center">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">What the numbers say</div>
        <h2 class="section-title">The cost nobody measures</h2>
        <p class="section-sub">
          These are numbers from the Spanish industrial sector. Most SMEs and workshops
          accept this as "normal." It isn't.
        </p>
      </div>

      <div class="dolor-grid fade-up delay-1">
        <div class="dolor-item">
          <div class="dolor-num">7.2<sup>%</sup></div>
          <div class="dolor-label">
            <strong>Average absenteeism rate</strong> in industrial SMEs.
            1 in 14 workers absent every day.
          </div>
        </div>
        <div class="dolor-item">
          <div class="dolor-num">3-5</div>
          <div class="dolor-label">
            <strong>Days to ramp up</strong> until a new operator performs at the level
            of the experienced operator.
          </div>
        </div>
        <div class="dolor-item">
          <div class="dolor-num">40<sup>%</sup></div>
          <div class="dolor-label">
            <strong>Of production managers</strong> call their expert directly
            when someone is absent. Even if they're on sick leave.
          </div>
        </div>
      </div>

      <div class="dolor-cta fade-up delay-2">
        <a href="https://diagnostico.gmvsolutions.es/?lang=en" class="btn-primary">
          Evaluate my situation →
        </a>
        <div class="dolor-cta-note">
          Free calculator · Results in 2 minutes
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ═══ 4 PILLARS ═══ -->
  <section class="section section-center">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Real product value</div>
        <h2 class="section-title">Four benefits you'll notice <em>on the shop floor</em></h2>
        <p class="section-sub">
          REELEVO doesn't stop at documenting processes. It helps work happen with less improvisation,
          more clarity, and much more useful knowledge transfer.
        </p>
      </div>

      <div class="steps-grid steps-grid-four fade-up delay-1">
        <div class="step-card">
          <div class="step-card-icon">📲</div>
          <h3 class="step-card-title">1. Structured onboarding from day one</h3>
          <p class="step-card-desc">
            The new operator finds clear instructions at the workstation. Your onboarding software reduces repetitive training and speeds up onboarding with less expert dependency.
          </p>
        </div>
        <div class="step-card">
          <div class="step-card-icon">🧾</div>
          <h3 class="step-card-title">2. More clarity to decide better</h3>
          <p class="step-card-desc">
            Production gains context about what's being done and where the shift gets blocked,
            without depending only on calls, reports, or memory.
          </p>
        </div>
        <div class="step-card">
          <div class="step-card-icon">📊</div>
          <h3 class="step-card-title">3. Skills management and onboarding</h3>
          <p class="step-card-desc">
            See skills by operator and process. Onboarding becomes consistent and you stop depending on memory. Each hire is documented.
          </p>
        </div>
        <div class="step-card">
          <div class="step-card-icon">✅</div>
          <h3 class="step-card-title">4. Industrial onboarding with traceability</h3>
          <p class="step-card-desc">
            What happens on the floor leaves evidence of execution. Better data for onboarding, reduced operator dependency, and more structured operations.
          </p>
        </div>
      </div>

      <div class="steps-cta fade-up delay-2">
        <a href="/en/como-funciona/" class="btn-ghost">See the complete flow →</a>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ═══ PRODUCT IN ACTION ═══ -->
  <section class="section section-center" id="producto">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">The product</div>
        <h2 class="section-title">This is what <em>you'll see on your shop floor</em></h2>
        <p class="section-sub">
          Company dashboard, operator work view, and activity visibility.
          The value isn't just consulting instructions: it's working with less friction and more order.
        </p>
      </div>

      <div class="screenshots-wrap fade-up delay-1">
        <div class="screenshots-track" id="screenshotsTrack">
          <div class="screenshot-slide">
            <div class="screenshot-frame">
              <img src="/screenshots/admin-dashboard.png" alt="REELEVO company dashboard with processes, machines, and operational configuration" loading="lazy">
            </div>
            <div class="screenshot-caption">Company dashboard — a more structured view of processes, stations, and operations</div>
          </div>
          <div class="screenshot-slide">
            <div class="screenshot-frame">
              <img src="/screenshots/sop-operario.png" alt="REELEVO operator view with access to process from the workstation" loading="lazy">
            </div>
            <div class="screenshot-caption">Operator view — work appears at the workstation when needed, without unnecessary friction</div>
          </div>
          <div class="screenshot-slide">
            <div class="screenshot-frame">
              <img src="/screenshots/monitor-actividad.png" alt="REELEVO activity monitor" loading="lazy">
            </div>
            <div class="screenshot-caption">Production view — more context to see activity and decide with less improvisation</div>
          </div>
          <div class="screenshot-slide">
            <div class="screenshot-frame">
              <img src="/screenshots/Captura de pantalla 2026-03-31 161924.png" alt="Weekly operator planning" loading="lazy">
            </div>
            <div class="screenshot-caption">Weekly planning — visual task and shift assignment</div>
          </div>
          <div class="screenshot-slide">
            <div class="screenshot-frame">
              <img src="/screenshots/Captura de pantalla 2026-03-31 162126.png" alt="Product and process management" loading="lazy">
            </div>
            <div class="screenshot-caption">Product management — process definition and combinations</div>
          </div>
          <div class="screenshot-slide">
            <div class="screenshot-frame">
              <img src="/screenshots/Captura de pantalla 2026-03-31 162150.png" alt="Operations team dashboard" loading="lazy">
            </div>
            <div class="screenshot-caption">Operations team — activity tracking and skills</div>
          </div>
          <div class="screenshot-slide">
            <div class="screenshot-frame">
              <img src="/screenshots/Captura de pantalla 2026-03-31 162218.png" alt="Operator skills detail" loading="lazy">
            </div>
            <div class="screenshot-caption">Skills detail — certifications and operator capabilities</div>
          </div>
          <div class="screenshot-slide">
            <div class="screenshot-frame">
              <img src="/screenshots/Captura de pantalla 2026-03-31 162300.png" alt="Productivity and analytics dashboard" loading="lazy">
            </div>
            <div class="screenshot-caption">Productivity — process analytics and performance</div>
          </div>
          <div class="screenshot-slide">
            <div class="screenshot-frame">
              <img src="/screenshots/Captura de pantalla 2026-03-31 162618.png" alt="Process details and timing" loading="lazy">
            </div>
            <div class="screenshot-caption">Process detail — timing, steps, and efficiency</div>
          </div>
        </div>
        <button class="carousel-btn carousel-prev" id="carPrev" aria-label="Previous">←</button>
        <button class="carousel-btn carousel-next" id="carNext" aria-label="Next">→</button>
        <div class="carousel-dots" id="carDots">
          <button class="carousel-dot is-active" aria-label="Screen 1"></button>
          <button class="carousel-dot" aria-label="Screen 2"></button>
          <button class="carousel-dot" aria-label="Screen 3"></button>
          <button class="carousel-dot" aria-label="Screen 4"></button>
          <button class="carousel-dot" aria-label="Screen 5"></button>
          <button class="carousel-dot" aria-label="Screen 6"></button>
          <button class="carousel-dot" aria-label="Screen 7"></button>
          <button class="carousel-dot" aria-label="Screen 8"></button>
          <button class="carousel-dot" aria-label="Screen 9"></button>
        </div>
      </div>

      <div class="visual-proof-grid fade-up delay-2">
        <article class="visual-proof-card">
          <div class="visual-proof-tag">At the workstation</div>
          <h3 class="visual-proof-title">The substitute doesn't start blind</h3>
          <p class="visual-proof-desc">
            The work view shows that the process appears where it's needed,
            with less searching, fewer calls, and less dependency on the primary operator.
          </p>
        </article>

        <article class="visual-proof-card">
          <div class="visual-proof-tag">For production</div>
          <h3 class="visual-proof-title">There's more context to decide better</h3>
          <p class="visual-proof-desc">
            The production view turns shift activity into a clearer view
            to reorganize, spot bottlenecks, and act sooner.
          </p>
        </article>

        <article class="visual-proof-card">
          <div class="visual-proof-tag">For tracking</div>
          <h3 class="visual-proof-title">Work leaves a useful record</h3>
          <p class="visual-proof-desc">
            The company dashboard shows that REELEVO doesn't stop at viewing:
            it helps sustain training, continuity, and internal review with more facts.
          </p>
        </article>
      </div>

      <div class="screenshots-cta fade-up delay-3">
        <a href="https://app.gmvsolutions.es/registro" class="btn-ghost">Sign up for REELEVO →</a>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ═══ WHO IS IT FOR ═══ -->
  <section class="section" id="perfiles">
    <div class="section-inner">
      <div class="perfiles-header fade-up">
        <div class="eyebrow">Who is this for?</div>
        <h2 class="section-title">Each person sees a different value</h2>
        <p class="section-sub">
          REELEVO fits different priorities across the plant.
          Production gains clarity to decide, HR organizes training better,
          quality reviews what happens on the floor better, and management reduces operational dependency.
        </p>
      </div>

      <div class="perfiles-grid perfiles-grid-four fade-up delay-1">
        <div class="perfil-card">
          <div class="perfil-card-icon">👷</div>
          <h3 class="perfil-card-title">Production manager</h3>
          <p class="perfil-card-desc">
            More visibility to reorganize shifts, cover changes, and react sooner
            without depending as much on the experienced operator.
          </p>
          <a href="/en/para-quien/jefe-de-produccion/" class="perfil-card-link">See how it helps you →</a>
        </div>

        <div class="perfil-card">
          <div class="perfil-card-icon">👥</div>
          <h3 class="perfil-card-title">HR manager</h3>
          <p class="perfil-card-desc">
            More structured onboarding, less repetitive training, and more clarity
            about who needs support and who's ready for autonomy.
          </p>
          <a href="/en/para-quien/responsable-rrhh/" class="perfil-card-link">See how it helps you →</a>
        </div>

        <div class="perfil-card">
          <div class="perfil-card-icon">🧪</div>
          <h3 class="perfil-card-title">Quality manager</h3>
          <p class="perfil-card-desc">
            More clarity for internal review, process changes, and critical stations,
            without depending only on papers, memory, or conflicting versions.
          </p>
          <a href="/en/para-quien/responsable-calidad/" class="perfil-card-link">See how it helps you →</a>
        </div>

        <div class="perfil-card">
          <div class="perfil-card-icon">💼</div>
          <h3 class="perfil-card-title">Manager / Owner</h3>
          <p class="perfil-card-desc">
            Less operational fragility, more continuity, and a per-company price
            that makes it viable to start where it hurts most.
          </p>
          <a href="/en/para-quien/gerente-propietario/" class="perfil-card-link">See how it helps you →</a>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ═══ BENEFITS ═══ -->
  <section class="section section-center" id="beneficios">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">What changes on the floor</div>
        <h2 class="section-title">Operational impact <em>from the start</em></h2>
        <p class="section-sub">
          You start with critical processes, but the value shows right away:
          fewer bottlenecks, more clarity to decide, and more structured operations.
        </p>
      </div>

      <div class="benefits-grid fade-up delay-1">
        <div class="benefit-card">
          <div class="benefit-card-icon">⚡</div>
          <h3 class="benefit-card-title">The process appears where it's needed</h3>
          <p class="benefit-card-desc">
            When someone covers a station, they don't waste time looking for how to start.
            The instructions are there, at the right moment.
          </p>
        </div>

        <div class="benefit-card">
          <div class="benefit-card-icon">🎯</div>
          <h3 class="benefit-card-title">Less improvisation, more structure</h3>
          <p class="benefit-card-desc">
            Each process has the expert's real knowledge: the tricks, the adjustments,
            the signs that something's going to fail. Not the manual — the reality.
          </p>
        </div>

        <div class="benefit-card">
          <div class="benefit-card-icon">📈</div>
          <h3 class="benefit-card-title">Training gets shorter and more reliable</h3>
          <p class="benefit-card-desc">
            New operators train faster because the structure is clear.
            Your best operator spends less time training and more time producing.
          </p>
        </div>

        <div class="benefit-card">
          <div class="benefit-card-icon">🔍</div>
          <h3 class="benefit-card-title">You see what's really happening</h3>
          <p class="benefit-card-desc">
            Activity on the floor becomes visible. You know who's doing what, where there are delays,
            and where the problems are — not just guesses or late reports.
          </p>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ═══ PRECIOS ═══ -->
  <section class="section section-center">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Transparent pricing</div>
        <h2 class="section-title">One price, unlimited operators</h2>
        <p class="section-sub">
          No seat licenses. No hidden fees. Start with your critical processes and expand at your own pace.
        </p>
      </div>

      <div class="pricing-card fade-up delay-1">
        <div class="pricing-card-amount">€49<span class="pricing-card-period">/month</span></div>
        <div class="pricing-card-label">per company</div>
        <p class="pricing-card-detail">Unlimited operators, all critical processes you need</p>
        <ul class="pricing-card-features">
          <li>✓ Process documentation at the workstation</li>
          <li>✓ Operator onboarding tracking</li>
          <li>✓ Skills and competencies</li>
          <li>✓ Production visibility and analytics</li>
          <li>✓ Multi-language support</li>
          <li>✓ Email support included</li>
        </ul>
        <a href="https://app.gmvsolutions.es/registro" class="pricing-card-cta btn-primary">Get started free →</a>
        <p class="pricing-card-note">First 14 days free. No creditcard required.</p>
      </div>

      <div class="pricing-note fade-up delay-2">
        <p>See the <a href="/en/precios/">full pricing</a> page for volume discounts and custom plans.</p>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ═══ PILOT ═══ -->
  <section class="section section-center">
    <div class="section-inner">
      <div class="fade-up">
        <div class="eyebrow">Quick start</div>
        <h2 class="section-title">Start with a working pilot</h2>
        <p class="section-sub">
          Don't implement across your entire plant. Start with one critical process and see the impact in two weeks.
        </p>
      </div>

      <div class="pilot-grid fade-up delay-1">
        <div class="pilot-card">
          <div class="pilot-icon">📋</div>
          <div class="pilot-label">Week 1</div>
          <div class="pilot-title">Capture the expert's knowledge</div>
          <p class="pilot-desc">
            Sit down with your best operator. Document the process step by step: the real way she does it,
            not the manual.
          </p>
        </div>

        <div class="pilot-card">
          <div class="pilot-icon">📱</div>
          <div class="pilot-label">Week 2</div>
          <div class="pilot-title">Put it on the floor</div>
          <p class="pilot-desc">
            The substitute sees the steps on their phone, at the workstation.
            They execute without calling the expert. Time to productivity drops 60%.
          </p>
        </div>

        <div class="pilot-card">
          <div class="pilot-icon">📊</div>
          <div class="pilot-label">Week 3-4</div>
          <div class="pilot-title">Measure and scale</div>
          <p class="pilot-desc">
            See the impact: less downtime, faster onboarding, fewer errors.
            After that, pick the next process that needs the same treatment.
          </p>
        </div>
      </div>

      <div class="pilot-note fade-up delay-2">
        <p>First 14 days are free. <a href="https://app.gmvsolutions.es/registro">Start your pilot now →</a></p>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero section */
  .hero {
    background: linear-gradient(135deg, var(--bg) 0%, var(--surface) 100%);
    padding: 120px 32px;
    text-align: center;
    max-width: 1200px;
    margin: 0 auto;
  }

  .hero-eyebrow {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 24px;
  }

  .hero-title {
    font-family: 'Oswald', sans-serif;
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 24px;
  }

  .hero-title em {
    font-style: normal;
    color: var(--orange);
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--gray);
    line-height: 1.8;
    max-width: 800px;
    margin: 0 auto 48px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 80px;
  }

  .hero-proof {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 32px;
    max-width: 900px;
    margin: 0 auto;
  }

  .hero-proof-item {
    text-align: center;
  }

  .hero-proof-num {
    font-family: 'Oswald', sans-serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--orange);
    margin-bottom: 8px;
  }

  .hero-proof-label {
